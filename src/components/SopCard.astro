---
import StatusBadge from "./StatusBadge.astro";
import { formatDate } from "../lib/dates";

interface Props {
  title: string;
  purpose: string;
  category: string;
  tags?: string[];
  owner: string;
  lastUpdated: string;
  reviewDate: string;
  tools?: string[];
  status: string;
  url: string;
  estimatedCompletionTime?: string;
}

const {
  title,
  purpose,
  category,
  tags = [],
  owner,
  lastUpdated,
  reviewDate,
  tools = [],
  status,
  url,
  estimatedCompletionTime,
} = Astro.props;
---

<article class="sop-card">
  <div class="sop-card__topline">
    <span class="sop-card__category">{category}</span>
    <StatusBadge status={status} />
  </div>
  <h2><a href={url}>{title}</a></h2>
  <p class="sop-card__purpose">{purpose}</p>
  <dl class="compact-meta">
    <div>
      <dt>Owner</dt>
      <dd>{owner}</dd>
    </div>
    <div>
      <dt>Updated</dt>
      <dd>{formatDate(lastUpdated)}</dd>
    </div>
    <div>
      <dt>Review</dt>
      <dd>{formatDate(reviewDate)}</dd>
    </div>
  </dl>
  {
    estimatedCompletionTime && (
      <p class="sop-card__time">
        <span class="sop-card__time-icon" aria-hidden="true">⏱</span>
        {estimatedCompletionTime}
      </p>
    )
  }
  {
    tools.length > 0 && (
      <p class="sop-card__tools">
        <strong>Tools:</strong> {tools.join(", ")}
      </p>
    )
  }
  {
    tags.length > 0 && (
      <ul class="tag-list" aria-label="Tags">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )
  }
</article>

<style>
  .sop-card__category {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-ink);
    background: var(--color-linen);
    border: 1px solid var(--color-dune);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
  }

  .sop-card__purpose {
    flex: 1;
    color: var(--color-muted);
  }

  .sop-card__time {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0.5rem 0 0;
    font-size: 0.84rem;
    color: var(--color-muted);
  }

  .sop-card__time-icon {
    font-size: 0.9rem;
  }
</style>
