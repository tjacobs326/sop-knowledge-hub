---
const navGroups = [
  {
    label: "Normal Users",
    items: [
      { href: "/", label: "Home", icon: "H" },
      { href: "/search/", label: "Search SOPs" },
      { href: "/finder/", label: "Guided Finder" },
      { href: "/categories/", label: "Categories" },
      { href: "/submit/", label: "Submit Request" },
    ],
  },
  {
    label: "Creators / Reviewers",
    items: [
      { href: "/my-work/", label: "My Work" },
      { href: "/ai-assist/", label: "AI Assist" },
      { href: "/create/", label: "Create SOP" },
      { href: "/drafts/", label: "My Drafts" },
      { href: "/admin/review/", label: "Review Queue" },
      { href: "/admin/needs-review/", label: "Needs Review" },
    ],
  },
  {
    label: "Admins",
    items: [
      { href: "/admin/users/", label: "Users" },
      { href: "/admin/categories/", label: "Categories" },
      { href: "/admin/tags/", label: "Tags" },
      { href: "/admin/analytics/", label: "Analytics" },
      { href: "/admin/settings/", label: "Settings" },
    ],
  },
];

const pathname = Astro.url.pathname;
const isCurrent = (href: string) => pathname === href || (href !== "/" && pathname.startsWith(href));
const roleClass = (label: string) => label.toLowerCase().replace(/[^a-z0-9]+/g, "-");
const navIcon = (label: string, icon?: string) =>
  icon ?? label
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((word) => word[0]?.toUpperCase())
    .join("");
---

<header class="site-header no-print" aria-label="SOP Knowledge Hub navigation">
  <aside class="site-sidebar">
    <a class="brand" href="/" aria-label="SOP Knowledge Hub home">
      <span class="brand__mark" aria-hidden="true">SOP</span>
      <span>
        <span class="brand__name">SOP Knowledge Hub</span>
        <span class="brand__tagline">Find the process, template, or guide you need.</span>
      </span>
    </a>
    <nav class="main-nav" aria-label="Role-based navigation">
      {
        navGroups.map((group) => (
          <section class:list={["main-nav__role", `main-nav__role--${roleClass(group.label)}`]} aria-label={group.label}>
            <span class="main-nav__role-label">{group.label}</span>
            <div class="main-nav__links" role="list">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  role="listitem"
                  aria-current={isCurrent(item.href) ? "page" : undefined}
                >
                  <span class="main-nav__icon" aria-hidden="true">{navIcon(item.label, item.icon)}</span>
                  {item.label}
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </nav>
    <div class="sidebar-support">
      <span class="sidebar-support__icon" aria-hidden="true">?</span>
      <strong>Need help?</strong>
      <span>Contact SOP Support</span>
      <a href="mailto:sop-support@organization.edu">Get Support</a>
    </div>
  </aside>
  <div class="app-topbar">
    <form class="topbar-search" action="/search/" method="get">
      <label class="sr-only" for="topbar-search">Search SOPs</label>
      <span aria-hidden="true">S</span>
      <input
        id="topbar-search"
        name="q"
        type="search"
        placeholder="Search by title, tag, tool, owner, category, or keyword"
        autocomplete="off"
      />
      <kbd>Ctrl K</kbd>
    </form>
    <div class="topbar-actions" aria-label="Current user">
      <span class="topbar-bell" aria-label="3 notifications">3</span>
      <span class="topbar-avatar" aria-hidden="true">AM</span>
      <span class="topbar-user">Alex Morgan</span>
      <span aria-hidden="true">v</span>
    </div>
  </div>
</header>
