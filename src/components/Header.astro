---
import AppIcon from "./AppIcon.astro";
import { renderCategoryIconSvg } from "../lib/category-icons";

const navGroups = [
  {
    label: "Normal Users",
    role: "normal",
    items: [
      { href: "/", label: "Home", icon: "home" },
      { href: "/search/", label: "Search SOPs", icon: "search" },
      { href: "/guided-finder/", label: "Guided Finder", icon: "finder" },
      { href: "/categories/", label: "Categories", icon: "categories" },
      { href: "/submit/", label: "Request an SOP", icon: "submit" },
    ],
  },
  {
    label: "Creators / Reviewers",
    role: "creator",
    items: [
      { href: "/", label: "Home", icon: "home" },
      { href: "/my-work/", label: "My Work", icon: "work" },
      { href: "/ai-assist/", label: "AI Assist", icon: "ai" },
      { href: "/create/", label: "Create SOP", icon: "create" },
      { href: "/drafts/", label: "My Drafts", icon: "drafts" },
      { href: "/admin/review/", label: "Review Queue", icon: "review" },
      { href: "/admin/needs-review/", label: "Needs Review", icon: "needsReview" },
    ],
  },
  {
    label: "Admins",
    role: "admin",
    items: [
      { href: "/admin/users/", label: "Users", icon: "users" },
      { href: "/admin/categories/", label: "Categories", icon: "categories" },
      { href: "/admin/tags/", label: "Tags", icon: "tags" },
      { href: "/admin/analytics/", label: "Analytics", icon: "analytics" },
      { href: "/admin/settings/", label: "Settings", icon: "settings" },
    ],
  },
];

const pathname = Astro.url.pathname;
const isCurrent = (href: string) => pathname === href || (href !== "/" && pathname.startsWith(href));
const roleClass = (label: string) => label.toLowerCase().replace(/[^a-z0-9]+/g, "-");
const renderNavIcon = (icon: string, label: string) => renderCategoryIconSvg({ name: label, icon });
---

<header class="site-header no-print" aria-label="SOP Knowledge Hub navigation">
  <button
    class="mobile-nav-toggle"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="site-sidebar"
    data-nav-toggle
  >
    <span aria-hidden="true"></span>
    Menu
  </button>
  <div class="site-sidebar-backdrop" data-nav-backdrop hidden></div>
  <aside class="site-sidebar" id="site-sidebar" aria-label="SOP Knowledge Hub menu" aria-hidden="false">
    <button class="mobile-nav-close" type="button" aria-label="Close navigation menu" data-nav-close>
      Close
    </button>
    <a class="brand" href="/" aria-label="SOP Knowledge Hub home">
      <span class="brand__mark" aria-hidden="true">SOP</span>
      <span>
        <span class="brand__name">SOP Knowledge Hub</span>
        <span class="brand__tagline">Find the process, template, or guide you need.</span>
      </span>
    </a>
    <nav class="main-nav" aria-label="Role-based navigation">
      {
        navGroups.map((group) => (
          <section
            class:list={["main-nav__role", `main-nav__role--${roleClass(group.label)}`]}
            aria-label={group.label}
            data-role-nav={group.role}
          >
            <span class="main-nav__role-label">{group.label}</span>
            <div class="main-nav__links">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  aria-current={isCurrent(item.href) ? "page" : undefined}
                >
                  <span class="main-nav__icon" aria-hidden="true" set:html={renderNavIcon(item.icon, item.label)} />
                  {item.label}
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </nav>
    <div class="sidebar-support">
      <span class="sidebar-support__icon" aria-hidden="true"><AppIcon name="support" /></span>
      <strong>Need help?</strong>
      <span>Contact SOP Support</span>
      <a href="mailto:sop-support@organization.edu">Get Support</a>
    </div>
  </aside>
  <div class="app-topbar">
    <form class="topbar-search" action="/search/" method="get">
      <label class="sr-only" for="topbar-search">Search SOPs</label>
      <span aria-hidden="true"><AppIcon name="search" /></span>
      <input
        id="topbar-search"
        name="q"
        type="search"
        placeholder="Search by title, tag, tool, owner, category, or keyword"
        autocomplete="off"
      />
      <kbd>Ctrl K</kbd>
    </form>
    <div class="topbar-actions" aria-label="Current user">
      <span class="topbar-bell" aria-label="3 notifications">3</span>
      <span class="topbar-avatar" aria-hidden="true">AM</span>
      <span class="topbar-user" data-current-role-label>Select Role</span>
      <button class="role-switcher" type="button" data-role-reset>Switch</button>
    </div>
  </div>
</header>

<script>
  // @ts-nocheck
  const toggle = document.querySelector("[data-nav-toggle]");
  const closeButton = document.querySelector("[data-nav-close]");
  const sidebar = document.getElementById("site-sidebar");
  const backdrop = document.querySelector("[data-nav-backdrop]");
  let lastFocused = null;

  const focusableSelector = [
    "a[href]",
    "button:not([disabled])",
    "input:not([disabled])",
    "select:not([disabled])",
    "textarea:not([disabled])",
    "[tabindex]:not([tabindex='-1'])",
  ].join(",");

  function isDrawerLayout() {
    return window.matchMedia("(max-width: 920px)").matches;
  }

  function drawerFocusables() {
    if (!sidebar) return [];
    return Array.from(sidebar.querySelectorAll(focusableSelector)).filter((element) => {
      const htmlElement = element;
      return htmlElement.offsetParent !== null || htmlElement === closeButton;
    });
  }

  function setDrawer(open) {
    if (!sidebar || !toggle || !backdrop) return;
    document.body.classList.toggle("nav-drawer-open", open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
    sidebar.setAttribute("aria-hidden", isDrawerLayout() ? String(!open) : "false");
    sidebar.inert = isDrawerLayout() ? !open : false;
    backdrop.hidden = !open;
    if (open) {
      lastFocused = document.activeElement;
      window.requestAnimationFrame(() => closeButton?.focus());
    } else if (lastFocused instanceof HTMLElement) {
      window.requestAnimationFrame(() => lastFocused?.focus());
    }
  }

  toggle?.addEventListener("click", () => {
    setDrawer(!document.body.classList.contains("nav-drawer-open"));
  });

  closeButton?.addEventListener("click", () => setDrawer(false));
  backdrop?.addEventListener("click", () => setDrawer(false));

  sidebar?.addEventListener("click", (event) => {
    if (event.target instanceof HTMLAnchorElement && isDrawerLayout()) {
      setDrawer(false);
    }
  });

  document.addEventListener("keydown", (event) => {
    if (!document.body.classList.contains("nav-drawer-open")) return;
    if (event.key === "Escape") {
      event.preventDefault();
      setDrawer(false);
      return;
    }
    if (event.key !== "Tab") return;
    const focusables = drawerFocusables();
    if (!focusables.length) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  });

  window.addEventListener("resize", () => {
    if (!isDrawerLayout()) setDrawer(false);
    else {
      const open = document.body.classList.contains("nav-drawer-open");
      sidebar?.setAttribute("aria-hidden", String(!open));
      if (sidebar) sidebar.inert = !open;
    }
  });

  if (sidebar && isDrawerLayout()) {
    sidebar.setAttribute("aria-hidden", "true");
    sidebar.inert = true;
  }
</script>
