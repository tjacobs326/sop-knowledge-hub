---
const navGroups = [
  {
    label: "Normal Users",
    items: [
      { href: "/search/", label: "Search SOPs" },
      { href: "/finder/", label: "Guided Finder" },
      { href: "/categories/", label: "Categories" },
      { href: "/submit/", label: "Submit Request" },
    ],
  },
  {
    label: "Creators / Reviewers",
    items: [
      { href: "/create/", label: "Create SOP" },
      { href: "/drafts/", label: "My Drafts" },
      { href: "/admin/review/", label: "Review Queue" },
      { href: "/admin/needs-review/", label: "Needs Review" },
    ],
  },
  {
    label: "Admins",
    items: [
      { href: "/admin/users/", label: "Users" },
      { href: "/admin/categories/", label: "Categories" },
      { href: "/admin/tags/", label: "Tags" },
      { href: "/admin/analytics/", label: "Analytics" },
      { href: "/admin/settings/", label: "Settings" },
    ],
  },
];

const pathname = Astro.url.pathname;
const isCurrent = (href: string) => pathname === href || (href !== "/" && pathname.startsWith(href));
---

<header class="site-header no-print">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="SOP Knowledge Hub home">
      <span class="brand__mark" aria-hidden="true">SOP</span>
      <span>
        <span class="brand__name">SOP Knowledge Hub</span>
        <span class="brand__tagline">Find the process, template, or guide you need.</span>
      </span>
    </a>
    <nav class="main-nav" aria-label="Role-based navigation">
      {
        navGroups.map((group) => (
          <section class="main-nav__role" aria-label={group.label}>
            <span class="main-nav__role-label">{group.label}</span>
            <div class="main-nav__links" role="list">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  role="listitem"
                  aria-current={isCurrent(item.href) ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </nav>
  </div>
</header>

