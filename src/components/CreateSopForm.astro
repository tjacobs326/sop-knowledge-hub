---
import SopDraftPreview from "./SopDraftPreview.astro";

const sopTypes = [
  "Process",
  "Troubleshooting Guide",
  "Template",
  "Checklist",
  "Job Aid",
  "Decision Tree",
];
---

<section class="tool-surface" aria-labelledby="create-heading">
  <div class="section-heading">
    <p class="eyebrow">Internal Creator Workflow</p>
    <h1 id="create-heading">Create New SOP</h1>
    <p id="create-description">Create, preview, save, submit, and publish SOP drafts through the backend workflow.</p>
  </div>

  <form class="form-grid" id="create-sop-form" novalidate>
    <div class="field field--full">
      <label for="sop-title">SOP Title</label>
      <input id="sop-title" name="title" type="text" required />
    </div>
    <div class="field field--full">
      <label for="purpose">Purpose</label>
      <textarea id="purpose" name="purpose" rows="3" required></textarea>
    </div>
    <div class="field">
      <label for="owner">Owner</label>
      <select id="owner" name="ownerId" required>
        <option value="">Loading owners...</option>
      </select>
    </div>
    <div class="field">
      <label for="reviewer">Assign Reviewer</label>
      <select id="reviewer" name="reviewerId">
        <option value="">Loading reviewers...</option>
      </select>
    </div>
    <div class="field">
      <label for="category">Category</label>
      <select id="category" name="categoryId" required>
        <option value="">Loading categories...</option>
      </select>
    </div>
    <div class="field">
      <label for="type">SOP Type</label>
      <select id="type" name="type" required>
        <option value="">Select type</option>
        {sopTypes.map((type) => <option value={type}>{type}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="review-date">Review Date</label>
      <input id="review-date" name="reviewDate" type="date" required />
    </div>
    <div class="field">
      <label for="tools">Tools / Systems</label>
      <input id="tools" name="tools" type="text" placeholder="Ivanti, Brightspace D2L" list="tool-options" />
      <datalist id="tool-options"></datalist>
    </div>
    <div class="field">
      <label for="audience">Audience</label>
      <input id="audience" name="audience" type="text" placeholder="Instructional Designers, QA Reviewers" />
    </div>
    <div class="field">
      <label for="tags">Tags</label>
      <input id="tags" name="tags" type="text" placeholder="qa, launch, accessibility" list="tag-options" />
      <datalist id="tag-options"></datalist>
    </div>
    <div class="field">
      <label for="estimated-time">Estimated Completion Time</label>
      <input id="estimated-time" name="estimatedCompletionTime" type="text" placeholder="10 minutes" />
    </div>
    <div class="field field--full">
      <label for="before-you-begin">Before You Begin</label>
      <textarea id="before-you-begin" name="beforeYouBegin" rows="3"></textarea>
    </div>

    <fieldset class="field field--full step-builder">
      <legend>Procedure Steps</legend>
      <div id="procedure-steps"></div>
      <button class="button button--secondary" id="add-step" type="button">Add Step</button>
    </fieldset>

    <div class="field field--full">
      <label for="troubleshooting-notes">Troubleshooting Notes</label>
      <textarea id="troubleshooting-notes" name="troubleshootingNotes" rows="3"></textarea>
    </div>
    <div class="field">
      <label for="related-sops">Related SOPs or Links</label>
      <input id="related-sops" name="relatedSops" type="text" placeholder="Submit a New Ivanti Ticket, https://..." />
    </div>
    <div class="field">
      <label for="change-summary">Change Summary</label>
      <input id="change-summary" name="changeSummary" type="text" />
    </div>
    <div class="field">
      <label for="version">Version</label>
      <input id="version" name="version" type="text" value="0.1" />
    </div>
    <div class="field">
      <label for="workflow-notes">Workflow Notes</label>
      <input id="workflow-notes" name="workflowNotes" type="text" placeholder="Reviewer instructions or approval notes" />
    </div>

    <div class="field publish-permission" id="publish-permission" role="status"></div>
    <div class="form-errors field--full" id="create-errors" role="alert" hidden></div>
    <div class="confirmation field--full" id="create-confirmation" role="status" hidden></div>

    <div class="form-actions field--full">
      <button class="button button--secondary" id="save-draft" type="button" data-create-action="save">Save Draft</button>
      <button class="button button--primary" id="preview-sop" type="button" data-create-action="preview">Preview</button>
      <button class="button button--primary" id="submit-review" type="button" data-create-action="submit">Submit for Review</button>
      <button class="button button--primary" id="publish-sop" type="button" data-create-action="publish" hidden>Publish</button>
      <button class="button button--secondary" id="approve-sop" type="button" data-create-action="approve" hidden>Approve</button>
      <button class="button button--secondary" id="request-changes" type="button" data-create-action="changes" hidden>Request Changes</button>
      <button class="button button--danger" id="reject-sop" type="button" data-create-action="reject" hidden>Reject</button>
      <a class="button button--ghost" id="cancel-create" href="/my-work/">Cancel</a>
    </div>
  </form>
</section>

<SopDraftPreview />

<script>
  // @ts-nocheck
  const form = document.getElementById("create-sop-form");
  const errorsEl = document.getElementById("create-errors");
  const confirmation = document.getElementById("create-confirmation");
  const stepContainer = document.getElementById("procedure-steps");
  const publishPermission = document.getElementById("publish-permission");
  const publishButton = document.getElementById("publish-sop");
  const approveButton = document.getElementById("approve-sop");
  const changesButton = document.getElementById("request-changes");
  const rejectButton = document.getElementById("reject-sop");
  const cancelLink = document.getElementById("cancel-create");
  const SUB_ROLE_KEY = "sopHubSelectedCreatorSubRole";
  const EDIT_SOP_STORAGE_KEY = "sopHubEditSop";
  let options = { currentUser: null, categories: [], users: [], reviewers: [], tags: [] };
  let currentSop = null;
  let hasUnsavedChanges = false;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
      return replacements[character];
    });

  const splitList = (value) =>
    String(value || "")
      .split(/[\n,]+/)
      .map((item) => item.trim())
      .filter(Boolean);

  const arrayValue = (value) => {
    if (Array.isArray(value)) return value.map(String).map((item) => item.trim()).filter(Boolean);
    return splitList(value);
  };

  function normalizeDateValue(value) {
    if (!value) return "";
    if (typeof value === "number") return new Date(value * 1000).toISOString().slice(0, 10);
    const raw = String(value);
    if (/^\d+$/.test(raw)) return new Date(Number(raw) * 1000).toISOString().slice(0, 10);
    return raw.slice(0, 10);
  }

  function apiHeaders() {
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    return {
      accept: "application/json",
      "content-type": "application/json",
      ...(subRole ? { "x-sop-sub-role": subRole } : {}),
    };
  }

  function getField(name) {
    const element = form?.querySelector(`[name="${name}"]`);
    return element instanceof HTMLInputElement ||
      element instanceof HTMLSelectElement ||
      element instanceof HTMLTextAreaElement
      ? element.value.trim()
      : "";
  }

  function setField(name, value) {
    const element = form?.querySelector(`[name="${name}"]`);
    if (
      element instanceof HTMLInputElement ||
      element instanceof HTMLSelectElement ||
      element instanceof HTMLTextAreaElement
    ) {
      element.value = String(value ?? "");
    }
  }

  function createStepElement(step = {}, index = 1) {
    const wrapper = document.createElement("div");
    wrapper.className = "procedure-step";
    wrapper.dataset.step = "";
    wrapper.innerHTML = `
      <div class="procedure-step__header">
        <strong>Step ${index}</strong>
        ${index > 1 ? '<button class="button button--ghost" type="button" data-remove-step>Remove</button>' : ""}
      </div>
      <div class="field">
        <label>Step title</label>
        <input name="stepTitle" type="text" required value="${escapeHtml(step.title || "")}" />
      </div>
      <div class="field field--full">
        <label>Step instructions</label>
        <textarea name="stepInstructions" rows="3" required>${escapeHtml(step.instructions || "")}</textarea>
      </div>
      <div class="field">
        <label>Optional note</label>
        <input name="stepNote" type="text" value="${escapeHtml(step.note || "")}" />
      </div>
    `;
    return wrapper;
  }

  function renderSteps(steps = [{}]) {
    if (!stepContainer) return;
    stepContainer.innerHTML = "";
    const safeSteps = Array.isArray(steps) && steps.length ? steps : [{}];
    safeSteps.forEach((step, index) => stepContainer.append(createStepElement(step, index + 1)));
  }

  function collectSteps() {
    return Array.from(document.querySelectorAll("[data-step]"))
      .map((step) => ({
        title: step.querySelector('[name="stepTitle"]')?.value.trim() || "",
        instructions: step.querySelector('[name="stepInstructions"]')?.value.trim() || "",
        note: step.querySelector('[name="stepNote"]')?.value.trim() || "",
      }))
      .filter((step) => step.title || step.instructions);
  }

  function contentMarkdown(draft) {
    return [
      `## Purpose\n\n${draft.purpose}`,
      draft.beforeYouBegin ? `## Before You Begin\n\n${draft.beforeYouBegin}` : "",
      draft.procedureSteps.length
        ? `## Procedure\n\n${draft.procedureSteps
            .map((step, index) => `${index + 1}. ${step.title}\n   ${step.instructions}${step.note ? `\n   Note: ${step.note}` : ""}`)
            .join("\n\n")}`
        : "",
      draft.troubleshootingNotes ? `## Troubleshooting / Notes\n\n${draft.troubleshootingNotes}` : "",
      draft.relatedSops.length ? `## Related SOPs\n\n${draft.relatedSops.map((item) => `- ${item}`).join("\n")}` : "",
    ]
      .filter(Boolean)
      .join("\n\n");
  }

  function markdownSection(content, heading) {
    const text = String(content || "");
    const pattern = new RegExp(`^##\\s+${heading}\\s*$`, "im");
    const match = text.match(pattern);
    if (!match || match.index === undefined) return "";
    const afterHeading = text.slice(match.index + match[0].length);
    const nextHeading = afterHeading.search(/^##\s+/m);
    return (nextHeading >= 0 ? afterHeading.slice(0, nextHeading) : afterHeading).trim();
  }

  function parseProcedureSteps(content, checklist) {
    const procedure = markdownSection(content, "Procedure");
    const steps = [];
    let current = null;
    procedure.split(/\r?\n/).forEach((line) => {
      const stepMatch = line.match(/^\s*\d+\.\s+(.+?)\s*$/);
      if (stepMatch) {
        if (current) steps.push(current);
        current = { title: stepMatch[1].trim(), instructions: "", note: "" };
        return;
      }
      if (!current) return;
      const cleaned = line.trim();
      if (!cleaned) return;
      if (/^note:/i.test(cleaned)) {
        current.note = cleaned.replace(/^note:\s*/i, "");
      } else {
        current.instructions = [current.instructions, cleaned].filter(Boolean).join("\n");
      }
    });
    if (current) steps.push(current);
    if (steps.length) return steps;

    const checklistSteps = String(checklist || "")
      .split(/\r?\n/)
      .map((item) => item.replace(/^[-*]\s*/, "").trim())
      .filter(Boolean)
      .map((title) => ({ title, instructions: title, note: "" }));
    return checklistSteps.length ? checklistSteps : [{}];
  }

  function relatedSopsFromContent(content) {
    return markdownSection(content, "Related SOPs")
      .split(/\r?\n/)
      .map((item) => item.replace(/^[-*]\s*/, "").trim())
      .filter(Boolean);
  }

  function buildDraft(status = "Draft") {
    const category = options.categories.find((item) => item.id === getField("categoryId"));
    const owner = options.users.find((item) => item.id === getField("ownerId"));
    const draft = {
      id: currentSop?.id || "",
      title: getField("title"),
      purpose: getField("purpose"),
      summary: getField("purpose"),
      ownerId: getField("ownerId"),
      owner: owner?.name || "",
      reviewerId: getField("reviewerId"),
      categoryId: getField("categoryId"),
      category: category?.name || "",
      type: getField("type"),
      tools: splitList(getField("tools")),
      audience: splitList(getField("audience")),
      tags: splitList(getField("tags")),
      estimatedCompletionTime: getField("estimatedCompletionTime"),
      beforeYouBegin: getField("beforeYouBegin"),
      procedureSteps: collectSteps(),
      troubleshootingNotes: getField("troubleshootingNotes"),
      relatedSops: splitList(getField("relatedSops")),
      changeSummary: getField("changeSummary") || "Draft saved from Create SOP.",
      reviewDate: getField("reviewDate"),
      version: getField("version") || "0.1",
      status,
    };
    return { ...draft, content: contentMarkdown(draft), checklist: draft.procedureSteps.map((step) => step.title).join("\n") };
  }

  function validateDraft(draft, action = "save") {
    const errors = [];
    if (!draft.title) errors.push("SOP Title is required.");
    if (!draft.purpose) errors.push("Purpose is required.");
    if (!draft.ownerId) errors.push("Owner is required.");
    if (!draft.categoryId) errors.push("Category is required.");
    if (!draft.type) errors.push("SOP Type is required.");
    if (!draft.reviewDate) errors.push("Review Date is required.");
    if (!draft.procedureSteps.length) errors.push("At least one procedure step is required.");
    if (draft.procedureSteps.some((step) => !step.title || !step.instructions)) {
      errors.push("Each procedure step needs a title and instructions.");
    }
    if (action === "publish" && (!draft.purpose || !draft.procedureSteps.length || !draft.categoryId)) {
      errors.push("Complete the title, purpose, category, and procedure before publishing.");
    }
    if (errorsEl) {
      errorsEl.hidden = errors.length === 0;
      errorsEl.innerHTML = errors.map((error) => `<p>${escapeHtml(error)}</p>`).join("");
    }
    return errors.length === 0;
  }

  function renderPreview(draft) {
    document.getElementById("preview-title").textContent = draft.title;
    document.getElementById("preview-purpose").textContent = draft.purpose;
    document.getElementById("preview-before").textContent = draft.beforeYouBegin || "No before-you-begin notes entered.";
    document.getElementById("preview-notes").textContent = draft.troubleshootingNotes || "No troubleshooting notes entered.";
    document.getElementById("preview-meta").innerHTML = [
      ["Owner", draft.owner],
      ["Category", draft.category],
      ["Tools used", draft.tools.join(", ") || "None listed"],
      ["Audience", draft.audience.join(", ") || "None listed"],
      ["Status", draft.status],
      ["Version", draft.version],
      ["Review date", draft.reviewDate],
      ["Estimated time", draft.estimatedCompletionTime || "Not estimated"],
    ]
      .map(([label, value]) => `<div><dt>${label}</dt><dd>${escapeHtml(value)}</dd></div>`)
      .join("");
    document.getElementById("preview-steps").innerHTML = draft.procedureSteps
      .map((step) => `<li><h4>${escapeHtml(step.title)}</h4><p>${escapeHtml(step.instructions)}</p>${step.note ? `<p><strong>Note:</strong> ${escapeHtml(step.note)}</p>` : ""}</li>`)
      .join("");
    document.getElementById("preview-related").innerHTML = draft.relatedSops.length
      ? draft.relatedSops.map((item) => `<li>${escapeHtml(item)}</li>`).join("")
      : "<li>No related SOPs entered.</li>";
    const preview = document.getElementById("draft-preview");
    preview.hidden = false;
    preview.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function showConfirmation(message) {
    if (!confirmation) return;
    confirmation.hidden = false;
    confirmation.innerHTML = message;
    confirmation.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  async function parseApiResponse(response) {
    const data = await response.json().catch(() => ({}));
    if (!response.ok || data?.success === false) {
      throw new Error(data?.error?.message || data?.error || `Request failed: ${response.status}`);
    }
    return data.data || data;
  }

  async function saveDraft(status = "Draft") {
    const draft = buildDraft(status);
    if (!validateDraft(draft, "save")) return null;
    const body = {
      title: draft.title,
      summary: draft.summary,
      purpose: draft.purpose,
      categoryId: draft.categoryId,
      ownerId: draft.ownerId,
      reviewerId: draft.reviewerId,
      type: draft.type,
      version: draft.version,
      audience: draft.audience,
      tools: draft.tools,
      tags: draft.tags,
      estimatedCompletionTime: draft.estimatedCompletionTime,
      content: draft.content,
      beforeYouBegin: draft.beforeYouBegin,
      checklist: draft.checklist,
      troubleshooting: draft.troubleshootingNotes,
      changeSummary: draft.changeSummary,
      reviewDate: draft.reviewDate,
    };
    const response = currentSop?.id
      ? await fetch(`/api/sops/${encodeURIComponent(currentSop.id)}`, {
          method: "PUT",
          headers: apiHeaders(),
          body: JSON.stringify(body),
        })
      : await fetch("/api/sops", {
          method: "POST",
          headers: apiHeaders(),
          body: JSON.stringify(body),
        });
    const data = await parseApiResponse(response);
    currentSop = data.sop || currentSop;
    hasUnsavedChanges = false;
    return currentSop;
  }

  async function workflow(action, notes) {
    if (!currentSop?.id) {
      const saved = await saveDraft(action === "publish" ? "Published" : "Draft");
      if (!saved) return null;
    }
    const endpoint =
      action === "submit"
        ? "submit-review"
        : action === "changes"
          ? "request-changes"
          : action === "reject"
            ? "archive"
            : action;
    const response = await fetch(`/api/sops/${encodeURIComponent(currentSop.id)}/${endpoint}`, {
      method: "POST",
      headers: apiHeaders(),
      body: JSON.stringify({ notes: notes || getField("workflowNotes") || endpoint }),
    });
    return parseApiResponse(response);
  }

  function populateSelect(selectId, items, placeholder, labelFn) {
    const select = document.getElementById(selectId);
    if (!(select instanceof HTMLSelectElement)) return;
    const current = select.value;
    select.innerHTML = `<option value="">${escapeHtml(placeholder)}</option>${items
      .map((item) => `<option value="${escapeHtml(item.id)}">${escapeHtml(labelFn(item))}</option>`)
      .join("")}`;
    if (items.some((item) => item.id === current)) select.value = current;
  }

  async function loadOptions() {
    const response = await fetch("/api/create-options", { headers: apiHeaders(), cache: "no-store" });
    options = await parseApiResponse(response);
    populateSelect("category", options.categories || [], "Select category", (item) => item.name);
    populateSelect("owner", options.users || [], "Select owner", (item) => `${item.name} - ${item.department || item.accessLevel}`);
    populateSelect("reviewer", options.reviewers || [], "Optional reviewer", (item) => `${item.name} - ${item.department || item.accessLevel}`);
    const currentUser = options.currentUser;
    if (currentUser?.id) setField("ownerId", currentUser.id);
    const tagList = document.getElementById("tag-options");
    if (tagList) tagList.innerHTML = (options.tags || []).map((tag) => `<option value="${escapeHtml(tag.name)}"></option>`).join("");

    const permissions = new Set(currentUser?.permissions || []);
    const canPublish = currentUser?.role === "admin" || permissions.has("Publish SOPs");
    const canApprove = currentUser?.role === "admin" || permissions.has("Approve SOPs");
    const canRequestChanges = currentUser?.role === "admin" || permissions.has("Request Changes");
    if (publishButton) publishButton.hidden = !canPublish;
    if (approveButton) approveButton.hidden = !canApprove;
    if (changesButton) changesButton.hidden = !canRequestChanges;
    if (rejectButton) rejectButton.hidden = !canRequestChanges;
    if (publishPermission) {
      publishPermission.innerHTML = canPublish
        ? `<strong>Publish enabled:</strong> ${escapeHtml(currentUser?.name || "This user")} has publish permission.`
        : "<strong>Publish disabled:</strong> publish permission is required.";
    }
  }

  function fillFormFromSource(source) {
    const version = source.version || {};
    const metadata = source.metadata || version.metadata || {};
    const content = version.content || source.bodyMarkdown || source.content || "";
    currentSop = source.sourceId ? { id: source.sourceId } : source.id ? { id: source.id, currentVersionId: source.currentVersionId || version.id } : null;
    setField("title", source.title);
    setField("purpose", source.purpose || source.summary || version.purpose || version.summary);
    setField("ownerId", source.ownerId);
    setField("reviewerId", source.reviewerId);
    setField("categoryId", source.categoryId);
    setField("type", source.type || "Process");
    setField("reviewDate", normalizeDateValue(source.reviewDate || source.reviewDueAt));
    setField("tools", arrayValue(source.tools || metadata.tools).join(", "));
    setField("audience", arrayValue(source.audience || metadata.audience).join(", "));
    setField("tags", arrayValue(source.tags || metadata.tags).join(", "));
    setField("estimatedCompletionTime", source.estimatedCompletionTime);
    setField("beforeYouBegin", source.beforeYouBegin || version.beforeYouBegin);
    setField("troubleshootingNotes", source.troubleshootingNotes || version.troubleshooting);
    setField("relatedSops", arrayValue(source.relatedSops || relatedSopsFromContent(content)).join(", "));
    setField("changeSummary", source.changeSummary || version.changeSummary);
    setField("version", source.versionNumber || version.number || source.version || "0.1");
    renderSteps(source.procedureSteps || parseProcedureSteps(content, source.checklist || version.checklist));
    hasUnsavedChanges = false;
  }

  async function loadBackendEditSource(id) {
    const response = await fetch(`/api/sops/${encodeURIComponent(id)}`, {
      headers: apiHeaders(),
      cache: "no-store",
    });
    const data = await parseApiResponse(response);
    fillFormFromSource(data.sop || data);
  }

  async function loadEditSource() {
    const params = new URLSearchParams(window.location.search);
    if (!params.has("edit")) return;
    const id = params.get("id");
    if (id) {
      await loadBackendEditSource(id);
      return;
    }
    try {
      const source = JSON.parse(sessionStorage.getItem(EDIT_SOP_STORAGE_KEY) || "null");
      if (!source) return;
      fillFormFromSource(source);
    } catch {
      // If edit context is unavailable, start a clean backend draft.
    }
  }

  form?.addEventListener("input", () => {
    hasUnsavedChanges = true;
  });

  window.addEventListener("beforeunload", (event) => {
    if (!hasUnsavedChanges) return;
    event.preventDefault();
    event.returnValue = "";
  });

  cancelLink?.addEventListener("click", (event) => {
    if (hasUnsavedChanges && !window.confirm("Discard unsaved SOP changes?")) {
      event.preventDefault();
    }
  });

  document.getElementById("add-step")?.addEventListener("click", () => {
    const count = stepContainer?.querySelectorAll("[data-step]").length || 0;
    stepContainer?.append(createStepElement({}, count + 1));
    hasUnsavedChanges = true;
  });

  stepContainer?.addEventListener("click", (event) => {
    const target = event.target;
    if (target instanceof HTMLElement && target.matches("[data-remove-step]")) {
      target.closest("[data-step]")?.remove();
      hasUnsavedChanges = true;
    }
  });

  document.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const actionButton = target.closest("[data-create-action], [data-draft-action]");
    if (!(actionButton instanceof HTMLElement)) return;
    const action = actionButton.dataset.createAction || actionButton.dataset.draftAction;
    const draft = buildDraft(action === "publish" ? "Published" : action === "submit" ? "In Review" : "Draft");

    try {
      if (action === "preview") {
        if (!validateDraft(draft, "preview")) return;
        renderPreview(draft);
        return;
      }
      if (action === "clear") {
        if (hasUnsavedChanges && !window.confirm("Clear the form without saving?")) return;
        form?.reset();
        currentSop = null;
        hasUnsavedChanges = false;
        renderSteps([{}]);
        return;
      }
      if (action === "save") {
        const saved = await saveDraft("Draft");
        if (saved) showConfirmation(`<strong>Draft saved.</strong><p>SOP ID: ${escapeHtml(saved.id)}. It is now available to backend My Work and draft workflows.</p>`);
        return;
      }
      if (action === "submit") {
        const saved = await saveDraft("Draft");
        if (!saved) return;
        await workflow("submit", "Submitted for review from Create SOP.");
        showConfirmation("<strong>SOP submitted for review.</strong><p>It is now routed to the backend review workflow and assignments.</p>");
        return;
      }
      if (action === "publish") {
        if (!validateDraft(draft, "publish")) return;
        const saved = await saveDraft("Draft");
        if (!saved) return;
        await workflow("publish", "Published from Create SOP.");
        showConfirmation("<strong>SOP published.</strong><p>It will appear in Search SOPs, Categories, Home counts, and role/sub-role SOP lists.</p>");
        return;
      }
      if (action === "approve" || action === "changes" || action === "reject") {
        await workflow(action, getField("workflowNotes"));
        const label = action === "approve" ? "approved" : action === "changes" ? "sent back for changes" : "rejected and archived";
        showConfirmation(`<strong>SOP ${label}.</strong><p>The backend workflow status has been updated.</p>`);
      }
    } catch (error) {
      if (errorsEl) {
        errorsEl.hidden = false;
        errorsEl.innerHTML = `<p>${escapeHtml(error instanceof Error ? error.message : "The SOP action failed.")}</p>`;
      }
    }
  });

  renderSteps([{}]);
  loadOptions().then(() => loadEditSource()).catch((error) => {
    if (errorsEl) {
      errorsEl.hidden = false;
      errorsEl.innerHTML = `<p>${escapeHtml(error instanceof Error ? error.message : "Create SOP setup could not load.")}</p>`;
    }
  });
</script>
