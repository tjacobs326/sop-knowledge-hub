---
import { categories } from "../data/categories";
import { USER_STORAGE_KEY, userAccounts } from "../data/mock-users";
import {
  DRAFTS_STORAGE_KEY,
  EDIT_SOP_STORAGE_KEY,
  PUBLISHED_SOPS_STORAGE_KEY,
} from "../lib/drafts";
import { REVIEW_QUEUE_STORAGE_KEY } from "../lib/submissions";
import SopDraftPreview from "./SopDraftPreview.astro";

const sopTypes = [
  "Process",
  "Troubleshooting Guide",
  "Template",
  "Checklist",
  "Job Aid",
  "Decision Tree",
];

const draftStatuses = [
  "Draft",
  "In Review",
  "Needs Revision",
  "Approved",
  "Published",
  "Archived",
];

const publishingUsers = [...userAccounts]
  .filter((user) => user.status === "Active")
  .sort((a, b) => {
    const aCanPublish = a.accessLevel === "Creator / Reviewer";
    const bCanPublish = b.accessLevel === "Creator / Reviewer";
    return Number(bCanPublish) - Number(aCanPublish) || a.name.localeCompare(b.name);
  });
---

<section class="tool-surface" aria-labelledby="create-heading">
  <div class="section-heading">
    <p class="eyebrow">Internal Creator Workflow</p>
    <h1 id="create-heading">Create New SOP</h1>
    <p id="create-description">Use this form to create a complete SOP draft for review and publishing.</p>
    <div class="create-edit-actions" id="edit-cancel-actions" hidden>
      <a class="button button--ghost" id="cancel-edit-sop" href="/search/">Cancel Editing</a>
      <span>Return without saving changes.</span>
    </div>
  </div>

  <form class="form-grid" id="create-sop-form" novalidate>
    <div class="field field--full">
      <label for="sop-title">SOP Title</label>
      <input id="sop-title" name="title" type="text" required />
    </div>
    <div class="field field--full">
      <label for="purpose">Purpose</label>
      <textarea id="purpose" name="purpose" rows="3" required></textarea>
    </div>
    <div class="field">
      <label for="owner">Owner</label>
      <input id="owner" name="owner" type="text" required />
    </div>
    <div class="field">
      <label for="category">Category</label>
      <select id="category" name="category" required>
        <option value="">Select category</option>
        {categories.map((category) => <option value={category.name}>{category.name}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="type">SOP Type</label>
      <select id="type" name="type" required>
        <option value="">Select type</option>
        {sopTypes.map((type) => <option value={type}>{type}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="review-date">Review Date</label>
      <input id="review-date" name="reviewDate" type="date" required />
    </div>
    <div class="field">
      <label for="tools">Tools Used</label>
      <input id="tools" name="tools" type="text" placeholder="Ivanti, Brightspace D2L" />
    </div>
    <div class="field">
      <label for="audience">Audience</label>
      <input id="audience" name="audience" type="text" placeholder="Instructional Designers, QA Reviewers" />
    </div>
    <div class="field">
      <label for="tags">Tags</label>
      <input id="tags" name="tags" type="text" placeholder="qa, launch, accessibility" />
    </div>
    <div class="field">
      <label for="estimated-time">Estimated Completion Time</label>
      <input id="estimated-time" name="estimatedCompletionTime" type="text" placeholder="10 minutes" />
    </div>
    <div class="field field--full">
      <label for="before-you-begin">Before You Begin</label>
      <textarea id="before-you-begin" name="beforeYouBegin" rows="3"></textarea>
    </div>

    <fieldset class="field field--full step-builder">
      <legend>Procedure Steps</legend>
      <div id="procedure-steps">
        <div class="procedure-step" data-step>
          <div class="procedure-step__header">
            <strong>Step 1</strong>
          </div>
          <div class="field">
            <label>Step title</label>
            <input name="stepTitle" type="text" required />
          </div>
          <div class="field field--full">
            <label>Step instructions</label>
            <textarea name="stepInstructions" rows="3" required></textarea>
          </div>
          <div class="field">
            <label>Optional note</label>
            <input name="stepNote" type="text" />
          </div>
          <div class="field field--full">
            <label>Step media</label>
            <div class="screenshot-input" data-screenshot-input>
              <input name="stepScreenshot" type="hidden" />
              <input name="stepVideo" type="hidden" />
              <input name="stepVideoLabel" type="hidden" />
              <input name="stepScreenshotFile" type="file" accept="image/*,video/*" />
              <textarea
                class="screenshot-paste-target"
                aria-label="Paste step media"
                rows="3"
                spellcheck="false"
                data-screenshot-paste
              >Paste a screenshot here or upload an image or video file.</textarea>
              <figure class="screenshot-preview" data-screenshot-preview hidden>
                <img alt="Step screenshot preview" data-screenshot-image />
                <video controls data-screenshot-video hidden></video>
                <figcaption>
                  <button class="button button--ghost" type="button" data-remove-screenshot>
                    Remove Media
                  </button>
                </figcaption>
              </figure>
            </div>
          </div>
        </div>
      </div>
      <button class="button button--secondary" id="add-step" type="button">Add Step</button>
    </fieldset>

    <div class="field field--full">
      <label for="screenshots">Screenshots</label>
      <textarea id="screenshots" name="screenshots" rows="2" placeholder="/images/screenshots/example-placeholder.svg"></textarea>
    </div>
    <div class="field field--full">
      <label for="troubleshooting-notes">Troubleshooting Notes</label>
      <textarea id="troubleshooting-notes" name="troubleshootingNotes" rows="3"></textarea>
    </div>
    <div class="field">
      <label for="related-sops">Related SOPs</label>
      <input id="related-sops" name="relatedSops" type="text" placeholder="Submit a New Ivanti Ticket" />
    </div>
    <div class="field">
      <label for="change-summary">Change Summary</label>
      <input id="change-summary" name="changeSummary" type="text" />
    </div>
    <div class="field">
      <label for="draft-status">Draft Status</label>
      <select id="draft-status" name="status">
        {draftStatuses.map((status) => <option value={status}>{status}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="version">Version</label>
      <input id="version" name="version" type="text" value="0.1" />
    </div>
    <div class="field">
      <label for="publishing-account">Publishing Account</label>
      <select id="publishing-account" name="publishingAccount">
        {publishingUsers.map((user) => (
          <option value={user.email}>{user.name} - {user.accessLevel}</option>
        ))}
      </select>
    </div>
    <div class="field publish-permission" id="publish-permission" role="status"></div>
    <div class="form-actions field--full">
      <button class="button button--primary" id="preview-sop" type="button">Preview SOP</button>
    </div>
    <div class="form-errors field--full" id="create-errors" role="alert" hidden></div>
  </form>
</section>

<SopDraftPreview />

<script
  is:inline
  define:vars={{
    DRAFTS_STORAGE_KEY,
    EDIT_SOP_STORAGE_KEY,
    PUBLISHED_SOPS_STORAGE_KEY,
    REVIEW_QUEUE_STORAGE_KEY,
    USER_STORAGE_KEY,
    initialPublishingUsers: publishingUsers,
  }}
>
  const form = document.getElementById("create-sop-form");
  const createHeading = document.getElementById("create-heading");
  const createDescription = document.getElementById("create-description");
  const editCancelActions = document.getElementById("edit-cancel-actions");
  const cancelEditLink = document.getElementById("cancel-edit-sop");
  const errorsEl = document.getElementById("create-errors");
  const addStepButton = document.getElementById("add-step");
  const stepContainer = document.getElementById("procedure-steps");
  const previewButton = document.getElementById("preview-sop");
  const publishButton = document.getElementById("publish-sop");
  const publishingAccount = document.getElementById("publishing-account");
  const publishPermission = document.getElementById("publish-permission");
  const preview = document.getElementById("draft-preview");
  const confirmation = document.getElementById("create-confirmation");

  let currentDraft = null;
  let editingDraftId = "";
  let editingCreatedDate = "";
  let editingSource = null;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  const splitList = (value) =>
    String(value || "")
      .split(/[\n,]+/)
      .map((item) => item.trim())
      .filter(Boolean);

  const slugify = (value) =>
    String(value)
      .toLowerCase()
      .trim()
      .replace(/&/g, "and")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");

  function getPublishedSopUrl(source) {
    if (!source?.sourceSlug) return "/search/";

    return `/sops/${slugify(source.category || "")}/${source.sourceSlug}/`;
  }

  function showCancelEditAction(href, label = "Cancel Editing") {
    if (cancelEditLink instanceof HTMLAnchorElement) {
      cancelEditLink.href = href;
      cancelEditLink.textContent = label;
    }
    if (editCancelActions instanceof HTMLElement) {
      editCancelActions.hidden = false;
    }
  }

  function getField(name) {
    const element = form?.querySelector(`[name="${name}"]`);
    return element instanceof HTMLInputElement ||
      element instanceof HTMLSelectElement ||
      element instanceof HTMLTextAreaElement
      ? element.value.trim()
      : "";
  }

  function setField(name, value) {
    const element = form?.querySelector(`[name="${name}"]`);
    if (
      element instanceof HTMLInputElement ||
      element instanceof HTMLSelectElement ||
      element instanceof HTMLTextAreaElement
    ) {
      element.value = String(value ?? "");
    }
  }

  function collectSteps() {
    return Array.from(document.querySelectorAll("[data-step]"))
      .map((step) => {
        const title = step.querySelector('[name="stepTitle"]')?.value.trim() ?? "";
        const instructions = step.querySelector('[name="stepInstructions"]')?.value.trim() ?? "";
        const note = step.querySelector('[name="stepNote"]')?.value.trim() ?? "";
        const screenshot = step.querySelector('[name="stepScreenshot"]')?.value.trim() ?? "";
        const video = step.querySelector('[name="stepVideo"]')?.value.trim() ?? "";
        const videoLabel = step.querySelector('[name="stepVideoLabel"]')?.value.trim() ?? "";
        return { title, instructions, note, screenshot, video, videoLabel };
      })
      .filter((step) => step.title || step.instructions);
  }

  function getStepFromElement(element) {
    return element instanceof HTMLElement ? element.closest("[data-step]") : null;
  }

  function setPasteTargetMessage(pasteTarget, message) {
    if (pasteTarget instanceof HTMLTextAreaElement) {
      pasteTarget.value = message;
    } else if (pasteTarget instanceof HTMLElement) {
      pasteTarget.textContent = message;
    }
  }

  function updateStepScreenshotPreview(step) {
    if (!(step instanceof HTMLElement)) return;

    const screenshotInput = step.querySelector('[name="stepScreenshot"]');
    const videoInput = step.querySelector('[name="stepVideo"]');
    const videoLabelInput = step.querySelector('[name="stepVideoLabel"]');
    const preview = step.querySelector("[data-screenshot-preview]");
    const image = step.querySelector("[data-screenshot-image]");
    const video = step.querySelector("[data-screenshot-video]");
    const pasteTarget = step.querySelector("[data-screenshot-paste]");
    const screenshot =
      screenshotInput instanceof HTMLInputElement ? screenshotInput.value.trim() : "";
    const videoSource = videoInput instanceof HTMLInputElement ? videoInput.value.trim() : "";
    const videoLabel =
      videoLabelInput instanceof HTMLInputElement ? videoLabelInput.value.trim() : "Step video";

    if (
      !(preview instanceof HTMLElement) ||
      !(image instanceof HTMLImageElement) ||
      !(video instanceof HTMLVideoElement)
    ) {
      return;
    }

    if (screenshot) {
      image.src = screenshot;
      image.hidden = false;
      video.hidden = true;
      video.removeAttribute("src");
      preview.hidden = false;
      setPasteTargetMessage(
        pasteTarget,
        "Screenshot added. Paste a replacement here or upload a new file.",
      );
    } else if (videoSource) {
      video.src = videoSource;
      video.hidden = false;
      image.hidden = true;
      image.removeAttribute("src");
      preview.hidden = false;
      setPasteTargetMessage(
        pasteTarget,
        `${videoLabel} added. Upload a replacement image or video file.`,
      );
    } else {
      image.removeAttribute("src");
      image.hidden = false;
      video.removeAttribute("src");
      video.hidden = true;
      preview.hidden = true;
      setPasteTargetMessage(
        pasteTarget,
        "Paste a screenshot here or upload an image or video file.",
      );
    }
  }

  function setStepMedia(step, { screenshot = "", video = "", videoLabel = "" }) {
    if (!(step instanceof HTMLElement)) return;

    const screenshotInput = step.querySelector('[name="stepScreenshot"]');
    const videoInput = step.querySelector('[name="stepVideo"]');
    const videoLabelInput = step.querySelector('[name="stepVideoLabel"]');
    if (screenshotInput instanceof HTMLInputElement) {
      screenshotInput.value = screenshot;
    }
    if (videoInput instanceof HTMLInputElement) {
      videoInput.value = video;
    }
    if (videoLabelInput instanceof HTMLInputElement) {
      videoLabelInput.value = videoLabel;
    }
    updateStepScreenshotPreview(step);
  }

  function setStepScreenshot(step, value) {
    setStepMedia(step, { screenshot: value });
  }

  function setStepVideo(step, value, label) {
    setStepMedia(step, { video: value, videoLabel: label });
  }

  function readVideoFile(file, step) {
    if (!file.type.startsWith("video/")) return;

    const reader = new FileReader();
    reader.addEventListener("load", () => {
      setStepVideo(step, typeof reader.result === "string" ? reader.result : "", file.name || "Step video");
      if (errorsEl) {
        errorsEl.hidden = true;
        errorsEl.innerHTML = "";
      }
    });
    reader.readAsDataURL(file);
  }

  function readStepMediaFile(file, step) {
    if (file.type.startsWith("image/")) {
      readImageFile(file, step);
      return;
    }
    if (file.type.startsWith("video/")) {
      readVideoFile(file, step);
      return;
    }

    if (errorsEl) {
      errorsEl.hidden = false;
      errorsEl.innerHTML = "<p>Please choose an image or video file for this step.</p>";
    }
  }

  function getClipboardMediaFile(clipboardData) {
    const files = Array.from(clipboardData?.files || []);
    const file = files.find((item) =>
      item.type.startsWith("image/") || item.type.startsWith("video/"),
    );
    if (file) return file;

    const items = Array.from(clipboardData?.items || []);
    const mediaItem = items.find((item) =>
      item.kind === "file" &&
      (item.type.startsWith("image/") || item.type.startsWith("video/")),
    );
    return mediaItem?.getAsFile() || null;
  }

  function readImageFile(file, step) {
    if (!file.type.startsWith("image/")) {
      if (errorsEl) {
        errorsEl.hidden = false;
        errorsEl.innerHTML = "<p>Please choose or paste an image file for the step screenshot.</p>";
      }
      return;
    }

    const reader = new FileReader();
    reader.addEventListener("load", () => {
      setStepScreenshot(step, typeof reader.result === "string" ? reader.result : "");
      if (errorsEl) {
        errorsEl.hidden = true;
        errorsEl.innerHTML = "";
      }
    });
    reader.readAsDataURL(file);
  }

  function createStepElement(step = {}, index = 1) {
    const wrapper = document.createElement("div");
    wrapper.className = "procedure-step";
    wrapper.dataset.step = "";
    wrapper.innerHTML = `
      <div class="procedure-step__header">
        <strong>Step ${index}</strong>
        ${index > 1 ? '<button class="button button--ghost" type="button" data-remove-step>Remove</button>' : ""}
      </div>
      <div class="field">
        <label>Step title</label>
        <input name="stepTitle" type="text" required />
      </div>
      <div class="field field--full">
        <label>Step instructions</label>
        <textarea name="stepInstructions" rows="3" required></textarea>
      </div>
      <div class="field">
        <label>Optional note</label>
        <input name="stepNote" type="text" />
      </div>
      <div class="field field--full">
        <label>Step screenshot</label>
        <div class="screenshot-input" data-screenshot-input>
          <input name="stepScreenshot" type="hidden" />
          <input name="stepVideo" type="hidden" />
          <input name="stepVideoLabel" type="hidden" />
          <input name="stepScreenshotFile" type="file" accept="image/*,video/*" />
          <textarea
            class="screenshot-paste-target"
            aria-label="Paste step media"
            rows="3"
            spellcheck="false"
            data-screenshot-paste
          >Paste a screenshot here or upload an image or video file.</textarea>
          <figure class="screenshot-preview" data-screenshot-preview hidden>
            <img alt="Step screenshot preview" data-screenshot-image />
            <video controls data-screenshot-video hidden></video>
            <figcaption>
              <button class="button button--ghost" type="button" data-remove-screenshot>
                Remove Media
              </button>
            </figcaption>
          </figure>
        </div>
      </div>
    `;

    wrapper.querySelector('[name="stepTitle"]').value = step.title || "";
    wrapper.querySelector('[name="stepInstructions"]').value = step.instructions || "";
    wrapper.querySelector('[name="stepNote"]').value = step.note || "";
    wrapper.querySelector('[name="stepScreenshot"]').value = step.screenshot || "";
    wrapper.querySelector('[name="stepVideo"]').value = step.video || "";
    wrapper.querySelector('[name="stepVideoLabel"]').value = step.videoLabel || "";
    updateStepScreenshotPreview(wrapper);

    return wrapper;
  }

  function renderSteps(steps) {
    if (!stepContainer) return;

    const safeSteps = Array.isArray(steps) && steps.length > 0 ? steps : [{}];
    stepContainer.innerHTML = "";
    safeSteps.forEach((step, index) => {
      stepContainer.append(createStepElement(step, index + 1));
    });
  }

  function loadEditSource() {
    const params = new URLSearchParams(window.location.search);
    if (!params.has("edit")) return;

    let source = null;
    try {
      source = JSON.parse(sessionStorage.getItem(EDIT_SOP_STORAGE_KEY) || "null");
    } catch {
      source = null;
    }

    if (!source && params.get("edit") === "draft") {
      const draftId = params.get("id");
      const draft = readStorage(DRAFTS_STORAGE_KEY).find((item) => item.id === draftId);
      if (draft) {
        source = {
          ...draft,
          editMode: "draft",
        };
      }
    }

    if (!source) {
      if (createHeading) createHeading.textContent = "Edit Published SOP";
      if (createDescription) {
        createDescription.textContent =
          "Open an SOP and use its Edit Published SOP button to prefill this draft editor.";
      }
      showCancelEditAction("/search/");
      return;
    }

    const isDraftEdit = source.editMode === "draft";
    editingSource = isDraftEdit ? null : source;
    editingDraftId = isDraftEdit ? source.id || "" : "";
    editingCreatedDate = isDraftEdit ? source.createdDate || "" : "";

    if (createHeading) {
      createHeading.textContent = isDraftEdit ? "Edit SOP Draft" : "Edit Published SOP";
    }
    if (createDescription) {
      createDescription.textContent = isDraftEdit
        ? `Continue editing "${source.title}". Saving will update this draft in My Drafts.`
        : `Create a reviewed draft update for "${source.sourceTitle || source.title}". The published SOP stays unchanged until the revised draft is approved.`;
    }
    showCancelEditAction(isDraftEdit ? "/drafts/" : getPublishedSopUrl(source));

    setField("title", source.title);
    setField("purpose", source.purpose);
    setField("owner", source.owner);
    setField("category", source.category);
    setField("type", source.type);
    setField("reviewDate", source.reviewDate);
    setField("tools", (source.tools || []).join(", "));
    setField("audience", (source.audience || []).join(", "));
    setField("tags", (source.tags || []).join(", "));
    setField("estimatedCompletionTime", source.estimatedCompletionTime);
    setField("beforeYouBegin", source.beforeYouBegin);
    setField("screenshots", (source.screenshots || []).join("\n"));
    setField("troubleshootingNotes", source.troubleshootingNotes);
    setField("relatedSops", (source.relatedSops || []).join(", "));
    setField("changeSummary", source.changeSummary);
    setField("status", isDraftEdit ? source.status || "Draft" : "Draft");
    setField("version", source.version);
    renderSteps(source.procedureSteps);
  }

  function validateDraft(draft) {
    const errors = [];

    if (!draft.title) errors.push("SOP Title is required.");
    if (!draft.purpose) errors.push("Purpose is required.");
    if (!draft.owner) errors.push("Owner is required.");
    if (!draft.category) errors.push("Category is required.");
    if (!draft.type) errors.push("SOP Type is required.");
    if (!draft.reviewDate) errors.push("Review Date is required.");
    if (!draft.procedureSteps.length) errors.push("At least one procedure step is required.");
    if (draft.procedureSteps.some((step) => !step.title || !step.instructions)) {
      errors.push("Each procedure step needs a title and instructions.");
    }

    if (errorsEl) {
      errorsEl.hidden = errors.length === 0;
      errorsEl.innerHTML = errors.map((error) => `<p>${escapeHtml(error)}</p>`).join("");
    }

    return errors.length === 0;
  }

  function buildDraft(statusOverride) {
    const today = new Date().toISOString().slice(0, 10);
    const title = getField("title");

    return {
      id: editingDraftId || `draft-${slugify(title || "untitled")}-${Date.now()}`,
      title,
      purpose: getField("purpose"),
      owner: getField("owner"),
      category: getField("category"),
      type: getField("type"),
      tools: splitList(getField("tools")),
      audience: splitList(getField("audience")),
      tags: splitList(getField("tags")),
      estimatedCompletionTime: getField("estimatedCompletionTime"),
      beforeYouBegin: getField("beforeYouBegin"),
      procedureSteps: collectSteps(),
      screenshots: splitList(getField("screenshots")),
      troubleshootingNotes: getField("troubleshootingNotes"),
      relatedSops: splitList(getField("relatedSops")),
      reviewDate: getField("reviewDate"),
      status: statusOverride || getField("status") || "Draft",
      version: getField("version") || "0.1",
      changeSummary: getField("changeSummary") || "Initial draft created.",
      createdDate: editingCreatedDate || today,
      updatedDate: today,
      sourceId: editingSource?.sourceId,
      sourceSlug: editingSource?.sourceSlug,
      sourceTitle: editingSource?.sourceTitle,
    };
  }

  function renderPreview(draft) {
    document.getElementById("preview-title").textContent = draft.title;
    document.getElementById("preview-purpose").textContent = draft.purpose;
    document.getElementById("preview-before").textContent =
      draft.beforeYouBegin || "No before-you-begin notes entered.";
    document.getElementById("preview-notes").textContent =
      draft.troubleshootingNotes || "No troubleshooting notes entered.";

    document.getElementById("preview-meta").innerHTML = [
      ["Owner", draft.owner],
      ["Category", draft.category],
      ["Tools used", draft.tools.join(", ") || "None listed"],
      ["Audience", draft.audience.join(", ") || "None listed"],
      ["Status", draft.status],
      ["Version", draft.version],
      ["Review date", draft.reviewDate],
      ["Estimated time", draft.estimatedCompletionTime || "Not estimated"],
    ]
      .map(([label, value]) => `<div><dt>${label}</dt><dd>${escapeHtml(value)}</dd></div>`)
      .join("");

    document.getElementById("preview-steps").innerHTML = draft.procedureSteps
      .map(
        (step) => `
          <li>
            <h4>${escapeHtml(step.title)}</h4>
            <p>${escapeHtml(step.instructions)}</p>
            ${step.note ? `<p><strong>Note:</strong> ${escapeHtml(step.note)}</p>` : ""}
            ${
              step.screenshot
                ? `<figure class="step-screenshot"><img src="${escapeHtml(step.screenshot)}" alt="Screenshot for ${escapeHtml(step.title)}" /><figcaption>Step screenshot</figcaption></figure>`
                : ""
            }
            ${
              step.video
                ? `<figure class="step-screenshot"><video controls src="${escapeHtml(step.video)}"></video><figcaption>${escapeHtml(step.videoLabel || "Step video")}</figcaption></figure>`
                : ""
            }
          </li>
        `,
      )
      .join("");

    document.getElementById("preview-related").innerHTML =
      draft.relatedSops.length > 0
        ? draft.relatedSops.map((item) => `<li>${escapeHtml(item)}</li>`).join("")
        : "<li>No related SOPs entered.</li>";

    preview.hidden = false;
    preview.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function readStorage(key) {
    try {
      return JSON.parse(localStorage.getItem(key) || "[]");
    } catch {
      return [];
    }
  }

  function writeStorage(key, value) {
    localStorage.setItem(key, JSON.stringify(value));
  }

  function mergeById(...groups) {
    const map = new Map();
    groups.flat().forEach((item) => {
      if (item?.id) map.set(item.id, item);
    });
    return Array.from(map.values());
  }

  function getPublishingUsers() {
    return mergeById(initialPublishingUsers, readStorage(USER_STORAGE_KEY))
      .filter((user) => user.status === "Active")
      .sort((a, b) => {
        const aCanPublish = a.accessLevel === "Creator / Reviewer";
        const bCanPublish = b.accessLevel === "Creator / Reviewer";
        return Number(bCanPublish) - Number(aCanPublish) || a.name.localeCompare(b.name);
      });
  }

  function renderPublishingAccounts() {
    if (!(publishingAccount instanceof HTMLSelectElement)) return;

    const selected = publishingAccount.value;
    const users = getPublishingUsers();
    publishingAccount.innerHTML = users
      .map(
        (user) =>
          `<option value="${escapeHtml(user.email)}">${escapeHtml(user.name)} - ${escapeHtml(
            user.accessLevel,
          )}</option>`,
      )
      .join("");
    if (users.some((user) => user.email === selected)) {
      publishingAccount.value = selected;
    }
  }

  function getSelectedPublisher() {
    const email =
      publishingAccount instanceof HTMLSelectElement ? publishingAccount.value : "";
    return getPublishingUsers().find((user) => user.email === email) || null;
  }

  function canPublish(user) {
    return user?.accessLevel === "Creator / Reviewer" && user.status === "Active";
  }

  function updatePublishCapability() {
    const publisher = getSelectedPublisher();
    const allowed = canPublish(publisher);

    if (publishButton instanceof HTMLButtonElement) {
      publishButton.disabled = !allowed;
      publishButton.title = allowed
        ? "Publish this SOP"
        : "Only active Creator / Reviewer accounts can publish SOPs.";
    }
    if (publishPermission instanceof HTMLElement) {
      publishPermission.innerHTML = allowed
        ? `<strong>Publish enabled:</strong> ${escapeHtml(publisher.name)} can publish SOPs.`
        : "<strong>Publish disabled:</strong> only active Creator / Reviewer accounts can publish SOPs.";
    }
  }

  function upsertReviewItem(draft, status = "Published") {
    const reviewItem = {
      id: `review-${draft.id}`,
      source: "Internal SOP Creator",
      submissionType: "Submit a draft SOP",
      title: draft.title,
      department: draft.audience[0],
      submittedBy: draft.owner,
      category: draft.category,
      priority: "Medium",
      status,
      assignedOwner: draft.owner,
      createdDate: draft.createdDate,
      reviewDate: draft.reviewDate,
      originalId: draft.id,
    };
    const reviewItems = readStorage(REVIEW_QUEUE_STORAGE_KEY).filter(
      (item) => item.id !== reviewItem.id,
    );
    writeStorage(REVIEW_QUEUE_STORAGE_KEY, [...reviewItems, reviewItem]);
  }

  function savePublishedSop(draft, publisher) {
    const publishedAt = new Date().toISOString();
    const sourceId = editingSource?.sourceId || draft.sourceId || draft.id;
    const sourceSlug = editingSource?.sourceSlug || draft.sourceSlug || slugify(draft.title);
    const url = editingSource?.sourceId
      ? getPublishedSopUrl(editingSource)
      : `/published/?id=${encodeURIComponent(draft.id)}`;
    const published = {
      ...draft,
      id: sourceId,
      draftId: draft.id,
      sourceId,
      sourceSlug,
      status: "Published",
      lastUpdated: draft.updatedDate,
      publishedAt,
      publishedBy: publisher.name,
      publishedByEmail: publisher.email,
      url,
    };

    const publishedSops = readStorage(PUBLISHED_SOPS_STORAGE_KEY).filter(
      (item) => item.id !== published.id,
    );
    writeStorage(PUBLISHED_SOPS_STORAGE_KEY, [...publishedSops, published]);
    return published;
  }

  function storeDraft(draft, submitForReview) {
    const drafts = readStorage(DRAFTS_STORAGE_KEY).filter((item) => item.id !== draft.id);
    writeStorage(DRAFTS_STORAGE_KEY, [...drafts, draft]);

    if (submitForReview) {
      upsertReviewItem(draft, "In Review");
    }
  }

  addStepButton?.addEventListener("click", () => {
    if (!stepContainer) return;

    const stepCount = stepContainer.querySelectorAll("[data-step]").length + 1;
    stepContainer.append(createStepElement({}, stepCount));
  });

  stepContainer?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    if (target.matches("[data-remove-step]")) {
      target.closest("[data-step]")?.remove();
    }

    if (target.matches("[data-remove-screenshot]")) {
      const step = getStepFromElement(target);
      setStepMedia(step, {});
      const fileInput = step?.querySelector('[name="stepScreenshotFile"]');
      if (fileInput instanceof HTMLInputElement) {
        fileInput.value = "";
      }
    }
  });

  stepContainer?.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement) || target.name !== "stepScreenshotFile") return;

    const file = target.files?.[0];
    if (file) {
      readStepMediaFile(file, getStepFromElement(target));
    }
  });

  stepContainer?.addEventListener("keydown", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement) || !target.closest("[data-screenshot-paste]")) return;

    const isPasteShortcut = (event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "v";
    const isNavigationKey = ["Tab", "Escape"].includes(event.key);
    if (!isPasteShortcut && !isNavigationKey) {
      event.preventDefault();
    }
  });

  stepContainer?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const pasteTarget = target.closest("[data-screenshot-paste]");
    if (pasteTarget instanceof HTMLElement) {
      updateStepScreenshotPreview(getStepFromElement(pasteTarget));
    }
  });

  stepContainer?.addEventListener("paste", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement) || !target.closest("[data-screenshot-paste]")) return;

    event.preventDefault();
    const file = getClipboardMediaFile(event.clipboardData);
    if (!file) {
      updateStepScreenshotPreview(getStepFromElement(target));
      if (errorsEl) {
        errorsEl.hidden = false;
        errorsEl.innerHTML = "<p>Please paste an image or video file for the step media.</p>";
      }
      return;
    }

    readStepMediaFile(file, getStepFromElement(target));
  });

  cancelEditLink?.addEventListener("click", () => {
    try {
      sessionStorage.removeItem(EDIT_SOP_STORAGE_KEY);
    } catch {
      // Navigation is enough if storage is unavailable.
    }
  });

  previewButton?.addEventListener("click", () => {
    const draft = buildDraft();
    if (!validateDraft(draft)) return;

    currentDraft = draft;
    confirmation.hidden = true;
    renderPreview(draft);
    updatePublishCapability();
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const actionButton = target.closest("[data-draft-action]");
    if (!(actionButton instanceof HTMLElement)) return;

    const action = actionButton.dataset.draftAction;

    if (action === "clear") {
      form?.reset();
      preview.hidden = true;
      confirmation.hidden = true;
      currentDraft = null;
      updatePublishCapability();
      return;
    }

    if (!currentDraft) {
      const draft = buildDraft(
        action === "publish" ? "Published" : action === "submit" ? "In Review" : "Draft",
      );
      if (!validateDraft(draft)) return;
      currentDraft = draft;
      renderPreview(draft);
    }

    if (action === "publish") {
      const publisher = getSelectedPublisher();
      if (!canPublish(publisher)) {
        if (errorsEl) {
          errorsEl.hidden = false;
          errorsEl.innerHTML =
            "<p>Only active Creator / Reviewer accounts can publish SOPs. Choose a creator/reviewer account before publishing.</p>";
        }
        updatePublishCapability();
        return;
      }

      const publishedDraft = {
        ...currentDraft,
        status: "Published",
        updatedDate: new Date().toISOString().slice(0, 10),
        publishedBy: publisher.name,
        publishedByEmail: publisher.email,
      };
      const published = savePublishedSop(publishedDraft, publisher);
      storeDraft(publishedDraft, false);
      upsertReviewItem(publishedDraft, "Published");
      currentDraft = publishedDraft;

      if (errorsEl) {
        errorsEl.hidden = true;
        errorsEl.innerHTML = "";
      }
      if (confirmation) {
        confirmation.hidden = false;
        confirmation.innerHTML = `<strong>Your SOP has been published.</strong><p>Published by ${escapeHtml(
          publisher.name,
        )}. <a href="${escapeHtml(published.url)}">View the published SOP</a>.</p>`;
      }
      return;
    }

    const draftToStore = {
      ...currentDraft,
      status: action === "submit" ? "In Review" : currentDraft.status || getField("status") || "Draft",
      updatedDate: new Date().toISOString().slice(0, 10),
    };

    storeDraft(draftToStore, action === "submit");

    if (confirmation) {
      confirmation.hidden = false;
      confirmation.innerHTML =
        action === "submit"
          ? "<strong>Your SOP draft has been submitted for review.</strong><p>Next steps: A reviewer will verify the content, request revisions if needed, and publish the SOP once approved.</p>"
          : "<strong>Your SOP draft has been saved.</strong>";
    }
  });

  renderPublishingAccounts();
  updatePublishCapability();
  publishingAccount?.addEventListener("change", updatePublishCapability);
  loadEditSource();
</script>
