---
import { priorityBadgeDefinitions, statusBadgeDefinitions } from "../lib/badges";
import AppIllustration from "./AppIllustration.astro";

interface Props {
  mode?: "admin" | "queue" | "creator-reviewer" | "needs-review" | "admin-needs-review";
}

const { mode = "admin" } = Astro.props;
const isCreatorReviewMode = mode === "creator-reviewer";
const isAdminMode = mode === "admin" || mode === "queue" || mode === "admin-needs-review";
const isNeedsReviewMode = mode === "needs-review" || mode === "admin-needs-review";

const filters = [
  "All",
  "Internal Drafts",
  "Outside Department Submissions",
  "New SOP Requests",
  "Updates",
  "Templates",
  "Urgent",
  "Approved",
  "Published",
  "Archived",
];

const summaryFilters = [
  { label: "New", key: "new", filter: "summary:new" },
  { label: "Needs Review", key: "needsReview", filter: "summary:needs-review" },
  { label: "Urgent", key: "urgent", filter: "summary:urgent" },
  { label: "Approved", key: "approved", filter: "summary:approved" },
  { label: "Archived", key: "archived", filter: "summary:archived" },
  { label: "Published", key: "published", filter: "summary:published" },
];

const heading = isNeedsReviewMode ? "Needs Review" : isCreatorReviewMode ? "Review Queue" : "Admin Review Control Center";
const eyebrow = isNeedsReviewMode || isCreatorReviewMode ? "Creators / Reviewers" : "Review Queue";
const description = isNeedsReviewMode
  ? "Review backend SOP submissions, drafts, updates, and requests assigned to your selected department."
  : isCreatorReviewMode
    ? "Review assigned SOPs, provide feedback, and complete actions available for your current Creator / Reviewer role."
  : "Review, assign, approve, request changes, publish, and archive backend SOP work from one queue.";
---

<section class="tool-surface review-queue" aria-labelledby="review-heading">
  <div class="section-heading surface-intro">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1 id="review-heading">{heading}</h1>
      <p id="review-description">{description}</p>
    </div>
    <AppIllustration name={isNeedsReviewMode ? "needsReview" : "review"} size="md" />
  </div>

  <div class="form-grid work-user-panel">
    <div class="field">
      <label for="review-work-view">{isNeedsReviewMode ? "Needs Review scope" : "Review work view"}</label>
      <select id="review-work-view">
        <option value={isAdminMode ? "admin" : "team"}>Loading review queues...</option>
      </select>
    </div>
    <div class="field">
      <label for="review-work-scope">Current work scope</label>
      <input id="review-work-scope" type="text" readonly value="Loading..." />
    </div>
  </div>

  <div class="review-origin-nav no-print" id="review-origin-nav" hidden></div>
  <div class="drafts-context" id="review-context" role="status">Loading review queue context...</div>

  {!isNeedsReviewMode && <div class="stat-grid review-summary" aria-label="Review queue counts">
    {summaryFilters.map((summary) => (
      <button
        class="stat-card review-summary__card"
        type="button"
        data-review-summary-filter={summary.filter}
        data-summary-key={summary.key}
        aria-pressed="false"
        aria-label={`Show ${summary.label} review queue items`}
      >
        <span>{summary.label}</span>
        <strong data-review-summary-count>0</strong>
      </button>
    ))}
  </div>}

  {!isNeedsReviewMode && <div class="filter-tabs no-print" role="tablist" aria-label="Review queue filters">
    {filters.map((filter, index) => (
      <button
        class="filter-tab"
        type="button"
        role="tab"
        aria-selected={index === 0 ? "true" : "false"}
        data-review-filter={filter}
      >
        {filter}
      </button>
    ))}
  </div>}

  <div id="review-errors" class="form-errors" role="alert" hidden></div>
  <div id="review-confirmation" class="confirmation" role="status" hidden></div>
  <div id="review-list" class="review-list" aria-live="polite">
    <div class="empty-state">
      <strong>Loading review items</strong>
      <p>Connecting to the live Cloudflare database.</p>
    </div>
  </div>
</section>

<script is:inline define:vars={{ summaryFilters, priorityBadgeDefinitions, statusBadgeDefinitions, isNeedsReviewMode, isCreatorReviewMode, isAdminMode }}>
  const list = document.getElementById("review-list");
  const contextEl = document.getElementById("review-context");
  const originNavEl = document.getElementById("review-origin-nav");
  const descriptionEl = document.getElementById("review-description");
  const workViewSelect = document.getElementById("review-work-view");
  const workScopeInput = document.getElementById("review-work-scope");
  const errorsEl = document.getElementById("review-errors");
  const confirmation = document.getElementById("review-confirmation");
  const tabs = Array.from(document.querySelectorAll("[data-review-filter]"));
  const summaryCards = Array.from(document.querySelectorAll("[data-review-summary-filter]"));
  const ROLE_CONTEXT_EVENT = "sop-role-context-change";
  const ROLE_KEY = "sopHubSelectedRole";
  const SUB_ROLE_KEY = "sopHubSelectedCreatorSubRole";
  const DEFAULT_FILTER = isNeedsReviewMode ? "summary:needs-review" : "All";
  const safeOrigins = {
    "my-work-submitted-requests": {
      label: "My Submitted Requests",
      href: "/my-work/?workFilter=submitted#work-section-submitted",
      breadcrumb: `
        <li><a href="/">Home</a></li>
        <li><a href="/my-work/?workFilter=submitted#work-section-submitted">My Work</a></li>
        <li><a href="/my-work/?workFilter=submitted#work-section-submitted">My Submitted Requests</a></li>
        <li><span aria-current="page">Review Request</span></li>
      `,
    },
    "my-work-reviews-needed": {
      label: "Reviews Needed",
      href: "/my-work/?workFilter=review#work-section-review",
      breadcrumb: `
        <li><a href="/">Home</a></li>
        <li><a href="/my-work/?workFilter=review#work-section-review">My Work</a></li>
        <li><a href="/my-work/?workFilter=review#work-section-review">Reviews Needed</a></li>
        <li><span aria-current="page">Review SOP</span></li>
      `,
    },
    "my-work-overdue-reviews": {
      label: "Overdue Reviews",
      href: "/my-work/?workFilter=overdue#work-section-overdue",
      breadcrumb: `
        <li><a href="/">Home</a></li>
        <li><a href="/my-work/?workFilter=overdue#work-section-overdue">My Work</a></li>
        <li><a href="/my-work/?workFilter=overdue#work-section-overdue">Overdue Reviews</a></li>
        <li><span aria-current="page">Review SOP</span></li>
      `,
    },
    "my-drafts-review": {
      label: "My Drafts",
      href: "/drafts/",
      breadcrumb: `
        <li><a href="/">Home</a></li>
        <li><a href="/drafts/">My Drafts</a></li>
        <li><span aria-current="page">Review Draft</span></li>
      `,
    },
    "review-queue": {
      label: "Review Queue",
      href: "/review-queue/",
      breadcrumb: `
        <li><a href="/">Home</a></li>
        <li><a href="/review-queue/">Review Queue</a></li>
        <li><span aria-current="page">Review SOP</span></li>
      `,
    },
    "admin-review-queue": {
      label: "Admin Review Queue",
      href: "/admin/review/",
      breadcrumb: `
        <li><a href="/">Home</a></li>
        <li><a href="/admin/review/">Admin Review Queue</a></li>
        <li><span aria-current="page">Review SOP</span></li>
      `,
    },
  };
  const urlFilterMap = {
    "review-needed": "summary:needs-review",
    "needs-review": "summary:needs-review",
    overdue: "summary:overdue",
    urgent: "summary:urgent",
    approved: "summary:approved",
    published: "summary:published",
    archived: "summary:archived",
  };
  function requestedQueueFilter() {
    const value = new URLSearchParams(window.location.search).get("filter") || "";
    return urlFilterMap[value] || DEFAULT_FILTER;
  }
  function requestedReviewId() {
    return new URLSearchParams(window.location.search).get("review") || "";
  }
  function requestedOrigin() {
    const origin = new URLSearchParams(window.location.search).get("origin") || "";
    if (origin && Object.prototype.hasOwnProperty.call(safeOrigins, origin)) return origin;
    return isAdminMode ? "admin-review-queue" : "review-queue";
  }

  function isSubmittedRequestOrigin() {
    return requestedOrigin() === "my-work-submitted-requests";
  }

  let activeFilter = requestedQueueFilter();
  let queueItems = [];
  let queueCounts = {};
  let queueLabels = {};
  let reviewerMembers = [];
  let selectedReviewScope = isAdminMode ? "admin" : "";
  let activeQueueRequestId = 0;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
      return replacements[character];
    });

  function apiHeaders() {
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    return {
      accept: "application/json",
      "content-type": "application/json",
      ...(subRole ? { "x-sop-sub-role": subRole } : {}),
    };
  }

  function selectedSubRoleQuery() {
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    const params = new URLSearchParams();
    if (subRole) params.set("subRole", subRole);
    if (selectedReviewScope === "admin") {
      params.set("scope", "admin");
    } else if (selectedReviewScope) {
      params.set("userId", selectedReviewScope);
    }
    if (isNeedsReviewMode) params.set("view", "needs-review");
    const requestedFilter = new URLSearchParams(window.location.search).get("filter") || "";
    if (requestedFilter) params.set("filter", requestedFilter);
    const reviewId = requestedReviewId();
    if (reviewId) params.set("review", reviewId);
    const query = params.toString();
    return query ? `?${query}` : "";
  }

  function selectedSubRole() {
    return localStorage.getItem(SUB_ROLE_KEY) || "";
  }

  async function parseApiResponse(response) {
    const data = await response.json().catch(() => ({}));
    if (!response.ok || data?.success === false) {
      throw new Error(data?.error?.message || data?.error || `Request failed: ${response.status}`);
    }
    return data.data || data;
  }

  function badgeKey(value) {
    return String(value || "").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
  }

  function needsReviewStatus(status) {
    return [
      "submitted",
      "assigned",
      "draft",
      "under-review",
      "in-review",
      "needs-more-information",
      "needs-revision",
      "accepted",
      "in-progress",
      "draft-created",
      "in-approval",
      "approved",
    ].includes(badgeKey(status));
  }

  function statusBadge(status) {
    const badge = statusBadgeDefinitions[badgeKey(status)] || {
      label: status || "New",
      className: "status-badge--new",
    };
    return `<span class="badge status-badge ${escapeHtml(badge.className)}"><span class="sr-only">Status:</span>${escapeHtml(
      badge.label,
    )}</span>`;
  }

  function priorityBadge(priority) {
    const badge = priorityBadgeDefinitions[badgeKey(priority)] || {
      label: priority || "Medium",
      className: "priority-badge--medium",
    };
    return `<span class="badge priority-badge ${escapeHtml(badge.className)}"><span class="sr-only">Priority:</span>${escapeHtml(
      badge.label,
    )}</span>`;
  }

  function formatDate(value) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? value : `${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
  }

  function matchesSummary(item, filter) {
    const key = badgeKey(item.status);
    if (filter === "summary:new") return ["submitted", "assigned", "draft"].includes(key);
    if (filter === "summary:needs-review") {
      return [
        "submitted",
        "assigned",
        "draft",
        "under-review",
        "in-review",
        "needs-more-information",
        "needs-revision",
        "accepted",
        "in-progress",
        "draft-created",
        "in-approval",
        "approved",
      ].includes(key);
    }
    if (filter === "summary:urgent") return ["High", "Urgent"].includes(item.priority);
    if (filter === "summary:overdue") {
      const rawDate = item.reviewDate || item.dueDate || item.updatedDate;
      const reviewDate = rawDate ? String(rawDate).slice(0, 10) : "";
      const today = new Date().toISOString().slice(0, 10);
      return Boolean(reviewDate && reviewDate < today && needsReviewStatus(item.status));
    }
    if (filter === "summary:approved") return key === "approved";
    if (filter === "summary:published") return key === "published";
    if (filter === "summary:archived") return ["archived", "closed", "declined"].includes(key);
    return true;
  }

  function filterItem(item) {
    const reviewId = requestedReviewId();
    if (reviewId) return item.id === reviewId;
    if (isNeedsReviewMode) return matchesSummary(item, "summary:needs-review");
    if (activeFilter.startsWith("summary:")) return matchesSummary(item, activeFilter);
    if (activeFilter === "All") return true;
    if (activeFilter === "Urgent") return ["High", "Urgent"].includes(item.priority);
    if (activeFilter === "Approved") return badgeKey(item.status) === "approved";
    if (activeFilter === "Published") return badgeKey(item.status) === "published";
    if (activeFilter === "Archived") return ["archived", "closed", "declined"].includes(badgeKey(item.status));
    return item.filterGroup === activeFilter || item.source === activeFilter;
  }

  function renderSummaryCounts() {
    summaryCards.forEach((card) => {
      const key = card.dataset.summaryKey || "";
      const count = Number(queueCounts[key] || 0);
      const label = card.querySelector("span")?.textContent?.trim() || "review";
      const countEl = card.querySelector("[data-review-summary-count]");
      if (countEl) countEl.textContent = String(count);
      card.setAttribute("aria-label", `Show ${count} ${label} review queue item${count === 1 ? "" : "s"}`);
    });
  }

  function assigneeOptions(selected) {
    return [
      `<option value="">Unassigned</option>`,
      ...reviewerMembers.map(
        (member) =>
          `<option value="${escapeHtml(member.id)}" ${member.id === selected ? "selected" : ""}>${escapeHtml(
            member.name,
          )} - ${escapeHtml(member.department || member.accessLevel || "Reviewer")}</option>`,
      ),
    ].join("");
  }

  function renderWorkViewOptions(options, context, scopes = []) {
    if (!(workViewSelect instanceof HTMLSelectElement)) return;
    const mode = context.mode || (isAdminMode ? "admin" : "personal");
    const selectedId = mode === "admin" ? "admin" : mode === "team" ? "team" : context.selectedUser?.id || "";
    selectedReviewScope = selectedId;
    const safeOptions = Array.isArray(options) && options.length ? options : [];
    const scopeLabels = new Map(
      (Array.isArray(scopes) ? scopes : []).map((scope) => [String(scope.id || ""), String(scope.label || "")]),
    );
    workViewSelect.innerHTML = safeOptions
      .map((option) => {
        const suffix = option.id === "team" || option.id === "admin" ? "" : ` - ${option.department || option.accessLevel || "Reviewer"}`;
        const label = scopeLabels.get(String(option.id || "")) || `${option.name}${suffix}`;
        return `<option value="${escapeHtml(option.id)}" ${option.id === selectedId ? "selected" : ""}>${escapeHtml(
          label,
        )}</option>`;
      })
      .join("");
  }

  function actionButton(item, action, label, className = "button--secondary") {
    if (!Array.isArray(item.availableActions) || !item.availableActions.includes(action)) return "";
    if (isCreatorReviewMode && ["assign", "convert", "archive"].includes(action)) return "";
    if (isSubmittedRequestOrigin() && ["approve", "publish"].includes(action)) return "";
    return `<button class="button ${className}" type="button" data-review-action="${escapeHtml(action)}">${escapeHtml(label)}</button>`;
  }

  function detailHref(item) {
    if (isCreatorReviewMode && item.itemType === "request") {
      return `/review-queue/?review=${encodeURIComponent(item.id)}&origin=${encodeURIComponent(requestedOrigin())}`;
    }
    return item.detailUrl || "#";
  }

  function renderItem(item) {
    return `
      <article class="review-card" data-review-id="${escapeHtml(item.id)}" data-review-type="${escapeHtml(item.itemType)}">
        <div class="review-card__header">
          <div>
            <p class="eyebrow">${escapeHtml(item.source)}</p>
            <h2>${escapeHtml(item.title)}</h2>
          </div>
          ${statusBadge(item.status)}
        </div>
        <dl class="review-meta">
          <div><dt>Submission type</dt><dd>${escapeHtml(item.submissionType)}</dd></div>
          <div><dt>Category</dt><dd>${escapeHtml(item.category)}</dd></div>
          <div><dt>Department</dt><dd>${escapeHtml(item.department || "Not listed")}</dd></div>
          <div><dt>${item.itemType === "request" ? "Responsible SOP team" : "Owner"}</dt><dd>${escapeHtml(item.owner || "Unassigned")}</dd></div>
          <div><dt>Submitted by</dt><dd>${escapeHtml(item.submittedBy || "Unknown")}</dd></div>
          <div><dt>Assigned reviewer</dt><dd>${escapeHtml(item.assignedReviewer || "Unassigned")}</dd></div>
          <div><dt>Priority</dt><dd>${priorityBadge(item.priority)}</dd></div>
          <div><dt>Status</dt><dd>${statusBadge(item.status)}</dd></div>
          <div><dt>Review due</dt><dd>${escapeHtml(formatDate(item.reviewDate))}</dd></div>
          <div><dt>Last updated</dt><dd>${escapeHtml(formatDate(item.updatedDate))}</dd></div>
        </dl>
        <div class="review-actions no-print">
          ${
            isAdminMode
              ? `<label>
                  <span>Assigned reviewer</span>
                  <select data-review-assignee>${assigneeOptions(item.assignedTo)}</select>
                </label>`
              : ""
          }
          <label class="field--full">
            <span>Reviewer notes / reason</span>
            <textarea data-review-notes rows="2" placeholder="Add reviewer notes, denial reason, or instructions.">${escapeHtml(
              item.reviewerNotes || item.denialReason || "",
            )}</textarea>
          </label>
          <a class="button button--ghost" href="${escapeHtml(detailHref(item))}">View Details</a>
          ${
            item.editUrl && item.availableActions?.includes("edit")
              ? `<a class="button button--secondary" href="${escapeHtml(item.editUrl)}">Edit Draft</a>`
              : ""
          }
          ${actionButton(item, "review", "Review")}
          ${actionButton(item, "accept", "Accept")}
          ${actionButton(item, "assign", "Assign")}
          ${actionButton(item, "more-info", "Need Info")}
          ${actionButton(item, "decline", "Decline", "button--danger")}
          ${actionButton(item, "revision", "Request Changes")}
          ${actionButton(item, "approve", "Approve")}
          ${actionButton(item, "publish", "Publish", "button--primary")}
          ${actionButton(item, "archive", "Archive", "button--ghost")}
          ${actionButton(item, "convert", "Convert to SOP Draft", "button--primary")}
        </div>
      </article>
    `;
  }

  function renderContext(data) {
    const context = data.context || {};
    const labels = data.labels || {};
    renderWorkViewOptions(data.viewOptions?.users || [], context, data.viewOptions?.scopes || []);
    if (descriptionEl) descriptionEl.textContent = labels.description || descriptionEl.textContent || "";
    if (workScopeInput instanceof HTMLInputElement) {
      workScopeInput.value = context.workScopeLabel || context.accessLevel || "Review Queue";
    }
    const headingEl = document.getElementById("review-heading");
    if (headingEl && !requestedReviewId()) {
      headingEl.textContent = labels.heading || headingEl.textContent || "Review Queue";
    }
    const needsReviewSummary = summaryCards.find((card) => card.dataset.summaryKey === "needsReview");
    if (needsReviewSummary && labels.needsReviewLabel) {
      const labelEl = needsReviewSummary.querySelector("span");
      if (labelEl) labelEl.textContent = labels.needsReviewLabel;
    }
    renderOriginNav();
    if (contextEl) contextEl.textContent = labels.loadedMessage || "Review queue loaded.";
  }

  function renderOriginNav() {
    if (!(originNavEl instanceof HTMLElement)) return;
    const origin = safeOrigins[requestedOrigin()];
    const showOriginNav = Boolean(isCreatorReviewMode && requestedReviewId() && origin);
    originNavEl.hidden = !showOriginNav;
    originNavEl.innerHTML = showOriginNav
      ? `<a class="button button--ghost" href="${escapeHtml(origin.href)}">Back to ${escapeHtml(origin.label)}</a>`
      : "";
  }

  function render() {
    renderSummaryCounts();
    if (!list) return;
    const items = queueItems.filter(filterItem);
    list.innerHTML = items.length
      ? items.map(renderItem).join("")
      : `<div class="empty-state"><strong>No review items</strong><p>${escapeHtml(
          queueLabels.emptyMessage || `No backend review records ${isNeedsReviewMode ? "currently need your review" : "match this filter"} for the selected review queue.`,
        )}</p></div>`;
  }

  function clearQueueState(message = "Connecting to the live Cloudflare database.", { resetFilter = false } = {}) {
    queueItems = [];
    queueCounts = {};
    queueLabels = {};
    reviewerMembers = [];
    if (resetFilter) {
      setActiveFilter(DEFAULT_FILTER);
    } else {
      renderSummaryCounts();
    }
    if (contextEl) {
      contextEl.textContent = "Loading review queue context...";
    }
    if (workScopeInput instanceof HTMLInputElement) {
      workScopeInput.value = "Loading...";
    }
    if (list) {
      list.innerHTML = `<div class="empty-state"><strong>Loading review items</strong><p>${escapeHtml(message)}</p></div>`;
    }
  }

  function showError(error) {
    queueItems = [];
    queueCounts = {};
    queueLabels = {};
    reviewerMembers = [];
    renderSummaryCounts();
    if (errorsEl) {
      errorsEl.hidden = false;
      errorsEl.innerHTML = `<p>${escapeHtml(error instanceof Error ? error.message : "Review Queue could not load.")}</p>`;
    }
    if (list) {
      list.innerHTML = `<div class="empty-state"><strong>Review Queue unavailable</strong><p>The backend queue could not be loaded. Please refresh and try again.</p></div>`;
    }
  }

  async function loadQueue() {
    const requestId = ++activeQueueRequestId;
    const requestedSubRole = selectedSubRole();
    if (errorsEl) errorsEl.hidden = true;
    if (confirmation) confirmation.hidden = true;
    clearQueueState();
    const response = await fetch(`/api/review-queue${selectedSubRoleQuery()}`, {
      headers: apiHeaders(),
      cache: "no-store",
    });
    const data = await parseApiResponse(response);
    if (requestId !== activeQueueRequestId || requestedSubRole !== selectedSubRole()) return;
    queueItems = Array.isArray(data.items) ? data.items : [];
    queueCounts = data.counts || {};
    queueLabels = data.labels || {};
    reviewerMembers = (data.viewOptions?.users || []).filter((member) => member.id !== "team" && member.id !== "admin");
    renderContext(data);
    render();
  }

  async function runAction(card, action) {
    const requestedSubRole = selectedSubRole();
    const id = card.dataset.reviewId || "";
    const itemType = card.dataset.reviewType || "";
    const item = queueItems.find((record) => record.id === id);
    const notesField = card.querySelector("[data-review-notes]");
    const assigneeField = card.querySelector("[data-review-assignee]");
    const notes = notesField instanceof HTMLTextAreaElement ? notesField.value.trim() : "";
    const assignedTo = assigneeField instanceof HTMLSelectElement ? assigneeField.value : "";
    const response = await fetch("/api/review-queue", {
      method: "PUT",
      headers: apiHeaders(),
      body: JSON.stringify({
        id,
        itemType,
        action,
        assignedTo,
        notes,
        denialReason: action === "decline" ? notes : "",
      }),
    });
    await parseApiResponse(response);
    if (requestedSubRole !== selectedSubRole()) return;
    if (confirmation && item) {
      confirmation.hidden = false;
      confirmation.innerHTML = `<strong>Review item updated.</strong><p>${escapeHtml(item.title)} was updated in the backend workflow.</p>`;
    }
    await loadQueue();
  }

  function setActiveFilter(filter) {
    activeFilter = filter || "All";
    tabs.forEach((tab) => tab.setAttribute("aria-selected", String(tab.dataset.reviewFilter === activeFilter)));
    summaryCards.forEach((card) => card.setAttribute("aria-pressed", String(card.dataset.reviewSummaryFilter === activeFilter)));
    render();
  }

  function applyReviewPageContext() {
    const reviewId = requestedReviewId();
    const origin = safeOrigins[requestedOrigin()];
    const heading = document.getElementById("review-heading");
    const breadcrumbs = document.querySelector(".breadcrumbs ol");
    if (isCreatorReviewMode && reviewId) {
      const isRequest = reviewId.startsWith("request:");
      document.title = `${isRequest ? "Review Submitted Request" : "Review SOP"} | SOP Knowledge Hub`;
      if (heading) heading.textContent = isRequest ? "Review Submitted Request" : "Review SOP";
      if (breadcrumbs instanceof HTMLOListElement) breadcrumbs.innerHTML = origin.breadcrumb;
    }
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => setActiveFilter(tab.dataset.reviewFilter));
  });

  summaryCards.forEach((card) => {
    card.addEventListener("click", () => setActiveFilter(card.dataset.reviewSummaryFilter));
  });

  workViewSelect?.addEventListener("change", () => {
    selectedReviewScope = workViewSelect instanceof HTMLSelectElement ? workViewSelect.value || "team" : "team";
    activeQueueRequestId += 1;
    clearQueueState("Refreshing review items for the selected queue.", { resetFilter: true });
    loadQueue().catch(showError);
  });

  list?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-review-action]");
    if (!(button instanceof HTMLElement)) return;
    const card = button.closest("[data-review-id]");
    if (!(card instanceof HTMLElement)) return;
    runAction(card, button.dataset.reviewAction || "review").catch(showError);
  });

  window.addEventListener("storage", (event) => {
    if (event.key === SUB_ROLE_KEY || event.key === ROLE_KEY) {
      selectedReviewScope = isAdminMode ? "admin" : "";
      activeQueueRequestId += 1;
      clearQueueState("Refreshing review items for the newly selected role.", { resetFilter: true });
      loadQueue().catch(showError);
    }
  });

  window.addEventListener(ROLE_CONTEXT_EVENT, (event) => {
    const detail = event instanceof CustomEvent ? event.detail || {} : {};
    if (detail.previousSubRole !== detail.subRole || detail.previousRole !== detail.role) {
      selectedReviewScope = isAdminMode ? "admin" : "";
      activeQueueRequestId += 1;
      clearQueueState("Refreshing review items for the newly selected role.", { resetFilter: true });
      loadQueue().catch(showError);
    }
  });

  loadQueue().catch(showError);
  applyReviewPageContext();
</script>
