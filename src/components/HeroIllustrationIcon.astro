---
interface Props {
  name: "shield" | "search" | "people" | "chart" | "target" | "book" | "documentShield" | "support";
}

const { name } = Astro.props;
---

{
  name === "shield" && (
    <svg class="hero-art-icon hero-art-icon--shield" viewBox="0 0 96 96" role="img" aria-hidden="true">
      <path d="M18 68c-11-17-3-41 16-50 20-10 45 0 52 20 7 19-5 41-26 48-17 5-34-3-42-18Z" fill="#ffe5b8" opacity=".78" />
      <path d="M48 22 70 31v16c0 16-9 27-22 34C35 74 26 63 26 47V31l22-9Z" fill="#10225b" stroke="#10225b" stroke-width="3.2" stroke-linejoin="round" />
      <path d="m39 50 7 7 14-18" fill="none" stroke="#ffffff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M74 17v8M70 21h8M78 28l3 3M66 14l3 3" fill="none" stroke="#ff981f" stroke-width="2.4" stroke-linecap="round" />
      <path d="M22 24h7M25.5 20.5v7" fill="none" stroke="#c8cfdb" stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === "search" && (
    <svg class="hero-art-icon hero-art-icon--search" viewBox="0 0 96 96" role="img" aria-hidden="true">
      <path d="M22 69c-12-15-5-39 12-50 18-11 43-5 53 13 10 19 0 43-21 51-17 7-34 0-44-14Z" fill="#eaf1ff" opacity=".95" />
      <circle cx="42" cy="42" r="21" fill="#ffffff" stroke="#10225b" stroke-width="3.4" />
      <circle cx="42" cy="42" r="13" fill="#f7fbff" stroke="#9aa7bd" stroke-width="2.4" />
      <path d="m58 58 20 20" fill="none" stroke="#10225b" stroke-width="8" stroke-linecap="round" />
      <path d="m58 58 20 20" fill="none" stroke="#2e78ff" stroke-width="4.8" stroke-linecap="round" />
      <path d="M69 19v7M65.5 22.5h7M76 28l2.5 2.5" fill="none" stroke="#2e78ff" stroke-width="2.3" stroke-linecap="round" />
      <path d="M23 23c5-6 12-9 21-9" fill="none" stroke="#ffffff" stroke-width="4" stroke-linecap="round" opacity=".9" />
    </svg>
  )
}

{
  name === "people" && (
    <svg class="hero-art-icon hero-art-icon--people" viewBox="0 0 96 96" role="img" aria-hidden="true">
      <path d="M20 69c-9-16-1-38 16-48 18-10 42-3 51 14 9 18-2 41-23 49-18 7-36 0-44-15Z" fill="#f0e8ff" opacity=".88" />
      <circle cx="39" cy="38" r="12" fill="#ffffff" stroke="#10225b" stroke-width="3" />
      <circle cx="58" cy="40" r="10" fill="#9b78ff" stroke="#10225b" stroke-width="3" />
      <path d="M20 71c3-15 12-23 27-23s24 8 27 23" fill="#eaf1ff" stroke="#10225b" stroke-width="3" stroke-linecap="round" />
      <path d="M44 72c2-10 8-16 20-16 10 0 17 5 20 16" fill="#7f5cf4" stroke="#10225b" stroke-width="3" stroke-linecap="round" />
      <path d="M71 17v7M67.5 20.5h7M22 29l4 4M72 29l4-4" fill="none" stroke="#ff981f" stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === "chart" && (
    <svg class="hero-art-icon hero-art-icon--chart" viewBox="0 0 96 96" role="img" aria-hidden="true">
      <path d="M19 70c-9-16-2-39 17-49 19-9 43-1 51 18 8 19-4 41-25 47-17 5-35-2-43-16Z" fill="#e9f8ed" opacity=".9" />
      <path d="M22 76h56" fill="none" stroke="#10225b" stroke-width="3" stroke-linecap="round" />
      <path d="M31 57h10v19H31z" fill="#2e78ff" stroke="#10225b" stroke-width="3" stroke-linejoin="round" />
      <path d="M46 47h10v29H46z" fill="#19b7e8" stroke="#10225b" stroke-width="3" stroke-linejoin="round" />
      <path d="M61 36h10v40H61z" fill="#9be37a" stroke="#10225b" stroke-width="3" stroke-linejoin="round" />
      <path d="M28 44c10-2 20-12 27-10 7 1 9 9 20-6" fill="none" stroke="#ff981f" stroke-width="4.2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="m73 22 5 1-1 12" fill="none" stroke="#ff981f" stroke-width="4.2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M77 15v7M73.5 18.5h7" fill="none" stroke="#ff981f" stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === "target" && (
    <svg class="hero-art-icon hero-art-icon--target" viewBox="0 0 124 96" role="img" aria-hidden="true">
      <path d="M17 76c-11-18 0-46 23-58 23-11 53-4 66 17 13 21 2 48-23 58-24 10-53 2-66-17Z" fill="#f4f5f7" opacity=".86" />
      <circle cx="49" cy="50" r="31" fill="#ffffff" stroke="#10225b" stroke-width="3.5" />
      <circle cx="49" cy="50" r="21" fill="#dff2ff" stroke="#10225b" stroke-width="3" />
      <circle cx="49" cy="50" r="10" fill="#19b7e8" stroke="#10225b" stroke-width="3" />
      <path d="M49 50 91 18" fill="none" stroke="#10225b" stroke-width="4" stroke-linecap="round" />
      <path d="m84 23 18-8-8 18-10 2 2-10Z" fill="#ff5572" stroke="#10225b" stroke-width="3" stroke-linejoin="round" />
      <path d="M93 17 81 29" fill="none" stroke="#ffffff" stroke-width="2.4" stroke-linecap="round" />
      <path d="M17 72v8M13 76h8M99 48v7M95.5 51.5h7" fill="none" stroke="#ff981f" stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === "book" && (
    <svg class="hero-art-icon hero-art-icon--book" viewBox="0 0 124 96" role="img" aria-hidden="true">
      <path d="M18 75c-11-17-2-44 22-56 23-11 54-4 67 17 13 21 2 48-24 58-24 9-52 0-65-19Z" fill="#f3f5f8" opacity=".88" />
      <path d="M26 26c13-3 25 0 36 9v45c-11-9-23-12-36-9V26Z" fill="#ffffff" stroke="#10225b" stroke-width="3.2" stroke-linejoin="round" />
      <path d="M62 35c11-9 23-12 36-9v45c-13-3-25 0-36 9V35Z" fill="#eaf5ff" stroke="#10225b" stroke-width="3.2" stroke-linejoin="round" />
      <path d="M35 38c6-.5 11 .5 17 3M35 50c6-.5 11 .5 17 3M72 41c5-2 10-3 16-2M72 53c5-2 10-3 16-2" fill="none" stroke="#19b7e8" stroke-width="3" stroke-linecap="round" />
      <path d="M62 35v45" fill="none" stroke="#10225b" stroke-width="3.2" stroke-linecap="round" />
      <path d="M91 17v7M87.5 20.5h7M99 27l3 3" fill="none" stroke="#2e78ff" stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )
}

{
  name === "documentShield" && (
    <svg class="hero-art-icon hero-art-icon--document" viewBox="0 0 180 150" role="img" aria-hidden="true">
      <path d="M118 24c31 15 40 52 22 82-18 31-58 37-88 20-29-17-39-54-22-81 18-29 58-35 88-21Z" fill="#f3f6fb" />
      <path d="M70 28h45l25 25v66H70V28Z" fill="#ffffff" stroke="#10225b" stroke-width="5" stroke-linejoin="round" />
      <path d="M115 28v27h25" fill="#dcecff" stroke="#10225b" stroke-width="5" stroke-linejoin="round" />
      <path d="M86 70h34M86 84h39M86 98h26" fill="none" stroke="#b9c4d6" stroke-width="6" stroke-linecap="round" />
      <path d="M127 91 153 101v16c0 14-10 24-26 31-16-7-26-17-26-31v-16l26-10Z" fill="#ffad36" stroke="#10225b" stroke-width="4.5" stroke-linejoin="round" />
      <path d="m117 119 8 8 16-21" fill="none" stroke="#ffffff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M31 83c0-5 4-9 9-9 2-8 9-13 18-12 7 1 13 6 15 13 5 1 8 5 8 10" fill="none" stroke="#9aa7bd" stroke-width="4" stroke-linecap="round" />
      <path d="M149 42v9M144.5 46.5h9M42 36v8M38 40h8" fill="none" stroke="#9aa7bd" stroke-width="3" stroke-linecap="round" />
    </svg>
  )
}

{
  name === "support" && (
    <svg class="hero-art-icon hero-art-icon--support" viewBox="0 0 64 64" role="img" aria-hidden="true">
      <circle cx="32" cy="32" r="23" fill="#ffffff" stroke="#10225b" stroke-width="4" />
      <circle cx="32" cy="32" r="10" fill="#f7fbff" stroke="#10225b" stroke-width="3" />
      <path d="m17 17 10 10M47 17 37 27M17 47l10-10M47 47 37 37" fill="none" stroke="#19b7e8" stroke-width="5" stroke-linecap="round" />
    </svg>
  )
}
