const iconAccents = accentPaths[name] ?? accentPaths.document;
---

<svg
  class="app-icon"
  data-variant={variant}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={variant === "illustrated" ? "1.8" : "2"}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={label ? undefined : "true"}
  role={label ? "img" : undefined}
  aria-label={label}
>
  {variant === "illustrated" && (
    <>
      {iconAccents.map(({ d, tone }) => <path class={`app-icon__fill app-icon__fill--${tone}`} d={d} />)}
    </>
  )}
  {iconPaths.map((d) => <path d={d} />)}
</svg>
