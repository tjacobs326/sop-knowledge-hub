const iconPaths = paths[name] ?? paths.document;
---

<svg
  class="app-icon"
  data-variant={variant}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={variant === "illustrated" ? "2.4" : "2"}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={label ? undefined : "true"}
  role={label ? "img" : undefined}
  aria-label={label}
>
  {variant === "illustrated" && (
    <>
      <circle class="app-icon__accent app-icon__accent--soft" cx="17.5" cy="6.5" r="2.25" />
      <circle class="app-icon__accent app-icon__accent--warm" cx="6.25" cy="17.25" r="2" />
      <path class="app-icon__accent app-icon__accent--green" d="M16.2 17.5h4.2v2.8h-4.2z" />
    </>
  )}
  {iconPaths.map((d) => <path d={d} />)}
</svg>
