---
interface Props {
  name?: string;
  label?: string;
  variant?: "line" | "illustrated";
  size?: "sm" | "md" | "lg" | "xl";
}

const { name = "document", label, variant = "illustrated", size = "md" } = Astro.props;

const iconMap: Record<string, string> = {
  home: "home",
  search: "file-search",
  target: "target-arrow",
  finder: "map-search",
  categories: "folders",
  submit: "file-plus",
  request: "file-plus",
  work: "briefcase",
  ai: "sparkles",
  create: "file-pencil",
  drafts: "file-pencil",
  review: "file-check",
  needsReview: "file-alert",
  archive: "archive",
  archived: "archive",
  users: "users-group",
  tags: "tags",
  analytics: "chart-bar",
  activity: "history",
  settings: "adjustments-horizontal",
  qa: "shield-check",
  d2l: "book-2",
  template: "template",
  course: "stack-2",
  ticket: "ticket",
  operations: "building",
  finance: "currency-dollar",
  marketing: "speakerphone",
  troubleshooting: "tool",
  support: "lifebuoy",
  upload: "upload",
  attachment: "paperclip",
  image: "photo",
  video: "video",
  department: "building",
  permissions: "shield-lock",
  role: "user-shield",
  published: "circle-check",
  document: "file-text",
  back: "arrow-left",
  restart: "refresh",
  exit: "logout",
};

const iconName = iconMap[name] ?? iconMap.document;
const iconStyle = variant === "line" ? "outline" : "outline";
const src = `/assets/tabler-vocate/tabler-icons/icons/${iconStyle}/${iconName}.svg`;
const decorative = !label;
---

<img
  class="app-icon app-icon--tabler"
  data-variant={variant}
  data-icon={name}
  data-size={size}
  src={src}
  alt={label ?? ""}
  aria-hidden={decorative ? "true" : undefined}
  loading="lazy"
  decoding="async"
/>
