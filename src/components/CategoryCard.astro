---
import { getCategoryUrl } from "../lib/sops";

interface Props {
  name: string;
  slug: string;
  description: string;
  icon?: string;
  color?: string;
  count?: number;
}

const { name, slug, description, icon, color = "#f8fafc", count } = Astro.props;
const href = getCategoryUrl(slug);
---

<a class="category-card" href={href} style={`--card-accent: ${color}`}>
  {icon && <span class="category-card__icon" aria-hidden="true">{icon}</span>}
  <h3>{name}</h3>
  <p>{description}</p>
  <div class="category-card__footer">
    {count !== undefined && (
      <span class="category-card__count">{count} {count === 1 ? "SOP" : "SOPs"}</span>
    )}
    <span class="category-card__arrow" aria-hidden="true">-&gt;</span>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    background: var(--color-white);
  }

  .category-card__icon {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    margin-bottom: 0.75rem;
    color: var(--color-ink);
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
    background: var(--card-accent, var(--color-panel));
    border: 1px solid rgba(26, 50, 99, 0.12);
    border-radius: 999px;
  }

  .category-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .category-card__count {
    color: var(--color-ink);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .category-card__arrow {
    color: var(--color-ink);
    font-weight: 800;
    font-size: 1rem;
    transition: transform 0.15s ease;
  }

  .category-card:hover .category-card__arrow {
    transform: translateX(4px);
  }
</style>
