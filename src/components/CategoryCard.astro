---
import { getCategoryUrl } from "../lib/sops";
import AppIcon from "./AppIcon.astro";

interface Props {
  name: string;
  slug: string;
  description: string;
  icon?: string;
  color?: string;
  count?: number;
}

const { name, slug, description, color = "#f8fafc", count } = Astro.props;
const href = getCategoryUrl(slug);

const iconBySlug: Record<string, string> = {
  "qa-processes": "qa",
  "brightspace-d2l": "d2l",
  templates: "template",
  "course-builds": "course",
  "ivanti-ticketing-system": "ticket",
  operations: "operations",
  finance: "finance",
  marketing: "marketing",
  troubleshooting: "troubleshooting",
  "ai-tools": "ai",
};

const iconName = iconBySlug[slug] ?? "document";
---

<a class="category-card" href={href} style={`--card-accent: ${color}`}>
  <div class="category-card__header">
    <span class="category-card__icon" aria-hidden="true"><AppIcon name={iconName} variant="illustrated" /></span>
    <h2 class="category-card__title">{name}</h2>
  </div>
  <p>{description}</p>
  <div class="category-card__footer">
    {count !== undefined && (
      <span class="category-card__count"><AppIcon name="document" />{count} {count === 1 ? "SOP" : "SOPs"}</span>
    )}
    <span class="category-card__arrow" aria-hidden="true">&rsaquo;</span>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    min-height: 16rem;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.98)),
      var(--card-accent);
    border-top: 4px solid color-mix(in srgb, var(--card-accent), var(--color-kindle) 50%);
  }

  .category-card__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.05rem;
    align-items: start;
    padding-bottom: 1.05rem;
    margin-bottom: 0.75rem;
  }

  .category-card__title {
    display: block;
    min-width: 0;
    max-width: 100%;
    min-height: 0;
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(1.12rem, 1.35vw, 1.28rem);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0;
    text-wrap: balance;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: manual;
    white-space: normal;
  }

  .category-card__icon {
    display: grid;
    width: clamp(3.45rem, 4.8vw, 4.15rem);
    height: clamp(3.45rem, 4.8vw, 4.15rem);
    place-items: center;
    color: var(--color-ink);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.92)),
      var(--card-accent, var(--color-panel));
    border: 1.5px solid color-mix(in srgb, var(--card-accent, #dfe6f2), var(--color-ink) 18%);
    border-radius: 14px;
    box-shadow: 0 12px 24px rgba(11, 31, 68, 0.08);
  }

  .category-card__icon .app-icon {
    width: 2.45rem;
    height: 2.45rem;
  }

  .category-card p {
    margin: 0;
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.55;
  }

  .category-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-border);
  }

  .category-card__count {
    display: inline-flex;
    gap: 0.42rem;
    align-items: center;
    color: var(--color-ink);
    font-size: 0.9rem;
    font-weight: 900;
  }

  .category-card__count .app-icon {
    width: 1.05rem;
    height: 1.05rem;
  }

  .category-card__arrow {
    color: #52627a;
    font-weight: 800;
    font-size: 1.8rem;
    line-height: 1;
    transition: transform 0.15s ease;
  }

  .category-card:hover .category-card__arrow {
    transform: translateX(4px);
  }
</style>
