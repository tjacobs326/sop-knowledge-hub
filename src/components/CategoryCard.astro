---
import { getCategoryUrl } from "../lib/sops";
import AppIcon from "./AppIcon.astro";

interface Props {
  name: string;
  slug: string;
  description: string;
  icon?: string;
  color?: string;
  count?: number;
}

const { name, slug, description, color = "#f8fafc", count } = Astro.props;
const href = getCategoryUrl(slug);

const iconBySlug: Record<string, string> = {
  "qa-processes": "qa",
  "brightspace-d2l": "d2l",
  templates: "template",
  "course-builds": "course",
  "ivanti-ticketing-system": "ticket",
  operations: "operations",
  finance: "finance",
  marketing: "marketing",
  troubleshooting: "troubleshooting",
  "ai-tools": "ai",
};

const iconName = iconBySlug[slug] ?? "document";
---

<a class="category-card" href={href} style={`--card-accent: ${color}`}>
  <div class="category-card__header">
    <span class="category-card__icon" aria-hidden="true"><AppIcon name={iconName} variant="illustrated" /></span>
    <h2 class="category-card__title">{name}</h2>
  </div>
  <p>{description}</p>
  <div class="category-card__footer">
    {count !== undefined && (
      <span class="category-card__count"><AppIcon name="document" />{count} {count === 1 ? "SOP" : "SOPs"}</span>
    )}
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    min-height: 16rem;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), var(--color-linen)),
      var(--card-accent);
    border-top: 4px solid color-mix(in srgb, var(--card-accent), var(--color-kindle) 48%);
  }

  .category-card__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.95rem;
    align-items: start;
    padding-bottom: 1.05rem;
    margin-bottom: 0.75rem;
  }

  .category-card__title {
    display: block;
    min-width: 0;
    max-width: 100%;
    min-height: 0;
    margin: 0;
    color: var(--color-ink);
    font-size: 1.18rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0;
    text-wrap: balance;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: manual;
    white-space: normal;
  }

  .category-card__icon {
    display: grid;
    width: 3.8rem;
    height: 3.35rem;
    place-items: center;
    color: var(--color-ink);
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .category-card__icon .app-icon {
    width: 3.25rem;
    height: 3.25rem;
  }

  .category-card__icon .app-icon[data-variant="illustrated"] > path:not(.app-icon__fill),
  .category-card__icon .app-icon__fill {
    stroke: var(--color-ink);
  }

  .category-card__icon .app-icon__fill--blue {
    fill: var(--color-ink);
  }

  .category-card__icon .app-icon__fill--green {
    fill: var(--color-success);
  }

  .category-card__icon .app-icon__fill--orange {
    fill: var(--color-kindle-accessible);
  }

  .category-card__icon .app-icon__fill--pink {
    fill: var(--color-danger);
  }

  .category-card__icon .app-icon__fill--soft {
    fill: var(--color-muted);
  }

  .category-card__icon .app-icon__fill--yellow {
    fill: var(--color-beacon-accessible);
  }

  .category-card p {
    margin: 0;
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.55;
  }

  .category-card__footer {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-border);
  }

  .category-card__count {
    display: inline-flex;
    gap: 0.48rem;
    align-items: center;
    min-height: 1.55rem;
    color: var(--color-ink);
    font-size: 0.9rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .category-card__count .app-icon {
    flex: 0 0 auto;
    width: 0.95rem;
    height: 0.95rem;
    color: var(--color-ink);
    transform: translateY(-0.02rem);
  }
</style>
