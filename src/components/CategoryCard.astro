---
import { getCategoryUrl } from "../lib/sops";
import AppIcon from "./AppIcon.astro";

interface Props {
  name: string;
  slug: string;
  description: string;
  icon?: string;
  color?: string;
  count?: number;
}

const { name, slug, description, color = "#f8fafc", count } = Astro.props;
const href = getCategoryUrl(slug);

const iconBySlug: Record<string, string> = {
  "qa-processes": "qa",
  "brightspace-d2l": "d2l",
  templates: "template",
  "course-builds": "course",
  "ivanti-ticketing-system": "ticket",
  operations: "operations",
  finance: "finance",
  marketing: "marketing",
  troubleshooting: "troubleshooting",
  "ai-tools": "ai",
};

const iconName = iconBySlug[slug] ?? "document";
---

<a class="category-card" href={href} style={`--card-accent: ${color}`}>
  <div class="category-card__header">
    <span class="category-card__icon" aria-hidden="true"><AppIcon name={iconName} /></span>
    <h2 class="category-card__title">{name}</h2>
  </div>
  <p>{description}</p>
  <div class="category-card__footer">
    {count !== undefined && (
      <span class="category-card__count">{count} {count === 1 ? "SOP" : "SOPs"}</span>
    )}
    <span class="category-card__arrow" aria-hidden="true">-&gt;</span>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    background: var(--color-white);
  }

  .category-card__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.75rem;
    align-items: start;
    padding-bottom: 0.85rem;
    margin-bottom: 0.55rem;
    border-bottom: 1px solid var(--color-border);
  }

  .category-card__title {
    display: block;
    min-width: 0;
    max-width: 100%;
    min-height: 2.55rem;
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(1.02rem, 1.15vw, 1.12rem);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0;
    text-wrap: balance;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: manual;
    white-space: normal;
  }

  .category-card__icon {
    display: grid;
    width: clamp(2.75rem, 4vw, 3.3rem);
    height: clamp(2.75rem, 4vw, 3.3rem);
    place-items: center;
    color: var(--color-ink);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.92)),
      var(--card-accent, var(--color-panel));
    border: 1.5px solid color-mix(in srgb, var(--card-accent, #dfe6f2), var(--color-ink) 18%);
    border-radius: 12px;
  }

  .category-card__icon .app-icon {
    width: 1.65rem;
    height: 1.65rem;
  }

  .category-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .category-card__count {
    color: var(--color-ink);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .category-card__arrow {
    color: var(--color-ink);
    font-weight: 800;
    font-size: 1rem;
    transition: transform 0.15s ease;
  }

  .category-card:hover .category-card__arrow {
    transform: translateX(4px);
  }
</style>
