---
import { getCategoryUrl } from "../lib/sops";

interface Props {
  name: string;
  slug: string;
  description: string;
  icon?: string;
  color?: string;
  count?: number;
}

const { name, slug, description, icon, color = "#f8fafc", count } = Astro.props;
const href = getCategoryUrl(slug);
---

<a class="category-card" href={href} style={`--card-accent: ${color}`}>
  {icon && <span class="category-card__icon" aria-hidden="true">{icon}</span>}
  <h3>{name}</h3>
  <p>{description}</p>
  <div class="category-card__footer">
    {count !== undefined && (
      <span class="category-card__count">{count} {count === 1 ? "SOP" : "SOPs"}</span>
    )}
    <span class="category-card__arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .category-card {
    background: var(--card-accent, var(--color-panel));
    border-top: 3px solid color-mix(in srgb, var(--card-accent) 60%, #999);
    color: inherit;
    text-decoration: none;
  }

  .category-card__icon {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    font-size: 1.45rem;
    margin-bottom: 0.5rem;
    line-height: 1;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(26, 50, 99, 0.12);
    border-radius: 8px;
  }

  .category-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .category-card__count {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .category-card__arrow {
    color: var(--color-kindle);
    font-weight: 800;
    font-size: 1.1rem;
    transition: transform 0.15s ease;
  }

  .category-card:hover .category-card__arrow {
    transform: translateX(4px);
  }

  .category-card {
    display: flex;
    flex-direction: column;
  }
</style>
