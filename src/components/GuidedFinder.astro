<section class="guided-finder guided-workflow" aria-labelledby="finder-heading">
  <div class="ticket-guide-hero guided-workflow__hero">
    <div class="guided-workflow__hero-icon" aria-hidden="true">
      <svg viewBox="0 0 120 120" focusable="false">
        <path class="blob" d="M18 72c-8-29 12-53 43-55 30-2 52 18 54 47 2 30-20 49-49 51-25 2-40-13-48-43Z"></path>
        <path class="target" d="M60 28a31 31 0 1 0 0 62 31 31 0 0 0 0-62Zm0 12a19 19 0 1 1 0 38 19 19 0 0 1 0-38Z"></path>
        <path class="arrow" d="M72 49 92 29m-8 0h8v8"></path>
        <path class="dart" d="m50 68 18-18 9 9-18 18-14 5 5-14Z"></path>
      </svg>
    </div>
    <div class="ticket-guide-hero__content">
      <h1 id="finder-heading">Guided Finder</h1>
      <p>
        Answer a few questions about who you are and what you need to do. We'll recommend the most relevant SOP.
      </p>
    </div>
  </div>

  <div class="guided-workflow__shell">
    <div class="guided-workflow__main">
      <div class="ticket-guide-status guided-workflow__status" id="guided-finder-status" role="status" aria-live="polite">
        Loading Guided Finder options...
      </div>

      <section class="guided-workflow__question" id="guided-finder-question-panel" hidden aria-labelledby="guided-finder-question">
        <div class="guided-workflow__progress">
          <span id="guided-finder-step-count">Step 1 of 1</span>
          <div class="guided-workflow__progress-track" aria-hidden="true">
            <span id="guided-finder-progress-bar"></span>
          </div>
        </div>
        <span class="guided-workflow__question-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" focusable="false">
            <path d="M14 34c0-5 4-9 10-9s10 4 10 9"></path>
            <circle cx="24" cy="16" r="6"></circle>
            <path d="M7 36c0-4 3-7 8-7"></path>
            <path d="M33 29c5 0 8 3 8 7"></path>
            <circle cx="14" cy="19" r="4"></circle>
            <circle cx="34" cy="19" r="4"></circle>
          </svg>
        </span>
        <fieldset class="guided-workflow__fieldset">
          <legend id="guided-finder-question" tabindex="-1">Loading question</legend>
          <p id="guided-finder-help"></p>
          <div class="ticket-guide-choice-grid guided-workflow__choices" id="guided-finder-choices"></div>
        </fieldset>
        <div class="ticket-guide-actions guided-workflow__nav">
          <button class="button button--secondary" type="button" id="guided-finder-back">Back</button>
          <button class="button button--secondary" type="button" id="guided-finder-restart">Start Over</button>
          <a class="button button--secondary" href="/">Exit Guided Finder</a>
        </div>
      </section>
    </div>

    <aside class="ticket-guide-result guided-workflow__results" id="guided-finder-results" aria-live="polite">
      <div class="ticket-guide-empty">
        <span aria-hidden="true">
          <svg viewBox="0 0 120 120" focusable="false">
            <path class="blob" d="M17 73c-8-31 15-54 45-55 31-1 50 23 45 55-5 28-28 43-55 36-18-5-30-17-35-36Z"></path>
            <path class="target" d="M60 29a31 31 0 1 0 0 62 31 31 0 0 0 0-62Zm0 12a19 19 0 1 1 0 38 19 19 0 0 1 0-38Z"></path>
            <path class="arrow" d="M72 48 91 29m-7 0h7v7"></path>
            <path class="dart" d="M55 60h11"></path>
          </svg>
        </span>
        <h2>Ready when you are</h2>
        <p>Answer the guided questions. Results will appear here as the finder narrows the backend SOP records.</p>
      </div>
    </aside>
    <p class="guided-workflow__policy-note">Results are based on published SOPs you are authorized to view.</p>
  </div>
</section>

<script>
  // @ts-nocheck
  const ROLE_CONTEXT_EVENT = "sop-role-context-change";
  const state = {
    requestId: 0,
    options: null,
    steps: [],
    stepIndex: 0,
    filters: {},
    description: "",
    lastResults: [],
  };
  const guidedNeedOptions = [
    "Use a system or tool",
    "Complete a process",
    "Learn how to perform a task",
    "Review or approve work",
    "Troubleshoot a problem",
  ].map((label) => ({ value: label, label }));

  const statusEl = document.getElementById("guided-finder-status");
  const questionPanel = document.getElementById("guided-finder-question-panel");
  const descriptionEl = document.getElementById("guided-finder-description");
  const questionEl = document.getElementById("guided-finder-question");
  const helpEl = document.getElementById("guided-finder-help");
  const choicesEl = document.getElementById("guided-finder-choices");
  const mainEl = document.querySelector(".guided-workflow__main");
  const countEl = document.getElementById("guided-finder-step-count");
  const progressEl = document.getElementById("guided-finder-progress-bar");
  const backButton = document.getElementById("guided-finder-back");
  const restartButton = document.getElementById("guided-finder-restart");
  const resultsEl = document.getElementById("guided-finder-results");

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
      return replacements[character];
    });

  function setStatus(message, tone = "loading") {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.dataset.tone = tone;
  }

  function formatDate(value) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? value : `${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return String(value);
    return new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(date);
  }

  function toOption(value) {
    if (typeof value === "string") return { value, label: value };
    return {
      value: String(value?.name || value?.label || value?.id || ""),
      label: String(value?.name || value?.label || value?.id || ""),
      hint: String(value?.description || ""),
    };
  }

  function fallbackSteps() {
    const options = state.options?.options || {};
    return [
      {
        key: "department",
        number: 1,
        shortLabel: "Role",
        question: "Which department or team is this related to?",
        help: "Choose the department most connected to the SOP you need.",
        options: (options.departments || []).map(toOption),
      },
      {
        key: "task",
        number: 2,
        shortLabel: "Need",
        question: "What do you need?",
        help: "Choose the task or process closest to your work.",
        options: guidedNeedOptions,
      },
      {
        key: "tool",
        number: 3,
        shortLabel: "Tool",
        question: "Which system or tool are you using?",
        help: "Pick the platform, system, or tool involved in the task.",
        options: (options.tools || []).map(toOption),
      },
      {
        key: "category",
        number: 4,
        shortLabel: "Category",
        question: "Which SOP category best fits?",
        help: "These categories come from published backend SOP records.",
        options: (options.categories || []).map(toOption),
      },
      {
        key: "userRole",
        number: 5,
        shortLabel: "Audience",
        question: "Which user role is this for?",
        help: "Use this only when the SOP depends on a specific audience or role.",
        options: (options.roles || []).map(toOption),
      },
    ];
  }

  function buildSteps() {
    const definitions =
      Array.isArray(state.options?.steps) && state.options.steps.length
        ? state.options.steps.map((step) => ({
            ...step,
            options: (step.options || []).map(toOption),
          }))
        : fallbackSteps();

    const userDepartment = String(state.options?.user?.department || "").trim();
    if (userDepartment && !state.filters.department) {
      const match = definitions[0].options.find((option) => option.label.toLowerCase() === userDepartment.toLowerCase());
      if (match) state.filters.department = match.value;
    }

    definitions.forEach((step) => {
      if (step.preselected && !state.filters[step.key]) state.filters[step.key] = step.preselected;
    });

    state.steps = definitions.filter((step) => {
      if (!step.options.length) return false;
      if (step.locked) return false;
      if (step.options.length === 1) {
        state.filters[step.key] = step.options[0].value;
        return false;
      }
      return true;
    });
  }

  function currentStep() {
    return state.steps[state.stepIndex] || null;
  }

  function narrowCategoryOptions(options) {
    const selectedCategory = state.filters.category;
    const matchedCategories = Array.from(
      new Set((state.lastResults || []).map((sop) => String(sop.category || "").trim()).filter(Boolean)),
    );
    if (!matchedCategories.length) return options.slice(0, 10);

    const matchedSet = new Set(matchedCategories.map((category) => category.toLowerCase()));
    const narrowed = options.filter((option) => matchedSet.has(String(option.value || option.label || "").toLowerCase()));
    if (selectedCategory && !narrowed.some((option) => option.value === selectedCategory)) {
      const selected = options.find((option) => option.value === selectedCategory);
      if (selected) narrowed.unshift(selected);
    }
    return (narrowed.length ? narrowed : options).slice(0, 10);
  }

  function visibleStepOptions(step) {
    if (step.key === "category") return narrowCategoryOptions(step.options || []);
    return step.options || [];
  }

  function renderQuestion() {
    const step = currentStep();
    if (!step) {
      renderNoOptions();
      return;
    }

    if (questionPanel) questionPanel.hidden = false;
    if (questionEl) questionEl.textContent = step.question;
    if (helpEl) helpEl.textContent = step.help;
    if (countEl) countEl.textContent = `Step ${state.stepIndex + 1} of ${state.steps.length}`;
    if (progressEl) progressEl.style.width = `${((state.stepIndex + 1) / Math.max(state.steps.length, 1)) * 100}%`;
    if (backButton instanceof HTMLButtonElement) {
      backButton.hidden = state.stepIndex === 0;
      backButton.disabled = state.stepIndex === 0;
    }
    if (restartButton instanceof HTMLButtonElement) {
      restartButton.hidden = state.stepIndex === 0;
      restartButton.disabled = state.stepIndex === 0;
    }

    if (choicesEl) {
      const options = visibleStepOptions(step);
      choicesEl.dataset.stepKey = step.key;
      choicesEl.innerHTML = options
        .map((option) => {
          const active = state.filters[step.key] === option.value;
          return `
            <button
              class="ticket-guide-choice guided-workflow__choice${active ? " is-active" : ""}"
              type="button"
              data-key="${escapeHtml(step.key)}"
              data-value="${escapeHtml(option.value)}"
              aria-pressed="${active ? "true" : "false"}"
            >
              <span class="ticket-guide-choice__icon guided-workflow__choice-mark" aria-hidden="true"></span>
              <span>
                <strong>${escapeHtml(option.label)}</strong>
                ${option.hint ? `<small>${escapeHtml(option.hint)}</small>` : ""}
              </span>
            </button>
          `;
        })
        .join("");
    }

    window.requestAnimationFrame(() => {
      if (mainEl instanceof HTMLElement && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        mainEl.scrollIntoView({ block: "nearest", inline: "nearest", behavior: "smooth" });
      }
      questionEl?.focus?.({ preventScroll: true });
    });
  }

  function renderNoOptions() {
    if (questionPanel) questionPanel.hidden = true;
    setStatus("No Guided Finder filter options are available from the backend yet.", "ready");
  }

  function selectedQueryParams() {
    const params = new URLSearchParams();
    Object.entries(state.filters).forEach(([key, value]) => {
      if (value) params.set(key, String(value));
    });
    if (state.description) params.set("q", state.description);
    return params;
  }

  function renderEmptyState(message = "No published SOP matched those answers.") {
    const params = selectedQueryParams();
    const query = params.toString();
    const requestUrl = `/submit/${query ? `?${query}` : ""}`;
    const searchUrl = `/search/${query ? `?${query}` : ""}`;
    if (!resultsEl) return;
    resultsEl.innerHTML = `
      <div class="ticket-guide-empty guided-workflow__no-results">
        <h2>No exact match found</h2>
        <p>${escapeHtml(message)}</p>
        <div class="ticket-guide-actions">
          <button class="button button--secondary" type="button" id="guided-finder-change">Change answers</button>
          <a class="button button--secondary" href="${escapeHtml(searchUrl)}">Search all SOPs</a>
          <button class="button button--secondary" type="button" id="guided-finder-ask-hub">Ask Hub</button>
          <a class="button button--primary" href="${escapeHtml(requestUrl)}">Request an SOP</a>
          <a class="button button--secondary" href="/submit/?type=issue">Report missing content</a>
        </div>
      </div>
    `;
    document.getElementById("guided-finder-change")?.addEventListener("click", () => {
      if (questionPanel?.hidden) startGuidedFlow();
      renderQuestion();
    });
    document.getElementById("guided-finder-ask-hub")?.addEventListener("click", () => {
      document.querySelector(".ai-chatbot__toggle")?.click();
    });
  }

  function renderResults(payload) {
    const results = payload?.results || [];
    state.lastResults = results;
    if (!results.length) {
      renderEmptyState(payload?.nextQuestion || "Try changing a department, category, system, or task.");
      return;
    }

    const params = selectedQueryParams();
    const query = params.toString();
    if (!resultsEl) return;
    resultsEl.innerHTML = `
      <div class="guided-workflow__results-heading">
        <p class="eyebrow">${escapeHtml(payload?.model || "Guided Finder")}</p>
        <h2>${results.length === 1 ? "Best matching SOP" : "Best matching SOPs"}</h2>
        <p>${escapeHtml(payload?.sourcePolicy || "Only approved backend SOP records are shown.")}</p>
      </div>
      <div class="ticket-guide-sop-matches guided-workflow__match-list">
        ${results
          .map(
            (sop, index) => `
              <article class="ticket-guide-sop-match guided-workflow__match${index === 0 ? " guided-workflow__match--best" : ""}">
                <span>${escapeHtml(sop.department || "All departments")} · ${escapeHtml(sop.category || "Uncategorized")}</span>
                ${index === 0 ? `<em>Strongest match</em>` : ""}
                <h3><a href="${escapeHtml(sop.href || "#")}">${escapeHtml(sop.title || "Untitled SOP")}</a></h3>
                <p>${escapeHtml(sop.summary || "No description available.")}</p>
                <dl>
                  <div>
                    <dt>System/tool</dt>
                    <dd>${escapeHtml((sop.tools || []).join(", ") || "Not specified")}</dd>
                  </div>
                  <div>
                    <dt>Updated</dt>
                    <dd>${escapeHtml(formatDate(sop.lastReviewed || sop.updatedAt))}</dd>
                  </div>
                </dl>
                <strong>${escapeHtml(sop.relevance || "Matches your Guided Finder answers.")}</strong>
                <a class="button button--primary" href="${escapeHtml(sop.href || "#")}">Open SOP</a>
              </article>
            `,
          )
          .join("")}
      </div>
      ${payload?.total > results.length ? `<a class="button button--secondary" href="/search/${query ? `?${escapeHtml(query)}` : ""}">View all matching SOPs</a>` : ""}
      <button class="button button--secondary" type="button" id="guided-finder-change-results">Change answers</button>
    `;
    document.getElementById("guided-finder-change-results")?.addEventListener("click", () => {
      if (questionPanel) questionPanel.hidden = false;
      renderQuestion();
    });
  }

  async function searchGuidedFinder() {
    const requestId = ++state.requestId;
    state.description = String(descriptionEl?.value || "").trim();
    setStatus("Searching approved backend SOPs...", "loading");

    try {
      const response = await fetch("/api/guided-finder", {
        method: "POST",
        headers: { "content-type": "application/json", accept: "application/json" },
        cache: "no-store",
        body: JSON.stringify({ description: state.description, filters: state.filters }),
      });
      const payload = await response.json();
      if (requestId !== state.requestId) return;
      if (!response.ok || !payload.success) {
        throw new Error(payload.error?.message || "Guided Finder could not load matching SOPs.");
      }
      setStatus(
        payload.data.results?.length
          ? `${payload.data.results.length} matching SOP${payload.data.results.length === 1 ? "" : "s"} found.`
          : "No exact match found. Try changing the answers or request a missing SOP.",
        payload.data.results?.length ? "ready" : "error",
      );
      renderResults(payload.data);
      if (currentStep()?.key === "category") renderQuestion();
    } catch (error) {
      if (requestId !== state.requestId) return;
      setStatus(error.message || "Guided Finder could not load matching SOPs.", "error");
      renderEmptyState("The finder could not complete that search. You can still search all SOPs or submit a request.");
    }
  }

  async function loadOptions() {
    const requestId = ++state.requestId;
    setStatus("Loading live Guided Finder options...", "loading");
    try {
      const response = await fetch("/api/guided-finder", {
        method: "POST",
        headers: { "content-type": "application/json", accept: "application/json" },
        cache: "no-store",
        body: JSON.stringify({ mode: "options" }),
      });
      const payload = await response.json();
      if (requestId !== state.requestId) return;
      if (!response.ok || !payload.success) {
        throw new Error(payload.error?.message || "Guided Finder options could not be loaded.");
      }
      state.options = payload.data;
      state.filters = {};
      state.stepIndex = 0;
      buildSteps();
      setStatus("Guided Finder ready. Results use live backend records.", "ready");
      startGuidedFlow();
    } catch (error) {
      if (requestId !== state.requestId) return;
      state.options = null;
      state.steps = [];
      setStatus(error.message || "Guided Finder options could not be loaded.", "error");
    }
  }

  function startGuidedFlow() {
    if (!state.steps.length) {
      renderNoOptions();
      return;
    }
    state.stepIndex = 0;
    renderQuestion();
  }

  function resetFinder({ preserveDescription = false } = {}) {
    state.filters = {};
    state.stepIndex = 0;
    state.lastResults = [];
    if (!preserveDescription && descriptionEl) descriptionEl.value = "";
    if (questionPanel) questionPanel.hidden = true;
    if (resultsEl) {
      resultsEl.innerHTML = `
        <div class="ticket-guide-empty">
          <h2>Ready when you are</h2>
          <p>Answer the guided questions. Results will appear here as the finder narrows the backend SOP records.</p>
        </div>
      `;
    }
  }

  choicesEl?.addEventListener("click", (event) => {
    const button = event.target.closest("[data-key][data-value]");
    if (!button) return;
    state.filters[button.dataset.key] = button.dataset.value;
    if (state.stepIndex < state.steps.length - 1) {
      state.stepIndex += 1;
    }
    renderQuestion();
    searchGuidedFinder();
  });

  backButton?.addEventListener("click", () => {
    state.stepIndex = Math.max(0, state.stepIndex - 1);
    renderQuestion();
    searchGuidedFinder();
  });

  restartButton?.addEventListener("click", () => {
    resetFinder({ preserveDescription: true });
    startGuidedFlow();
  });

  window.addEventListener(ROLE_CONTEXT_EVENT, async () => {
    resetFinder();
    await loadOptions();
  });

  window.addEventListener("storage", async (event) => {
    if (!event.key || event.key.startsWith("sop-active-")) {
      resetFinder();
      await loadOptions();
    }
  });

  loadOptions();
</script>
