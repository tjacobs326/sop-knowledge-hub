---
import AppIcon from "./AppIcon.astro";

interface FinderAnswer {
  label: string;
  next?: string;
  results?: string[];
}

interface FinderNode {
  question: string;
  answers: FinderAnswer[];
}

interface FinderData {
  startNode: string;
  nodes: Record<string, FinderNode>;
}

interface SopRecord {
  id: string;
  title: string;
  purpose: string;
  category: string;
  tags: string[];
  tools: string[];
  owner: string;
  lastUpdated: string;
  reviewDate: string;
  status: string;
  url: string;
}

interface Props {
  finderData: FinderData;
  sops: SopRecord[];
}

const { finderData, sops } = Astro.props;
---

<section class="guided-finder" aria-labelledby="finder-heading">
  <div class="finder-hero">
    <div class="finder-hero__content">
      <p class="eyebrow">Guided Finder</p>
      <h1 id="finder-heading">What are you trying to do?</h1>
      <p>Tell us what you need and we'll help you find the right SOP, template, or guide.</p>
    </div>
    <div class="finder-hero__art" aria-hidden="true">
      <span class="finder-spark finder-spark--one"></span>
      <span class="finder-spark finder-spark--two"></span>
      <div class="finder-art-card finder-art-card--doc">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div class="finder-compass">
        <span class="finder-compass__ring"></span>
        <span class="finder-compass__tick finder-compass__tick--north"></span>
        <span class="finder-compass__tick finder-compass__tick--east"></span>
        <span class="finder-compass__tick finder-compass__tick--south"></span>
        <span class="finder-compass__tick finder-compass__tick--west"></span>
        <span class="finder-compass__needle"></span>
        <span class="finder-compass__pin"></span>
      </div>
      <div class="finder-art-card finder-art-card--checklist">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </div>

  <div class="finder-panel">
    <label class="finder-search" for="finder-search-input">
      <span>Search or describe what you need help with</span>
      <span class="finder-search__box">
        <span aria-hidden="true"><AppIcon name="search" /></span>
        <input
          id="finder-search-input"
          type="search"
          placeholder="Example: Submit a ticket, create a course, approve a request..."
          autocomplete="off"
        />
      </span>
    </label>
    <h2 id="finder-question" class="sr-only"></h2>
    <div id="finder-answers" class="finder-answers"></div>
    <div id="finder-results" class="finder-results" aria-live="polite"></div>
    <button class="button button--secondary" id="finder-restart" type="button" hidden>
      Restart Finder
    </button>
  </div>
</section>

<script is:inline define:vars={{ finderData, sopRecords: sops }}>
  const questionEl = document.getElementById("finder-question");
  const answersEl = document.getElementById("finder-answers");
  const resultsEl = document.getElementById("finder-results");
  const restartButton = document.getElementById("finder-restart");
  const finderSearchInput = document.getElementById("finder-search-input");

  const answerIcons = [
    {
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="M5 9.25V6.5A1.5 1.5 0 0 1 6.5 5h11A1.5 1.5 0 0 1 19 6.5v2.75a2.75 2.75 0 0 0 0 5.5v2.75a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 5 17.5v-2.75a2.75 2.75 0 0 0 0-5.5Z"/><path d="M9.25 8.25h5.5M9.25 12h5.5M9.25 15.75h3.5"/></svg>',
      tone: "ticket",
    },
    {
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="M5.5 5.75h5.25A2.25 2.25 0 0 1 13 8v10.25a2.25 2.25 0 0 0-2.25-2.25H5.5V5.75Z"/><path d="M18.5 5.75h-5.25A2.25 2.25 0 0 0 11 8v10.25a2.25 2.25 0 0 1 2.25-2.25h5.25V5.75Z"/></svg>',
      tone: "course",
    },
    {
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="m7 12 3.25 3.25L17.5 8"/><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"/></svg>',
      tone: "qa",
    },
    {
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="M12 3.75 13.9 9l5.35 1.9-5.35 1.9L12 18.25l-1.9-5.45-5.35-1.9L10.1 9 12 3.75Z"/><path d="m18.5 16 .65 1.85L21 18.5l-1.85.65L18.5 21l-.65-1.85L16 18.5l1.85-.65.65-1.85Z"/></svg>',
      tone: "ai",
    },
    {
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="M14.5 5.5a4.75 4.75 0 0 0 4 6.85l-6.15 6.15a2.75 2.75 0 0 1-3.9-3.9l6.15-6.15a4.75 4.75 0 0 0-.1-2.95Z"/><path d="m7.75 16.25 2 2"/></svg>',
      tone: "fix",
    },
    {
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="M7 4.5h6.25L17 8.25V19.5H7V4.5Z"/><path d="M13 4.75V8.5h3.75"/><path d="M9.75 12.25h4.5M9.75 15.25h4.5"/></svg>',
      tone: "template",
    },
    {
      icon: '<svg viewBox="0 0 24 24" focusable="false"><path d="M6.75 12h.01M12 12h.01M17.25 12h.01"/></svg>',
      tone: "other",
    },
  ];

  let currentNodeId = finderData.startNode;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function renderNode(nodeId) {
    const node = finderData.nodes[nodeId];
    if (!node || !questionEl || !answersEl || !resultsEl || !restartButton) return;

    currentNodeId = nodeId;
    questionEl.textContent = node.question;
    answersEl.innerHTML = node.answers
      .map(
        (answer, index) => {
          const icon = answerIcons[index % answerIcons.length];
          return `
            <button class="finder-answer finder-answer--${icon.tone}" type="button" data-answer-index="${index}">
              <span class="finder-answer__icon" aria-hidden="true">${icon.icon}</span>
              <span class="finder-answer__label">${escapeHtml(answer.label)}</span>
            </button>
          `;
        },
      )
      .join("");
    resultsEl.innerHTML = "";
    restartButton.hidden = nodeId === finderData.startNode;
  }

  function renderResults(ids) {
    if (!questionEl || !answersEl || !resultsEl || !restartButton) return;

    const records = ids
      .map((id) => sopRecords.find((record) => record.id === id))
      .filter(Boolean);

    questionEl.textContent = "Recommended SOPs";
    answersEl.innerHTML = "";
    restartButton.hidden = false;
    resultsEl.innerHTML =
      records.length > 0
        ? records
            .map(
              (record) => `
              <article class="sop-card">
                <div class="sop-card__topline">
                  <span>${escapeHtml(record.category)}</span>
                  <span class="status-badge">${escapeHtml(record.status)}</span>
                </div>
                <h3><a href="${record.url}">${escapeHtml(record.title)}</a></h3>
                <p>${escapeHtml(record.purpose)}</p>
                <p class="sop-card__tools"><strong>Tools:</strong> ${escapeHtml(
                  record.tools.join(", "),
                )}</p>
                <ul class="tag-list" aria-label="Tags">
                  ${record.tags.map((tag) => `<li>${escapeHtml(tag)}</li>`).join("")}
                </ul>
              </article>
            `,
            )
            .join("")
        : `<p>No matching SOPs are available yet.</p>`;
  }

  answersEl?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const answerButton = target.closest("[data-answer-index]");
    if (!(answerButton instanceof HTMLElement)) return;

    const node = finderData.nodes[currentNodeId];
    const answer = node.answers[Number(answerButton.dataset.answerIndex)];

    if (answer.next) {
      renderNode(answer.next);
      return;
    }

    renderResults(answer.results ?? []);
  });

  restartButton?.addEventListener("click", () => renderNode(finderData.startNode));

  finderSearchInput?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement) || !answersEl) return;

    const query = target.value.trim().toLowerCase();
    const buttons = Array.from(answersEl.querySelectorAll("[data-answer-index]"));
    buttons.forEach((button) => {
      if (!(button instanceof HTMLElement)) return;
      const text = button.textContent?.toLowerCase() || "";
      button.hidden = Boolean(query) && !text.includes(query);
    });
  });

  renderNode(finderData.startNode);
</script>
