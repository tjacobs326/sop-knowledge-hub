---
import AppIcon from "./AppIcon.astro";
import AppIllustration from "./AppIllustration.astro";

const submissionTypes = [
  "Request a new SOP",
  "Suggest an update",
  "Submit a department process",
  "Share a draft SOP for review",
];

const priorities = ["Low", "Medium", "High", "Urgent"];
const frequencies = ["Daily", "Weekly", "Monthly", "Term-based", "Occasionally", "One-time", "Unsure"];
---

<section class="submit-request-page" aria-labelledby="submit-heading">
  <div class="submit-request-hero">
    <div class="submit-request-hero__content">
      <p class="eyebrow">Outside Department Intake</p>
      <h1 id="submit-heading">Submit an SOP Request</h1>
      <p>
        Use this form to request a new SOP, suggest an update, submit a department process, or
        share a draft SOP for review.
      </p>
    </div>
    <div class="submit-request-hero__visual" aria-hidden="true">
      <AppIllustration name="request" size="hero" />
    </div>
  </div>

  <div class="submit-benefit-grid" aria-label="Submit request benefits">
    <div class="submit-benefit">
      <span class="submit-benefit__icon submit-benefit__icon--blue" aria-hidden="true">
        <AppIcon name="create" />
      </span>
      <span>
        <strong>Request or Suggest</strong>
        <small>Request a new SOP or suggest an update to existing content.</small>
      </span>
    </div>
    <div class="submit-benefit">
      <span class="submit-benefit__icon submit-benefit__icon--green" aria-hidden="true">
        <AppIcon name="users" />
      </span>
      <span>
        <strong>Share & Collaborate</strong>
        <small>Submit a draft or process for review and collaboration.</small>
      </span>
    </div>
    <div class="submit-benefit">
      <span class="submit-benefit__icon submit-benefit__icon--orange" aria-hidden="true">
        <AppIcon name="analytics" />
      </span>
      <span>
        <strong>Track Progress</strong>
        <small>We'll review your request and keep you updated.</small>
      </span>
    </div>
  </div>

  <form class="form-grid request-form-card" id="request-form" novalidate>
    <div class="form-section-title form-section-title--with-icon field--full">
      <span class="form-section-title__icon form-section-title__icon--orange" aria-hidden="true">
        <AppIcon name="drafts" />
      </span>
      <span>
        <h2>Submission Type</h2>
        <small>What would you like to submit?</small>
      </span>
    </div>
    <div class="field field--full">
      <label class="sr-only" for="submission-type">Submission Type</label>
      <select id="submission-type" name="submissionType" required>
        <option value="">Select submission type</option>
        {submissionTypes.map((type) => <option value={type}>{type}</option>)}
      </select>
    </div>

    <div class="form-section-title form-section-title--with-icon field--full">
      <span class="form-section-title__icon form-section-title__icon--green" aria-hidden="true">
        <AppIcon name="operations" />
      </span>
      <span>
        <h2>Department Information</h2>
        <small>Tell us who you are and which department you're submitting on behalf of.</small>
      </span>
    </div>
    <div class="field">
      <label for="department">Department name <span aria-hidden="true">*</span></label>
      <input id="department" name="department" type="text" placeholder="Enter department name" required />
    </div>
    <div class="field">
      <label for="submitted-by">Submitted by <span aria-hidden="true">*</span></label>
      <input id="submitted-by" name="submittedBy" type="text" placeholder="Your full name" required />
    </div>
    <div class="field">
      <label for="submitter-email">Submitter email <span aria-hidden="true">*</span></label>
      <input id="submitter-email" name="submitterEmail" type="email" placeholder="you@example.com" required />
    </div>
    <div class="field">
      <label for="role-title">Role or title</label>
      <input id="role-title" name="submitterRole" type="text" placeholder="Your role or title" />
    </div>
    <div class="field field--full">
      <label for="contact-method">Best contact method</label>
      <input id="contact-method" name="bestContactMethod" type="text" />
    </div>

    <div class="form-section-title form-section-title--with-icon field--full">
      <span class="form-section-title__icon form-section-title__icon--blue" aria-hidden="true">
        <AppIcon name="finder" />
      </span>
      <span>
        <h2>Process Information</h2>
        <small>Describe the SOP, audience, tools, timing, and priority.</small>
      </span>
    </div>
    <div class="field">
      <label for="requested-title">Requested SOP title</label>
      <input id="requested-title" name="title" type="text" required />
    </div>
    <div class="field">
      <label for="tool-system">Related system or tool</label>
      <input id="tool-system" name="toolOrSystem" type="text" />
    </div>
    <div class="field">
      <label for="request-category">Category</label>
      <select id="request-category" name="category" required>
        <option value="">Loading categories...</option>
      </select>
    </div>
    <div class="field">
      <label for="audience">Who uses this process?</label>
      <input id="audience" name="audience" type="text" required />
    </div>
    <div class="field field--full">
      <label for="business-need">Why is this SOP needed?</label>
      <textarea id="business-need" name="businessNeed" rows="3" required></textarea>
    </div>
    <div class="field">
      <label for="frequency">How often is this process used?</label>
      <select id="frequency" name="frequency">
        <option value="">Select frequency</option>
        {frequencies.map((frequency) => <option value={frequency}>{frequency}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="priority">Priority</label>
      <select id="priority" name="priority" required>
        <option value="">Select priority</option>
        {priorities.map((priority) => <option value={priority}>{priority}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="desired-date">Desired completion date</label>
      <input id="desired-date" name="desiredCompletionDate" type="date" />
    </div>

    <div class="form-section-title form-section-title--with-icon field--full">
      <span class="form-section-title__icon form-section-title__icon--purple" aria-hidden="true">
        <AppIcon name="document" />
      </span>
      <span>
        <h2>SOP Details or Draft Content</h2>
        <small>Add the process purpose, steps, attachments, and supporting notes.</small>
      </span>
    </div>
    <div class="field field--full">
      <label for="process-purpose">Purpose of the process</label>
      <textarea id="process-purpose" name="purpose" rows="3"></textarea>
    </div>
    <div class="field field--full">
      <label for="before-begin">Before you begin</label>
      <textarea id="before-begin" name="beforeYouBegin" rows="2"></textarea>
    </div>
    <div class="field field--full">
      <label for="process-steps">Procedure or process steps</label>
      <textarea id="process-steps" name="procedureSteps" rows="5"></textarea>
    </div>
    <div class="field field--full">
      <label for="known-issues">Known issues or exceptions</label>
      <textarea id="known-issues" name="knownIssues" rows="3"></textarea>
    </div>
    <div class="field">
      <label for="related-resources">Links to related resources</label>
      <input id="related-resources" name="relatedResources" type="text" />
    </div>
    <div class="field">
      <label for="documentation-location">Existing documentation location</label>
      <input id="documentation-location" name="documentationLocation" type="text" />
    </div>
    <div class="field field--full">
      <label for="attachments-file">Screenshots, videos, or attachments</label>
      <div class="screenshot-input" data-attachment-input>
        <textarea id="attachments" name="screenshots" hidden></textarea>
        <input id="attachments-file" name="attachmentFiles" type="file" accept="image/*,video/*,.pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt" multiple />
        <p class="field-help" id="attachments-help">
          Upload files or videos from your computer, or paste a screenshot into the box below.
        </p>
        <div
          class="screenshot-paste-target"
          tabindex="0"
          data-attachment-paste
          aria-describedby="attachments-help"
        >
          Paste a screenshot here or upload files and videos above.
        </div>
        <div class="attachment-list" data-attachment-list hidden></div>
      </div>
    </div>
    <div class="field field--full">
      <label for="additional-notes">Additional notes</label>
      <textarea id="additional-notes" name="additionalNotes" rows="3"></textarea>
    </div>
    <div class="form-actions form-actions--request-intake field--full">
      <button class="button button--primary" id="review-request" type="submit">Review</button>
      <button class="button button--ghost" id="cancel-request" type="button">Cancel</button>
    </div>
    <div class="form-errors field--full" id="request-errors" role="alert" hidden></div>
    <div class="confirmation field--full" id="request-confirmation" role="status" hidden></div>
  </form>

  <section class="request-review-panel" id="request-review-panel" aria-labelledby="request-review-heading" hidden>
    <div class="dashboard-panel request-review-panel__card">
      <div class="dashboard-panel__heading">
        <div>
          <p class="eyebrow">Review before submitting</p>
          <h2 id="request-review-heading">Confirm SOP request details</h2>
        </div>
      </div>
      <p class="request-review-panel__intro">
        Review the information below. Nothing has been submitted yet.
      </p>
      <div class="request-review-summary" id="request-review-summary"></div>
      <div class="form-actions form-actions--request-review">
        <button class="button button--secondary" id="edit-request" type="button">Back to Edit</button>
        <button class="button button--primary" id="confirm-request-submit" type="button">Submit SOP Request</button>
        <button class="button button--ghost" id="cancel-request-review" type="button">Cancel</button>
      </div>
    </div>
  </section>
</section>

<script is:inline>
  const form = document.getElementById("request-form");
  const errorsEl = document.getElementById("request-errors");
  const confirmationEl = document.getElementById("request-confirmation");
  const reviewPanel = document.getElementById("request-review-panel");
  const reviewSummary = document.getElementById("request-review-summary");
  const editRequestButton = document.getElementById("edit-request");
  const confirmSubmitButton = document.getElementById("confirm-request-submit");
  const cancelRequestButton = document.getElementById("cancel-request");
  const cancelRequestReviewButton = document.getElementById("cancel-request-review");
  const attachmentsInput = document.getElementById("attachments");
  const attachmentFileInput = document.getElementById("attachments-file");
  const attachmentList = document.querySelector("[data-attachment-list]");
  const attachmentPasteTarget = document.querySelector("[data-attachment-paste]");
  const categorySelect = document.getElementById("request-category");

  const attachments = [];
  let pendingSubmission = null;
  let hasUnsavedChanges = false;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  const splitList = (value) =>
    String(value || "")
      .split(/[\n,]+/)
      .map((item) => item.trim())
      .filter(Boolean);

  const splitAttachmentList = (value) =>
    String(value || "")
      .split(/\n+/)
      .map((item) => item.trim())
      .filter(Boolean);

  function getField(name) {
    const element = form?.querySelector(`[name="${name}"]`);
    return element instanceof HTMLInputElement ||
      element instanceof HTMLSelectElement ||
      element instanceof HTMLTextAreaElement
      ? element.value.trim()
      : "";
  }

  function formatFileSize(size) {
    if (!Number.isFinite(size)) return "";
    if (size < 1024) return `${size} B`;
    if (size < 1024 * 1024) return `${Math.round(size / 1024)} KB`;
    return `${(size / (1024 * 1024)).toFixed(1)} MB`;
  }

  function readFileAsDataUrl(file) {
    return new Promise((resolve) => {
      const reader = new FileReader();
      reader.addEventListener("load", () => {
        resolve(typeof reader.result === "string" ? reader.result : "");
      });
      reader.readAsDataURL(file);
    });
  }

  async function uploadMediaFile(file, purpose = "Request Attachment") {
    const formData = new FormData();
    formData.append("file", file);
    formData.append("purpose", purpose);
    formData.append("entityType", "request");

    try {
      const response = await fetch("/api/media/", {
        method: "POST",
        body: formData,
      });
      const data = await response.json();
      const uploaded = data.uploaded?.[0];
      if (response.ok && uploaded?.url) {
        return uploaded.url;
      }
    } catch {
      // Static local previews do not have the Cloudflare media API.
    }

    return readFileAsDataUrl(file);
  }

  function syncAttachmentsField() {
    if (attachmentsInput instanceof HTMLTextAreaElement) {
      attachmentsInput.value = attachments
        .map((attachment) => attachment.value || attachment.label)
        .filter(Boolean)
        .join("\n");
    }
  }

  function renderAttachments() {
    if (!(attachmentList instanceof HTMLElement)) return;

    syncAttachmentsField();
    attachmentList.hidden = attachments.length === 0;
    attachmentList.innerHTML = attachments
      .map((attachment, index) => {
        const image =
          attachment.kind === "image"
            ? `<img src="${escapeHtml(attachment.value)}" alt="${escapeHtml(attachment.label)} preview" />`
            : "";
        const video =
          attachment.kind === "video"
            ? `<video controls src="${escapeHtml(attachment.value)}"></video>`
            : "";
        return `
          <figure class="attachment-preview">
            ${image}
            ${video}
            <figcaption>
              <span>${escapeHtml(attachment.label)}</span>
              <button class="button button--ghost" type="button" data-remove-attachment="${index}">
                Remove
              </button>
            </figcaption>
          </figure>
        `;
      })
      .join("");

    if (attachmentPasteTarget instanceof HTMLElement) {
      attachmentPasteTarget.textContent =
        attachments.length > 0
          ? "Attachment added. Paste another screenshot here or upload more files or videos."
          : "Paste a screenshot here or upload files and videos above.";
    }
  }

  function addAttachment(attachment) {
    attachments.push(attachment);
    renderAttachments();
    hasUnsavedChanges = true;
    hideReviewStep();
    if (errorsEl) {
      errorsEl.hidden = true;
      errorsEl.innerHTML = "";
    }
  }

  async function readAttachmentFile(file) {
    if (file.type.startsWith("image/")) {
      const value = await uploadMediaFile(file, "Request Attachment");
      addAttachment({
        kind: "image",
        label: file.name || "Pasted screenshot",
        value,
      });
      return;
    }

    if (file.type.startsWith("video/")) {
      const value = await uploadMediaFile(file, "Request Attachment");
      addAttachment({
        kind: "video",
        label: `${file.name || "Uploaded video"} (${formatFileSize(file.size)})`,
        value,
      });
      return;
    }

    addAttachment({
      kind: "file",
      label: `${file.name} (${file.type || "file"}, ${formatFileSize(file.size)})`,
      value: `${file.name} (${file.type || "file"}, ${formatFileSize(file.size)})`,
    });
  }

  function validateSubmission(submission) {
    const required = [
      ["submissionType", "Submission Type is required."],
      ["department", "Department name is required."],
      ["submittedBy", "Submitted by is required."],
      ["submitterEmail", "Submitter email is required."],
      ["title", "Requested SOP title is required."],
      ["category", "Category is required."],
      ["audience", "Who uses this process is required."],
      ["businessNeed", "Why this SOP is needed is required."],
      ["priority", "Priority is required."],
    ];

    const errors = required
      .filter(([field]) => !submission[field])
      .map(([, message]) => message);

    if (submission.submitterEmail && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(submission.submitterEmail)) {
      errors.push("Enter a valid submitter email.");
    }

    errorsEl.hidden = errors.length === 0;
    errorsEl.innerHTML = errors.map((error) => `<p>${escapeHtml(error)}</p>`).join("");

    return errors.length === 0;
  }

  function displayValue(value) {
    if (Array.isArray(value)) return value.length ? value.join(", ") : "Not provided";
    return value ? String(value) : "Not provided";
  }

  function renderReviewSummary(submission) {
    if (!(reviewSummary instanceof HTMLElement)) return;
    const groups = [
      {
        title: "Submission",
        rows: [
          ["Submission type", submission.submissionType],
          ["Requested SOP title", submission.title],
          ["Priority", submission.priority],
          ["Desired completion", submission.desiredCompletionDate],
        ],
      },
      {
        title: "Department and contact",
        rows: [
          ["Department", submission.department],
          ["Submitted by", submission.submittedBy],
          ["Email", submission.submitterEmail],
          ["Role or title", submission.submitterRole],
          ["Best contact", submission.bestContactMethod],
        ],
      },
      {
        title: "Process details",
        rows: [
          ["Category", submission.category],
          ["System or tool", submission.toolOrSystem],
          ["Audience", submission.audience],
          ["Business need", submission.businessNeed],
          ["Frequency", submission.frequency],
          ["Purpose", submission.purpose],
          ["Before you begin", submission.beforeYouBegin],
          ["Procedure steps", submission.procedureSteps],
          ["Known issues", submission.knownIssues],
          ["Related resources", submission.relatedResources],
          ["Documentation location", submission.documentationLocation],
          ["Attachments", submission.screenshots],
          ["Additional notes", submission.additionalNotes],
        ],
      },
    ];
    reviewSummary.innerHTML = groups
      .map(
        (group) => `
          <section class="request-review-summary__group">
            <h3>${escapeHtml(group.title)}</h3>
            <dl>
              ${group.rows
                .map(
                  ([label, value]) => `
                    <div>
                      <dt>${escapeHtml(label)}</dt>
                      <dd>${escapeHtml(displayValue(value))}</dd>
                    </div>
                  `,
                )
                .join("")}
            </dl>
          </section>
        `,
      )
      .join("");
  }

  function showReviewStep(submission) {
    pendingSubmission = submission;
    renderReviewSummary(submission);
    if (reviewPanel instanceof HTMLElement) reviewPanel.hidden = false;
    if (confirmationEl instanceof HTMLElement) confirmationEl.hidden = true;
    reviewPanel?.scrollIntoView({ behavior: "smooth", block: "start" });
    editRequestButton?.focus({ preventScroll: true });
  }

  function hideReviewStep() {
    pendingSubmission = null;
    if (reviewPanel instanceof HTMLElement) reviewPanel.hidden = true;
  }

  function cancelRequestFlow() {
    if (hasUnsavedChanges && !window.confirm("Cancel this SOP request without submitting?")) return;
    window.location.href = "/";
  }

  function buildSubmission() {
    const now = new Date().toISOString().slice(0, 10);
    const selectedCategory =
      categorySelect instanceof HTMLSelectElement
        ? categorySelect.selectedOptions[0]
        : null;
    return {
      id: `sub-${Date.now()}`,
      source: "Outside Department Submission",
      submissionType: getField("submissionType"),
      title: getField("title"),
      department: getField("department"),
      submittedBy: getField("submittedBy"),
      submitterEmail: getField("submitterEmail"),
      submitterRole: getField("submitterRole"),
      bestContactMethod: getField("bestContactMethod"),
      categoryId: getField("category"),
      category: selectedCategory?.dataset.categoryName || selectedCategory?.textContent?.trim() || "",
      toolOrSystem: getField("toolOrSystem"),
      audience: getField("audience"),
      businessNeed: getField("businessNeed"),
      frequency: getField("frequency"),
      priority: getField("priority"),
      desiredCompletionDate: getField("desiredCompletionDate"),
      purpose: getField("purpose"),
      beforeYouBegin: getField("beforeYouBegin"),
      procedureSteps: splitList(getField("procedureSteps")),
      knownIssues: getField("knownIssues"),
      relatedResources: splitList(getField("relatedResources")),
      documentationLocation: getField("documentationLocation"),
      screenshots: splitAttachmentList(getField("screenshots")),
      additionalNotes: getField("additionalNotes"),
      status: "Submitted",
      assignedOwner: "",
      createdDate: now,
      updatedDate: now,
      reviewDate: getField("desiredCompletionDate"),
    };
  }

  async function sendSubmissionToApi(submission) {
    const draftLines = [
      submission.purpose ? `Purpose:\n${submission.purpose}` : "",
      submission.beforeYouBegin ? `Before you begin:\n${submission.beforeYouBegin}` : "",
      submission.procedureSteps?.length ? `Procedure:\n${submission.procedureSteps.join("\n")}` : "",
      submission.knownIssues ? `Known issues:\n${submission.knownIssues}` : "",
      submission.additionalNotes ? `Additional notes:\n${submission.additionalNotes}` : "",
      submission.screenshots?.length ? `Attachments:\n${submission.screenshots.join("\n")}` : "",
    ]
      .filter(Boolean)
      .join("\n\n");

    const response = await fetch("/api/sop-requests", {
      method: "POST",
      headers: {
        "content-type": "application/json",
      },
      body: JSON.stringify({
        requestType: submission.submissionType,
        requestedTitle: submission.title,
        departmentName: submission.department,
        submittedByName: submission.submittedBy,
        submittedByEmail: submission.submitterEmail,
        roleTitle: submission.submitterRole,
        description: submission.businessNeed || submission.purpose || submission.title,
        priority: submission.priority,
        desiredCompletionAt: submission.desiredCompletionDate,
        draftContent: draftLines,
        relatedLinks: submission.relatedResources,
        documentationLocation: submission.documentationLocation,
        categoryId: submission.categoryId,
        category: submission.category,
        toolOrSystem: submission.toolOrSystem,
        audience: submission.audience,
        bestContactMethod: submission.bestContactMethod,
        frequency: submission.frequency,
        requestedSopType: submission.submissionType === "Request a template" ? "Template" : "Process",
        requestNotes: submission.additionalNotes,
      }),
    });

    const data = await response.json().catch(() => ({}));
    if (!response.ok || data?.success === false) {
      const fields = data?.error?.fields || {};
      const fieldMessages = Object.values(fields);
      const message = data?.error?.message || "The request could not be saved to D1.";
      throw new Error([message, ...fieldMessages].join(" "));
    }
    return data?.data?.request;
  }

  async function loadRequestCategories() {
    if (!(categorySelect instanceof HTMLSelectElement)) return;
    try {
      const response = await fetch("/api/categories", { headers: { accept: "application/json" } });
      if (!response.ok) throw new Error("Categories failed to load.");
      const payload = await response.json();
      const categories = payload.categories || payload.data?.categories || [];
      const options = categories
        .filter((category) => Number(category.sopCount || category.count || 0) > 0)
        .sort((a, b) => String(a.name || "").localeCompare(String(b.name || "")))
        .map(
          (category) =>
            `<option value="${escapeHtml(category.id || category.slug || category.name)}" data-category-name="${escapeHtml(
              category.name,
            )}">${escapeHtml(category.name)}</option>`,
        )
        .join("");
      categorySelect.innerHTML = `<option value="">Select category</option>${options}`;
    } catch {
      categorySelect.innerHTML = `<option value="">Categories could not load</option>`;
    }
  }

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const submission = buildSubmission();
    if (!validateSubmission(submission)) return;

    showReviewStep(submission);
  });

  confirmSubmitButton?.addEventListener("click", async () => {
    const submission = pendingSubmission || buildSubmission();
    if (!validateSubmission(submission)) {
      hideReviewStep();
      return;
    }

    if (confirmSubmitButton instanceof HTMLButtonElement) {
      confirmSubmitButton.disabled = true;
      confirmSubmitButton.textContent = "Submitting...";
    }

    try {
      const backendRequest = await sendSubmissionToApi(submission);
      if (backendRequest?.id) {
        submission.id = backendRequest.id;
      }
      form.reset();
      attachments.splice(0, attachments.length);
      renderAttachments();
      if (attachmentFileInput instanceof HTMLInputElement) {
        attachmentFileInput.value = "";
      }
      hasUnsavedChanges = false;
      hideReviewStep();
      confirmationEl.hidden = false;
      confirmationEl.innerHTML = `<strong>Your SOP submission has been saved.</strong><p>Tracking ID: ${escapeHtml(
        backendRequest?.id || submission.id,
      )}. Status: ${escapeHtml(
        backendRequest?.status || "Submitted",
      )}. Routing: ${escapeHtml(
        backendRequest?.assignedDepartment || "SOP review queue",
      )}. The SOP team can now review, assign, accept, decline, convert, approve, and publish this request.</p>`;
      confirmationEl.scrollIntoView({ behavior: "smooth", block: "center" });
    } catch (error) {
      if (errorsEl instanceof HTMLElement) {
        errorsEl.hidden = false;
        errorsEl.innerHTML = `<p>${escapeHtml(
          error instanceof Error
            ? error.message
            : "The request could not be saved to the backend. Please try again.",
        )}</p>`;
      }
    } finally {
      if (confirmSubmitButton instanceof HTMLButtonElement) {
        confirmSubmitButton.disabled = false;
        confirmSubmitButton.textContent = "Submit SOP Request";
      }
    }
  });

  form?.addEventListener("input", () => {
    hasUnsavedChanges = true;
    hideReviewStep();
  });

  form?.addEventListener("change", () => {
    hasUnsavedChanges = true;
    hideReviewStep();
  });

  editRequestButton?.addEventListener("click", () => {
    hideReviewStep();
    form?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  cancelRequestButton?.addEventListener("click", cancelRequestFlow);
  cancelRequestReviewButton?.addEventListener("click", cancelRequestFlow);

  attachmentFileInput?.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement)) return;

    Array.from(target.files || []).forEach(readAttachmentFile);
  });

  attachmentPasteTarget?.addEventListener("paste", (event) => {
    const file = Array.from(event.clipboardData?.files || []).find((item) =>
      item.type.startsWith("image/"),
    );

    if (!file) return;

    event.preventDefault();
    readAttachmentFile(file);
  });

  attachmentList?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const button = target.closest("[data-remove-attachment]");
    if (!(button instanceof HTMLElement)) return;

    const index = Number(button.dataset.removeAttachment);
    if (!Number.isInteger(index)) return;

    attachments.splice(index, 1);
    renderAttachments();
    hasUnsavedChanges = true;
    hideReviewStep();
  });

  form?.addEventListener("reset", () => {
    window.setTimeout(() => {
      attachments.splice(0, attachments.length);
      renderAttachments();
      hasUnsavedChanges = false;
      hideReviewStep();
    }, 0);
  });

  loadRequestCategories();
</script>
