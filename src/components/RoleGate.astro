---
import { creatorSubRoleViews, roleAccessViews, roleRouteRules } from "../data/platform-config";
---

<section class="role-gate no-print" id="role-gate" aria-labelledby="role-gate-heading" hidden>
  <div
    class="role-gate__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="role-gate-heading"
    aria-describedby="role-gate-description"
  >
    <div class="role-gate__header">
      <span class="brand__mark" aria-hidden="true">SOP</span>
      <div>
        <p class="eyebrow">Choose your access view</p>
        <h1 id="role-gate-heading">Select Your Role</h1>
        <p id="role-gate-description">
          Pick the role you are using today. The app will show the navigation, tools, and options
          aligned to that role.
        </p>
      </div>
    </div>

    <div class="role-gate__grid">
      {roleAccessViews.map((role) => (
        <button
          class="role-gate__card"
          type="button"
          data-role-select={role.id}
          data-role-landing={role.landingPage}
        >
          <strong>{role.title}</strong>
          <span>{role.description}</span>
          <small>{role.options.join(" • ")}</small>
        </button>
      ))}
    </div>

    <div class="role-gate__subroles" id="creator-sub-role-panel" hidden>
      <p class="eyebrow">Creator / Reviewer department</p>
      <div class="role-gate__grid role-gate__grid--subroles">
        {creatorSubRoleViews.map((subRole) => (
          <button
            class="role-gate__card"
            type="button"
            data-sub-role-select={subRole.id}
          >
            <strong>{subRole.title}</strong>
            <span>{subRole.department}</span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="access-denied no-print" id="role-access-denied" hidden>
  <div class="access-denied__panel" role="alert">
    <p class="eyebrow">Role access</p>
    <h2>This page is outside your selected role.</h2>
    <p id="role-access-message">
      Switch roles or go to the landing page for your selected access view.
    </p>
    <div class="form-actions">
      <a class="button button--primary" id="role-landing-link" href="/">Go to My View</a>
      <button class="button button--ghost" type="button" data-role-reset>Switch Role</button>
    </div>
  </div>
</section>

<script is:inline define:vars={{ creatorSubRoleViews, roleAccessViews, roleRouteRules }}>
  const ROLE_KEY = "sopHubSelectedRole";
  const SUB_ROLE_KEY = "sopHubSelectedCreatorSubRole";
  const ROLE_CONTEXT_EVENT = "sop-role-context-change";
  const ROLE_LABELS = Object.fromEntries(roleAccessViews.map((role) => [role.id, role.title]));
  const ROLE_LANDING = Object.fromEntries(roleAccessViews.map((role) => [role.id, role.landingPage]));
  const SUB_ROLE_LABELS = Object.fromEntries(creatorSubRoleViews.map((subRole) => [subRole.id, subRole.title]));

  const gate = document.getElementById("role-gate");
  const subRolePanel = document.getElementById("creator-sub-role-panel");
  const accessDenied = document.getElementById("role-access-denied");
  const accessMessage = document.getElementById("role-access-message");
  const landingLink = document.getElementById("role-landing-link");
  const body = document.body;

  const routeRules = roleRouteRules.map((rule) => ({
    pattern: new RegExp(rule.pattern),
    roles: rule.roles,
  }));

  function normalizeRole(role) {
    return role === "admin" || role === "creator" || role === "normal" ? role : "";
  }

  function normalizeSubRole(subRole) {
    return creatorSubRoleViews.some((item) => item.id === subRole) ? subRole : "";
  }

  function selectedSubRoleLabel() {
    const subRole = normalizeSubRole(localStorage.getItem(SUB_ROLE_KEY));
    return subRole ? SUB_ROLE_LABELS[subRole] : "";
  }

  function roleCanAccessPath(role, pathname) {
    const rule = routeRules.find((item) => item.pattern.test(pathname));
    if (!rule) return true;
    return rule.roles.includes(role);
  }

  function syncRoleInputs(role) {
    const chatRole = document.getElementById("ai-chat-role");
    const assistRole = document.getElementById("assist-role");
    const apiRole = role === "admin" ? "admin" : role === "creator" ? "creator" : "normal";

    if (chatRole instanceof HTMLSelectElement) {
      chatRole.value = apiRole;
    }
    if (assistRole instanceof HTMLSelectElement) {
      assistRole.value = apiRole;
      assistRole.dispatchEvent(new Event("change"));
    }
  }

  const nativeFetch = window.fetch.bind(window);
  window.fetch = (input, init = {}) => {
    const subRole = normalizeSubRole(localStorage.getItem(SUB_ROLE_KEY));
    const url = typeof input === "string" ? input : input instanceof Request ? input.url : String(input);
    const isSameOriginApi =
      url.startsWith("/api/") ||
      (url.startsWith(window.location.origin) && new URL(url).pathname.startsWith("/api/"));

    if (!subRole || !isSameOriginApi) return nativeFetch(input, init);

    const headers = new Headers(input instanceof Request ? input.headers : undefined);
    new Headers(init.headers || {}).forEach((value, key) => headers.set(key, value));
    headers.set("x-sop-sub-role", subRole);

    return nativeFetch(input, { ...init, cache: "no-store", headers });
  };

  function emitRoleContextChange(previousRole, previousSubRole) {
    const role = normalizeRole(localStorage.getItem(ROLE_KEY));
    const subRole = role === "creator" ? normalizeSubRole(localStorage.getItem(SUB_ROLE_KEY)) : "";
    window.dispatchEvent(
      new CustomEvent(ROLE_CONTEXT_EVENT, {
        detail: {
          role,
          subRole,
          previousRole: normalizeRole(previousRole),
          previousSubRole: normalizeSubRole(previousSubRole),
        },
      }),
    );
  }

  function applyRole(role) {
    const selectedRole = normalizeRole(role);
    const selectedSubRole = normalizeSubRole(localStorage.getItem(SUB_ROLE_KEY));
    const roleReady = selectedRole && (selectedRole !== "creator" || selectedSubRole);
    body.dataset.sopRole = selectedRole;
    body.dataset.sopSubRole = selectedRole === "creator" ? selectedSubRole : "";
    body.classList.toggle("role-unselected", !roleReady);

    const subRoleLabel = selectedRole === "creator" ? selectedSubRoleLabel() : "";
    const label = subRoleLabel || ROLE_LABELS[selectedRole] || "Select Role";
    document.querySelectorAll("[data-current-role-label]").forEach((element) => {
      element.textContent = label;
    });

    if (landingLink instanceof HTMLAnchorElement) {
      landingLink.href = ROLE_LANDING[selectedRole] || "/";
    }

    syncRoleInputs(selectedRole);

    if (gate instanceof HTMLElement) {
      gate.hidden = Boolean(selectedRole && (selectedRole !== "creator" || selectedSubRole));
    }
    if (subRolePanel instanceof HTMLElement) {
      subRolePanel.hidden = selectedRole !== "creator" || Boolean(selectedSubRole);
    }

    const allowed = !selectedRole || roleCanAccessPath(selectedRole, window.location.pathname);
    if (accessDenied instanceof HTMLElement) {
      accessDenied.hidden = !roleReady || allowed;
    }
    body.classList.toggle("role-blocked", Boolean(roleReady) && !allowed);

    if (accessMessage) {
      accessMessage.textContent = `${label} access does not include this page. Switch roles or go to the ${label} landing view.`;
    }
  }

  function setRole(role, landing) {
    const selectedRole = normalizeRole(role);
    if (!selectedRole) return;
    const previousRole = normalizeRole(localStorage.getItem(ROLE_KEY));
    const previousSubRole = normalizeSubRole(localStorage.getItem(SUB_ROLE_KEY));
    localStorage.setItem(ROLE_KEY, selectedRole);
    if (selectedRole !== "creator") {
      localStorage.removeItem(SUB_ROLE_KEY);
    }
    applyRole(selectedRole);
    emitRoleContextChange(previousRole, previousSubRole);

    if (selectedRole !== "creator" && !roleCanAccessPath(selectedRole, window.location.pathname) && landing) {
      window.location.href = landing;
    }
  }

  function setSubRole(subRole) {
    const selectedSubRole = normalizeSubRole(subRole);
    if (!selectedSubRole) return;
    const previousRole = normalizeRole(localStorage.getItem(ROLE_KEY));
    const previousSubRole = normalizeSubRole(localStorage.getItem(SUB_ROLE_KEY));
    localStorage.setItem(SUB_ROLE_KEY, selectedSubRole);
    localStorage.setItem(ROLE_KEY, "creator");
    applyRole("creator");
    emitRoleContextChange(previousRole, previousSubRole);

    const landing = ROLE_LANDING.creator || "/";
    if (!roleCanAccessPath("creator", window.location.pathname) && landing) {
      window.location.href = landing;
    }
  }

  document.querySelectorAll("[data-role-select]").forEach((button) => {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLElement)) return;
      setRole(button.dataset.roleSelect || "", button.dataset.roleLanding);
    });
  });

  document.querySelectorAll("[data-role-reset]").forEach((button) => {
    button.addEventListener("click", () => {
      const previousRole = normalizeRole(localStorage.getItem(ROLE_KEY));
      const previousSubRole = normalizeSubRole(localStorage.getItem(SUB_ROLE_KEY));
      localStorage.removeItem(ROLE_KEY);
      localStorage.removeItem(SUB_ROLE_KEY);
      applyRole("");
      emitRoleContextChange(previousRole, previousSubRole);
    });
  });

  document.querySelectorAll("[data-sub-role-select]").forEach((button) => {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLElement)) return;
      setSubRole(button.dataset.subRoleSelect || "");
    });
  });

  applyRole(normalizeRole(localStorage.getItem(ROLE_KEY)));
</script>
