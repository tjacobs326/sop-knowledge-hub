---
import StatusBadge from "./StatusBadge.astro";
import { formatDate } from "../lib/dates";

interface Props {
  owner: string;
  lastUpdated: string;
  reviewDate: string;
  category: string;
  tools: string[];
  audience: string[];
  status: string;
  version: string;
  estimatedCompletionTime: string;
}

const {
  owner,
  lastUpdated,
  reviewDate,
  category,
  tools,
  audience,
  status,
  version,
  estimatedCompletionTime,
} = Astro.props;
---

<aside class="metadata-panel" aria-label="SOP metadata">
  <dl>
    <div>
      <dt>Owner</dt>
      <dd data-sop-meta="owner">{owner}</dd>
    </div>
    <div>
      <dt>Last updated</dt>
      <dd data-sop-meta="lastUpdated">{formatDate(lastUpdated)}</dd>
    </div>
    <div>
      <dt>Review date</dt>
      <dd data-sop-meta="reviewDate">{formatDate(reviewDate)}</dd>
    </div>
    <div>
      <dt>Category</dt>
      <dd data-sop-meta="category">{category}</dd>
    </div>
    <div>
      <dt>Tools used</dt>
      <dd data-sop-meta="tools">{tools.join(", ")}</dd>
    </div>
    <div>
      <dt>Audience</dt>
      <dd data-sop-meta="audience">{audience.join(", ")}</dd>
    </div>
    <div>
      <dt>Status</dt>
      <dd data-sop-meta="status"><StatusBadge status={status} /></dd>
    </div>
    <div>
      <dt>Version</dt>
      <dd data-sop-meta="version">{version}</dd>
    </div>
    <div>
      <dt>Estimated time</dt>
      <dd data-sop-meta="estimatedCompletionTime">{estimatedCompletionTime}</dd>
    </div>
  </dl>
</aside>
