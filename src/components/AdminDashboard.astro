---
import type { SopEntry } from "../lib/sops";
import AppIllustration from "./AppIllustration.astro";
import { getSopUrl } from "../lib/sops";
import { formatDate, daysUntil } from "../lib/dates";
import type { ReviewQueueItem } from "../types";

interface Props {
  sops: SopEntry[];
  reviewItems: ReviewQueueItem[];
}

const { sops, reviewItems } = Astro.props;

const totalSops = sops.length;
const draftSops = reviewItems.filter((item) => item.status === "Drafting").length;
const inReview = reviewItems.filter((item) => item.status === "In Review").length;
const published = sops.filter((sop) => sop.data.status === "Published").length;
const waitingTriage = reviewItems.filter((item) => item.status === "Submitted" || item.status === "Triage").length;
const urgent = reviewItems.filter((item) => item.priority === "Urgent").length;
const dueForReview = sops.filter((sop) => {
  const days = daysUntil(sop.data.reviewDate);
  return days !== null && days <= 45;
}).length;
const recentlyPublished = [...sops]
  .filter((sop) => sop.data.status === "Published")
  .sort((a, b) => b.data.lastUpdated.localeCompare(a.data.lastUpdated))
  .slice(0, 4);

const stats = [
  ["Total SOPs", totalSops],
  ["Draft SOPs", draftSops],
  ["SOPs In Review", inReview],
  ["Published SOPs", published],
  ["Submissions Waiting for Triage", waitingTriage],
  ["Urgent Requests", urgent],
  ["SOPs Due for Review", dueForReview],
];

const quickLinks = [
  ["/create/", "Create New SOP"],
  ["/ai-assist/", "AI Assist"],
  ["/admin/review/", "Review Queue"],
  ["/submit/", "Submit SOP Request"],
  ["/search/", "View All SOPs"],
  ["/categories/", "View Categories"],
];
---

<section class="tool-surface" aria-labelledby="admin-heading">
  <div class="section-heading surface-intro">
    <div>
      <p class="eyebrow">Admin Dashboard</p>
      <h1 id="admin-heading">SOP Operations</h1>
      <p>Monitor SOP volume, review activity, publishing status, and operational health.</p>
    </div>
    <AppIllustration name="admin" size="md" />
  </div>

  <div class="stat-grid" id="admin-dashboard-stats">
    {stats.map(([label, value]) => (
      <article class="stat-card">
        <span>{label}</span>
        <strong>{value}</strong>
      </article>
    ))}
  </div>

  <section class="dashboard-section" aria-labelledby="quick-links-heading">
    <h2 id="quick-links-heading">Quick Links</h2>
    <div class="quick-link-grid">
      {quickLinks.map(([href, label]) => <a class="quick-link" href={href}>{label}</a>)}
    </div>
  </section>

  <section class="dashboard-section" aria-labelledby="recent-heading">
    <h2 id="recent-heading">Recently Published SOPs</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">SOP</th>
            <th scope="col">Category</th>
            <th scope="col">Owner</th>
            <th scope="col">Updated</th>
          </tr>
        </thead>
        <tbody id="admin-recent-published">
          {recentlyPublished.map((sop) => (
            <tr>
              <td><a href={getSopUrl(sop)}>{sop.data.title}</a></td>
              <td>{sop.data.category}</td>
              <td>{sop.data.owner}</td>
              <td>{formatDate(sop.data.lastUpdated)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</section>

<script>
  // @ts-nocheck
  import { fetchAllD1Sops, fetchRecentD1Sops } from "../lib/sop-api";

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function formatDateClient(value) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? value : `${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return String(value);
    return new Intl.DateTimeFormat("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    }).format(date);
  }

  function daysUntilClient(value) {
    if (!value) return null;
    const reviewDate = new Date(`${String(value).slice(0, 10)}T00:00:00`);
    if (Number.isNaN(reviewDate.getTime())) return null;
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    return Math.ceil((reviewDate.getTime() - today.getTime()) / 86400000);
  }

  function renderStat(label, value) {
    return `
      <article class="stat-card">
        <span>${escapeHtml(label)}</span>
        <strong>${escapeHtml(value)}</strong>
      </article>
    `;
  }

  function renderRecentRow(sop) {
    return `
      <tr>
        <td><a href="${escapeHtml(sop.detailUrl)}">${escapeHtml(sop.title)}</a></td>
        <td>${escapeHtml(sop.category)}</td>
        <td>${escapeHtml(sop.owner)}</td>
        <td>${escapeHtml(formatDateClient(sop.updatedAt))}</td>
      </tr>
    `;
  }

  async function hydrateAdminDashboard() {
    try {
      const [sops, recent] = await Promise.all([
        fetchAllD1Sops({ limit: 100, sort: "recent" }),
        fetchRecentD1Sops(4),
      ]);
      if (!sops.length) return;

      const stats = [
        ["Total SOPs", sops.length],
        ["Draft SOPs", sops.filter((sop) => sop.status === "Draft").length],
        ["SOPs In Review", sops.filter((sop) => sop.status === "In Review").length],
        ["Published SOPs", sops.filter((sop) => sop.status === "Published").length],
        ["Submissions Waiting for Triage", 0],
        ["Urgent Requests", 0],
        [
          "SOPs Due for Review",
          sops.filter((sop) => {
            const days = daysUntilClient(sop.reviewDate);
            return days !== null && days <= 45;
          }).length,
        ],
      ];

      const statGrid = document.getElementById("admin-dashboard-stats");
      if (statGrid) statGrid.innerHTML = stats.map(([label, value]) => renderStat(label, value)).join("");

      const rows = document.getElementById("admin-recent-published");
      if (rows && recent.length) rows.innerHTML = recent.map(renderRecentRow).join("");
    } catch {
      // Static admin snapshot remains available without Cloudflare D1.
    }
  }

  hydrateAdminDashboard();
</script>
