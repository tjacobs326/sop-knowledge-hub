---
import Layout from "../components/Layout.astro";
import AppIcon from "../components/AppIcon.astro";
import HeroIllustrationIcon from "../components/HeroIllustrationIcon.astro";
---

<Layout title="SOP Knowledge Hub" wide>
  <div class="normal-home-dashboard">
    <section class="home-command-center" aria-labelledby="home-heading">
      <div class="home-command-center__copy">
        <p class="eyebrow">SOP Knowledge Hub</p>
        <h1 id="home-heading">Find the right SOP faster.</h1>
        <p>
          Search official SOPs, ask the hub for guidance, or request help when the process you need is missing.
        </p>
      </div>

      <form class="home-search-panel" action="/search/" role="search" aria-label="Search SOPs">
        <label for="home-sop-search">Search SOPs</label>
        <div class="home-search-panel__control">
          <input
            id="home-sop-search"
            name="q"
            type="search"
            placeholder="Search by title, system, category, owner, or keyword"
            autocomplete="off"
          />
          <button class="button button--primary" type="submit">Search</button>
        </div>
      </form>

      <div class="home-ask-panel" aria-labelledby="home-guided-banner-heading">
        <span class="home-ask-panel__icon" aria-hidden="true"><HeroIllustrationIcon name="book" /></span>
        <div>
          <h2 id="home-guided-banner-heading">Guided Finder</h2>
          <p>Answer a few questions to quickly find the right SOP.</p>
        </div>
        <a class="button button--secondary" href="/guided-finder/">Open Guided Finder</a>
      </div>
    </section>

    <section class="home-quick-actions" aria-labelledby="home-quick-actions-heading">
      <div class="dashboard-section-heading">
        <h2 id="home-quick-actions-heading">Quick Actions</h2>
      </div>
      <div class="home-quick-actions__grid">
        <a class="home-action-card" href="/search/">
          <span class="home-action-card__icon" aria-hidden="true"><HeroIllustrationIcon name="target" /></span>
          <span>
            <strong>Browse SOPs</strong>
            <small>Search and browse all published SOPs.</small>
          </span>
        </a>
        <a class="home-action-card" href="/guided-finder/">
          <span class="home-action-card__icon" aria-hidden="true"><HeroIllustrationIcon name="book" /></span>
          <span>
            <strong>Guided Finder</strong>
            <small>Step through filters to find the right SOP.</small>
          </span>
        </a>
        <a class="home-action-card" href="/submit/">
          <span class="home-action-card__icon" aria-hidden="true"><HeroIllustrationIcon name="support" /></span>
          <span>
            <strong>Request an SOP</strong>
            <small>Ask for a missing process or update.</small>
          </span>
        </a>
        <a class="home-action-card" href="/create/" id="home-create-sop-action" hidden>
          <span class="home-action-card__icon" aria-hidden="true"><HeroIllustrationIcon name="documentShield" /></span>
          <span>
            <strong>Create an SOP</strong>
            <small>Start an authorized SOP draft.</small>
          </span>
        </a>
        <button class="home-action-card" type="button" id="home-quick-ask-hub">
          <span class="home-action-card__icon" aria-hidden="true"><HeroIllustrationIcon name="book" /></span>
          <span>
            <strong>Ask Hub</strong>
            <small>Get guided help from the assistant.</small>
          </span>
        </button>
      </div>
    </section>

    <section class="home-summary-strip" aria-label="Knowledge hub summary">
      <div>
        <span>Published SOPs</span>
        <strong id="home-summary-published">Loading</strong>
      </div>
      <div>
        <span>Categories</span>
        <strong id="home-summary-categories">Loading</strong>
      </div>
      <div>
        <span>Last Updated</span>
        <strong id="home-summary-updated">Loading</strong>
      </div>
    </section>

    <section class="home-dashboard-section" id="home-activity-section" aria-labelledby="home-activity-heading" hidden>
      <div class="dashboard-section-heading">
        <div>
          <p class="eyebrow">Personal Dashboard</p>
          <h2 id="home-activity-heading">Your SOP Activity</h2>
        </div>
      </div>
      <div class="home-activity-grid">
        <article class="dashboard-panel home-activity-card" id="home-recently-viewed-card" hidden>
          <div class="dashboard-panel__heading">
            <h3>Recently Viewed SOPs</h3>
            <a href="/search/">View all</a>
          </div>
          <ul class="home-item-list" id="home-recently-viewed"></ul>
        </article>

        <article class="dashboard-panel home-activity-card" id="home-saved-card" hidden>
          <div class="dashboard-panel__heading">
            <h3>Saved SOPs</h3>
            <a href="/search/?saved=true">View all</a>
          </div>
          <ul class="home-item-list" id="home-saved-sops"></ul>
        </article>

        <article class="dashboard-panel home-activity-card" id="home-updated-card" hidden>
          <div class="dashboard-panel__heading">
            <h3>Recently Updated for You</h3>
            <a href="/search/?sort=recent">View all</a>
          </div>
          <ul class="home-item-list" id="home-updated-for-you"></ul>
        </article>
      </div>
    </section>

    <section class="home-dashboard-section" id="home-important-section" aria-labelledby="home-important-heading" hidden>
      <div class="dashboard-section-heading">
        <h2 id="home-important-heading">Important Updates</h2>
        <a href="/search/?sort=recent">View all</a>
      </div>
      <div class="home-update-grid" id="home-important-updates"></div>
    </section>

    <section class="home-dashboard-section" aria-labelledby="home-help-heading">
      <div class="dashboard-section-heading">
        <h2 id="home-help-heading">Need Help?</h2>
      </div>
      <div class="home-help-grid">
        <a class="dashboard-panel home-help-card" href="/submit/?type=issue">
          <AppIcon name="review" />
          <span>
            <strong>Report an SOP issue</strong>
            <small>Flag unclear, outdated, or incomplete content.</small>
          </span>
        </a>
        <a class="dashboard-panel home-help-card" href="mailto:sop-support@organization.edu">
          <AppIcon name="support" />
          <span>
            <strong>Contact support</strong>
            <small>Reach the SOP support team for help.</small>
          </span>
        </a>
        <a class="dashboard-panel home-help-card" href="/guided-finder/">
          <AppIcon name="finder" />
          <span>
            <strong>SOP Help & FAQs</strong>
            <small>Use Guided Finder for common questions and SOP discovery.</small>
          </span>
        </a>
      </div>
    </section>
  </div>
</Layout>

<script>
  // @ts-nocheck
  import { fetchD1Categories } from "../lib/sop-api";

  const ROLE_CONTEXT_EVENT = "sop-role-context-change";
  const MAX_PANEL_ITEMS = 5;
  let homeRequestId = 0;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function formatDateClient(value) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? value : `${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return String(value);
    return new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(date);
  }

  function setText(id, value) {
    const element = document.getElementById(id);
    if (element) element.textContent = String(value);
  }

  function sopUrl(sop) {
    if (sop?.detailUrl) return sop.detailUrl;
    if (sop?.slug) return `/sops/detail/?slug=${encodeURIComponent(sop.slug)}`;
    return `/sops/detail/?id=${encodeURIComponent(String(sop?.id || ""))}`;
  }

  function renderSopItem(sop) {
    return `
      <li>
        <a href="${escapeHtml(sopUrl(sop))}">${escapeHtml(sop.title || "Untitled SOP")}</a>
        <span>${escapeHtml(sop.category || "Uncategorized")} · ${escapeHtml(formatDateClient(sop.updatedAt || sop.publishedAt))}</span>
      </li>
    `;
  }

  function renderPanel(cardId, listId, items) {
    const card = document.getElementById(cardId);
    const list = document.getElementById(listId);
    if (!(card instanceof HTMLElement) || !(list instanceof HTMLElement)) return false;
    const safeItems = Array.isArray(items) ? items.filter(Boolean).slice(0, MAX_PANEL_ITEMS) : [];
    card.hidden = safeItems.length === 0;
    list.innerHTML = safeItems.map(renderSopItem).join("");
    return safeItems.length > 0;
  }

  function renderImportantUpdates(items) {
    const section = document.getElementById("home-important-section");
    const container = document.getElementById("home-important-updates");
    if (!(section instanceof HTMLElement) || !(container instanceof HTMLElement)) return;
    const safeItems = Array.isArray(items) ? items.filter(Boolean).slice(0, 3) : [];
    section.hidden = safeItems.length === 0;
    container.innerHTML = safeItems
      .map(
        (item) => `
          <a class="dashboard-panel home-update-card" href="${escapeHtml(item.href || "/search/")}">
            <strong>${escapeHtml(item.title || "SOP update")}</strong>
            <p>${escapeHtml(item.body || "A published SOP was updated.")}</p>
            <time>${escapeHtml(formatDateClient(item.updatedAt))}</time>
          </a>
        `,
      )
      .join("");
  }

  function openAskHub() {
    const launcher = document.querySelector(".ai-chatbot__toggle");
    if (launcher instanceof HTMLButtonElement && !launcher.hidden) {
      launcher.click();
    }
  }

  async function hydrateSummary(requestId) {
    try {
      const [sopsResponse, categories] = await Promise.all([
        fetch("/api/sops?limit=1&sort=recent", { headers: { accept: "application/json" } }).then((response) => response.json()),
        fetchD1Categories(),
      ]);
      if (requestId !== homeRequestId) return;
      const firstSop = sopsResponse?.data?.sops?.[0] || sopsResponse?.sops?.[0] || null;
      const total = Number(sopsResponse?.data?.total ?? sopsResponse?.total ?? 0);
      setText("home-summary-published", total);
      setText("home-summary-categories", categories.length);
      setText("home-summary-updated", formatDateClient(firstSop?.updatedAt || firstSop?.lastUpdated));
    } catch {
      if (requestId !== homeRequestId) return;
      setText("home-summary-published", "Unavailable");
      setText("home-summary-categories", "Unavailable");
      setText("home-summary-updated", "Unavailable");
    }
  }

  async function hydrateHome() {
    const requestId = ++homeRequestId;
    const activitySection = document.getElementById("home-activity-section");
    if (activitySection instanceof HTMLElement) activitySection.hidden = true;

    try {
      await hydrateSummary(requestId);
      const response = await fetch("/api/home-dashboard", {
        headers: { accept: "application/json" },
        cache: "no-store",
      });
      const payload = await response.json().catch(() => ({}));
      if (requestId !== homeRequestId) return;
      if (!response.ok || payload?.success === false) throw new Error(payload?.error?.message || "Dashboard could not load.");

      const dashboard = payload.data || {};
      const createAction = document.getElementById("home-create-sop-action");
      if (createAction instanceof HTMLElement) {
        createAction.hidden = !Boolean(dashboard.user?.permissions?.canCreateSop);
      }
      const activity = dashboard.activity || {};
      const hasViewed = renderPanel("home-recently-viewed-card", "home-recently-viewed", activity.recentlyViewed);
      const hasSaved = renderPanel("home-saved-card", "home-saved-sops", activity.savedSops);
      const hasUpdated = renderPanel("home-updated-card", "home-updated-for-you", activity.recentlyUpdatedForYou);
      if (activitySection instanceof HTMLElement) activitySection.hidden = !(hasViewed || hasSaved || hasUpdated);
      renderImportantUpdates(dashboard.importantUpdates);
    } catch {
      if (requestId !== homeRequestId) return;
      renderImportantUpdates([]);
    }
  }

  document.getElementById("home-open-ask-hub")?.addEventListener("click", openAskHub);
  document.getElementById("home-quick-ask-hub")?.addEventListener("click", openAskHub);
  window.addEventListener(ROLE_CONTEXT_EVENT, () => {
    hydrateHome();
  });
  hydrateHome();
</script>
