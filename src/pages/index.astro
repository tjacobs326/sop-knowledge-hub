---
import Layout from "../components/Layout.astro";
import CategoryCard from "../components/CategoryCard.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { formatDate } from "../lib/dates";
import { getAllSops, getCategoryCounts, getSopUrl } from "../lib/sops";

const sops = await getAllSops();
const categoryCounts = getCategoryCounts(sops);
const recentlyUpdated = [...sops]
  .sort((a, b) => new Date(b.data.lastUpdated).getTime() - new Date(a.data.lastUpdated).getTime())
  .slice(0, 5);
const totalPublished = sops.filter((sop) => sop.data.status === "Published").length;
const tagCount = new Set(sops.flatMap((sop) => sop.data.tags)).size;
const lastUpdated = recentlyUpdated[0]?.data.lastUpdated ?? new Date().toISOString().slice(0, 10);

const quickAccess = [
  ["/search/", "Search SOPs", "SS", "normal"],
  ["/finder/", "Guided Finder", "GF", "normal"],
  ["/categories/", "Categories", "C", "normal"],
  ["/submit/", "Submit Request", "SR", "normal"],
  ["/my-work/", "My Work", "MW", "creator"],
  ["/ai-assist/", "AI Assist", "AA", "creator"],
  ["/create/", "Create SOP", "CS", "creator"],
  ["/drafts/", "My Drafts", "MD", "creator"],
  ["/admin/review/", "Review Queue", "RQ", "creator"],
  ["/admin/needs-review/", "Needs Review", "NR", "creator"],
  ["/admin/users/", "Users", "U", "admin"],
  ["/admin/categories/", "Categories", "C", "admin"],
  ["/admin/tags/", "Tags", "T", "admin"],
  ["/admin/analytics/", "Analytics", "A", "admin"],
  ["/admin/settings/", "Settings", "S", "admin"],
];

const announcements = [
  ["New SOP Updates", "Review the latest changed procedures and recently published drafts.", "May 15, 2026"],
  ["Training on SOP Best Practices", "Use consistent steps, owners, review dates, and supporting media.", "May 22, 2026"],
  ["New Category Added", "Admin taxonomy tools now support category and tag management.", "May 10, 2026"],
];

const resources = [
  ["/categories/templates/", "SOP Templates", "Use templates to get started.", "normal"],
  ["/finder/", "SOP Guidelines", "Find the right process path.", "normal"],
  ["/admin/review/", "Approval Workflow", "Learn about the review process.", "creator"],
  ["/ai-assist/", "SOP Training", "Get controlled AI assistance.", "creator"],
  ["/admin/settings/", "Admin Settings", "Manage access, workflow, and taxonomy.", "admin"],
  ["/admin/analytics/", "Business Analytics", "View adoption and usage metrics.", "admin"],
  ["mailto:sop-support@organization.edu", "Contact SOP Support", "Get help from our team.", "all"],
];
---

<Layout title="SOP Knowledge Hub" wide>
  <div class="dashboard-layout">
    <div class="dashboard-main">
      <section class="hero dashboard-hero">
        <div class="hero__content">
          <p class="eyebrow">Welcome to the</p>
          <h1>SOP Knowledge Hub</h1>
          <p class="hero__subtitle">
            Your central hub for official standard operating procedures, guides, and best practices.
          </p>
          <div class="hero-actions">
            <a class="button button--primary" href="/search/">Search SOPs</a>
            <a class="button button--ghost hero-button" href="/finder/">Guided Finder</a>
          </div>
        </div>
        <div class="hero-illustration" aria-hidden="true">
          <div class="document-card">
            <strong>SOP</strong>
            <span></span>
            <span></span>
            <span></span>
            <ul>
              <li></li>
              <li></li>
              <li></li>
            </ul>
          </div>
          <span class="floating-tile">OK</span>
          <span class="floating-tile floating-tile--left">KB</span>
        </div>
      </section>

      <dl class="hero-stats dashboard-stats" aria-label="Knowledge base overview">
        <div class="hero-stats__item">
          <dt>Published SOPs</dt>
          <dd>{totalPublished}</dd>
          <a href="/search/">View all published</a>
        </div>
        <div class="hero-stats__item">
          <dt>Categories</dt>
          <dd>{categoryCounts.length}</dd>
          <a href="/categories/">View all categories</a>
        </div>
        <div class="hero-stats__item">
          <dt>Tags</dt>
          <dd>{tagCount}</dd>
          <a href="/admin/tags/">View all tags</a>
        </div>
        <div class="hero-stats__item">
          <dt>Last Updated</dt>
          <dd>{formatDate(lastUpdated)}</dd>
          <a href="/search/">See what's new</a>
        </div>
      </dl>

      <section class="page-section dashboard-section-block" aria-labelledby="categories-heading">
        <div class="dashboard-section-heading">
          <h2 id="categories-heading">Browse by Category</h2>
          <a href="/categories/">View all categories -></a>
        </div>
        <div class="category-grid dashboard-category-grid">
          {
            categoryCounts.slice(0, 5).map((category) => (
              <CategoryCard
                name={category.name}
                slug={category.slug}
                description={category.description}
                icon={category.icon}
                color={category.color}
                count={category.count}
              />
            ))
          }
        </div>
      </section>

      <section class="page-section dashboard-section-block" aria-labelledby="recent-heading">
        <div class="dashboard-section-heading">
          <h2 id="recent-heading">Recently Updated SOPs</h2>
          <a href="/search/">View all SOPs -></a>
        </div>
        <div class="table-wrap dashboard-table">
          <table>
            <thead>
              <tr>
                <th scope="col">SOP Title</th>
                <th scope="col">Category</th>
                <th scope="col">Updated</th>
                <th scope="col">Status</th>
              </tr>
            </thead>
            <tbody>
              {
                recentlyUpdated.map((sop) => (
                  <tr>
                    <td>
                      <a href={getSopUrl(sop)}>{sop.data.title}</a>
                      <span>{sop.data.purpose}</span>
                    </td>
                    <td><span class="category-pill">{sop.data.category}</span></td>
                    <td>{formatDate(sop.data.lastUpdated)}</td>
                    <td><StatusBadge status={sop.data.status} /></td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <aside class="dashboard-rail" aria-label="Dashboard tools">
      <section class="dashboard-panel">
        <h2>My Quick Access</h2>
        <div class="quick-access-grid">
          {
            quickAccess.map(([href, label, icon, role]) => (
              <a href={href} data-role-option={role}>
                <span aria-hidden="true">{icon}</span>
                {label}
              </a>
            ))
          }
        </div>
      </section>

      <section class="dashboard-panel">
        <div class="dashboard-panel__heading">
          <h2>Announcements</h2>
          <a href="/search/">View all</a>
        </div>
        <ol class="announcement-list">
          {
            announcements.map(([title, body, date]) => (
              <li>
                <strong>{title}</strong>
                <p>{body}</p>
                <time>{date}</time>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="dashboard-panel">
        <h2>Helpful Resources</h2>
        <div class="resource-list">
          {
            resources.map(([href, title, body, role]) => (
              <a href={href} data-role-option={role}>
                <span>
                  <strong>{title}</strong>
                  <small>{body}</small>
                </span>
                <span aria-hidden="true">></span>
              </a>
            ))
          }
        </div>
      </section>
    </aside>
  </div>
</Layout>
