---
import Layout from "../components/Layout.astro";
import AppIcon from "../components/AppIcon.astro";
import CategoryCard from "../components/CategoryCard.astro";
import { auditLogs, reviews, searchLogs, sopRequests, userAccounts } from "../data/mock-platform";
import { formatDate } from "../lib/dates";
import { getAllSops, getCategoryCounts, getSopUrl } from "../lib/sops";

const sops = await getAllSops();
const categoryCounts = getCategoryCounts(sops);
const recentlyUpdated = [...sops]
  .sort((a, b) => new Date(b.data.lastUpdated).getTime() - new Date(a.data.lastUpdated).getTime())
  .slice(0, 5);
const totalPublished = sops.filter((sop) => sop.data.status === "Published").length;
const tagCount = new Set(sops.flatMap((sop) => sop.data.tags)).size;
const lastUpdated = recentlyUpdated[0]?.data.lastUpdated ?? new Date().toISOString().slice(0, 10);

type DashboardRole = "normal" | "creator" | "admin";
type DashboardTone = "standard" | "urgent" | "danger" | "warning" | "success";
type DashboardCard = {
  href: string;
  label: string;
  value: string;
  description: string;
  icon: string;
  tone: DashboardTone;
  status?: string;
};

const normalUser = userAccounts.find((user) => user.accessLevel === "Normal User") ?? userAccounts[0];
const creatorUser = userAccounts.find((user) => user.accessLevel === "Creator / Reviewer") ?? userAccounts[0];
const adminUser = userAccounts.find((user) => user.accessLevel === "Admin") ?? userAccounts[0];
const today = new Date("2026-07-06T00:00:00Z");
const openRequestStatuses = new Set(["Submitted", "Triage", "Assigned", "In Review"]);
const pendingReviewStatuses = new Set(["Submitted", "Triage", "Assigned", "In Review", "Needs Revision"]);
const openRequests = sopRequests.filter((request) => openRequestStatuses.has(request.status));
const pendingReviews = reviews.filter((review) => pendingReviewStatuses.has(review.status));
const urgentItems = [...reviews, ...sopRequests].filter((item) => ["High", "Urgent"].includes(item.priority));
const overdueReviews = reviews.filter((review) => new Date(`${review.dueDate}T00:00:00Z`) < today && review.status !== "Approved");
const assignedToCreator = reviews.filter((review) => review.assignedReviewerUserId === creatorUser.id);
const needsCreatorReview = assignedToCreator.filter((review) => pendingReviewStatuses.has(review.status));
const recentlyViewedLog =
  [...searchLogs].sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())[0] ?? null;
const recentlyViewedSop =
  sops.find((sop) => sop.data.id === recentlyViewedLog?.clickedSopId) ?? recentlyUpdated[0];
const popularSop =
  sops.find((sop) => sop.data.id === searchLogs.find((log) => log.clickedSopId)?.clickedSopId) ?? recentlyUpdated[0];
const recentlyUpdatedSop = recentlyUpdated[0];
const contentHealth = Math.round((totalPublished / Math.max(sops.length, 1)) * 100);

const dashboardConfigs: Record<DashboardRole, { title: string; cards: DashboardCard[] }> = {
  normal: {
    title: "Recommended for You",
    cards: [
      {
        href: recentlyViewedSop ? getSopUrl(recentlyViewedSop) : "/search/",
        label: "Recently Viewed",
        value: recentlyViewedSop?.data.title ?? "No recent SOP",
        description: recentlyViewedLog ? `Last viewed ${formatDate(recentlyViewedLog.createdAt)}` : "Open an SOP to start your history.",
        icon: "document",
        tone: "standard",
      },
      {
        href: "/search/?saved=true",
        label: "Saved SOPs",
        value: "4",
        description: `${normalUser.name} has saved SOPs for quick reference.`,
        icon: "tags",
        tone: "standard",
      },
      {
        href: popularSop ? getSopUrl(popularSop) : "/search/",
        label: "Popular This Week",
        value: popularSop?.data.title ?? "Browse SOPs",
        description: "Most viewed published SOP in current sample data.",
        icon: "analytics",
        tone: "success",
      },
      {
        href: recentlyUpdatedSop ? getSopUrl(recentlyUpdatedSop) : "/search/",
        label: "Recently Updated",
        value: recentlyUpdatedSop?.data.title ?? "No updates",
        description: recentlyUpdatedSop ? `Updated ${formatDate(recentlyUpdatedSop.data.lastUpdated)}` : "Published SOP updates will appear here.",
        icon: "review",
        tone: "standard",
      },
      {
        href: "/categories/",
        label: "Explore Categories",
        value: String(categoryCounts.length),
        description: "Browse available SOP categories.",
        icon: "categories",
        tone: "standard",
      },
      {
        href: "/submit/",
        label: "Can't Find It?",
        value: "Request SOP",
        description: "Submit a request when the process you need is missing.",
        icon: "submit",
        tone: "warning",
        status: "Request help",
      },
    ],
  },
  creator: {
    title: "My Work Summary",
    cards: [
      {
        href: "/my-work/",
        label: "Assigned to Me",
        value: String(assignedToCreator.length || 3),
        description: "Active SOP tasks waiting on your update.",
        icon: "work",
        tone: "standard",
      },
      {
        href: "/admin/needs-review/",
        label: "Needs My Review",
        value: String(needsCreatorReview.length || 2),
        description: "SOPs ready for your approval pass.",
        icon: "review",
        tone: "urgent",
        status: "Action needed",
      },
      {
        href: "/drafts/",
        label: "My Drafts",
        value: "4",
        description: "Draft SOPs saved but not submitted.",
        icon: "drafts",
        tone: "standard",
      },
      {
        href: "/my-work/",
        label: "Overdue Reviews",
        value: String(overdueReviews.length || 1),
        description: "Past due review that needs attention.",
        icon: "needsReview",
        tone: "danger",
        status: "Past due",
      },
      {
        href: "/submit/",
        label: "Open Requests",
        value: String(openRequests.length || 5),
        description: "Submitted requests still in progress.",
        icon: "submit",
        tone: "warning",
        status: "Open",
      },
      {
        href: recentlyViewedSop ? getSopUrl(recentlyViewedSop) : "/search/",
        label: "Recently Viewed",
        value: recentlyViewedSop?.data.title ?? "Course QA",
        description: "Last opened SOP from your history.",
        icon: "search",
        tone: "standard",
      },
    ],
  },
  admin: {
    title: "Knowledge Hub Overview",
    cards: [
      {
        href: "/admin/review/",
        label: "Pending Reviews",
        value: String(pendingReviews.length),
        description: "Review items awaiting admin or reviewer action.",
        icon: "review",
        tone: "urgent",
        status: "Queue",
      },
      {
        href: "/admin/review/",
        label: "Urgent Items",
        value: String(urgentItems.length),
        description: "High-priority requests and reviews across the hub.",
        icon: "needsReview",
        tone: "danger",
        status: "Priority",
      },
      {
        href: "/admin/needs-review/",
        label: "Past-Due SOP Reviews",
        value: String(overdueReviews.length),
        description: "Published or queued items past their review date.",
        icon: "qa",
        tone: "danger",
        status: "Past due",
      },
      {
        href: "/submit/",
        label: "Open Requests",
        value: String(openRequests.length),
        description: "Requests still moving through intake or review.",
        icon: "submit",
        tone: "warning",
        status: "Open",
      },
      {
        href: "/admin/analytics/",
        label: "Content Health",
        value: `${contentHealth}%`,
        description: `${totalPublished} of ${sops.length} SOPs are published.`,
        icon: "analytics",
        tone: "success",
      },
      {
        href: "/admin/users/",
        label: "Recent Admin Activity",
        value: auditLogs[0]?.action ?? "No activity",
        description: auditLogs[0] ? `${auditLogs[0].actorName}: ${auditLogs[0].summary}` : `No recent activity for ${adminUser.name}.`,
        icon: "settings",
        tone: "standard",
      },
    ],
  },
};

const announcements = [
  ["New SOP Updates", "Review the latest changed procedures and recently published drafts.", "May 15, 2026"],
  ["Training on SOP Best Practices", "Use consistent steps, owners, review dates, and supporting media.", "May 22, 2026"],
  ["New Category Added", "Admin taxonomy tools now support category and tag management.", "May 10, 2026"],
];

const resources = [
  ["/categories/templates/", "SOP Templates", "Use templates to get started.", "normal"],
  ["/finder/", "SOP Guidelines", "Find the right process path.", "normal"],
  ["/admin/review/", "Approval Workflow", "Learn about the review process.", "creator"],
  ["/ai-assist/", "SOP Training", "Get controlled AI assistance.", "creator"],
  ["/admin/settings/", "Admin Settings", "Manage access, workflow, and taxonomy.", "admin"],
  ["/admin/analytics/", "Business Analytics", "View adoption and usage metrics.", "admin"],
  ["mailto:sop-support@organization.edu", "Contact SOP Support", "Get help from our team.", "all"],
];

const categoryIconByName: Record<string, string> = {
  "QA Processes": "qa",
  "Brightspace D2L": "d2l",
  Templates: "template",
  "Course Builds": "course",
  "Ivanti / Ticketing System": "ticket",
  "AI Tools": "ai",
  Troubleshooting: "troubleshooting",
};
---

<Layout title="SOP Knowledge Hub" wide>
  <div class="dashboard-layout">
    <div class="dashboard-main">
      <section class="hero dashboard-hero">
        <div class="hero__content">
          <p class="eyebrow">Welcome to the</p>
          <h1>SOP Knowledge Hub</h1>
          <p class="hero__subtitle">
            Your central hub for official standard operating procedures, guides, and best practices.
          </p>
          <div class="hero-actions">
            <a class="button button--primary" href="/search/"><AppIcon name="search" />Search SOPs</a>
            <a class="button button--ghost hero-button" href="/finder/"><AppIcon name="finder" />Guided Finder</a>
          </div>
        </div>
        <div class="hero-illustration" aria-hidden="true">
          <div class="document-card">
            <strong>SOP</strong>
            <span></span>
            <span></span>
            <span></span>
            <ul>
              <li></li>
              <li></li>
              <li></li>
            </ul>
          </div>
          <span class="floating-tile">OK</span>
          <span class="floating-tile floating-tile--left">KB</span>
        </div>
      </section>

      <div class="hero-stats dashboard-stats" role="list" aria-label="Knowledge base overview">
        <div class="hero-stats__item" role="listitem">
          <span class="hero-stats__icon hero-stats__icon--published" aria-hidden="true"><AppIcon name="document" variant="illustrated" /></span>
          <span class="hero-stats__content">
            <span class="hero-stats__label">Published SOPs</span>
            <strong class="hero-stats__value">{totalPublished}</strong>
            <a href="/search/">View all published</a>
          </span>
        </div>
        <div class="hero-stats__item" role="listitem">
          <span class="hero-stats__icon hero-stats__icon--categories" aria-hidden="true"><AppIcon name="categories" variant="illustrated" /></span>
          <span class="hero-stats__content">
            <span class="hero-stats__label">Categories</span>
            <strong class="hero-stats__value">{categoryCounts.length}</strong>
            <a href="/categories/">View all categories</a>
          </span>
        </div>
        <div class="hero-stats__item" role="listitem">
          <span class="hero-stats__icon hero-stats__icon--tags" aria-hidden="true"><AppIcon name="tags" variant="illustrated" /></span>
          <span class="hero-stats__content">
            <span class="hero-stats__label">Tags</span>
            <strong class="hero-stats__value">{tagCount}</strong>
            <a href="/admin/tags/">View all tags</a>
          </span>
        </div>
        <div class="hero-stats__item" role="listitem">
          <span class="hero-stats__icon hero-stats__icon--updated" aria-hidden="true"><AppIcon name="analytics" variant="illustrated" /></span>
          <span class="hero-stats__content">
            <span class="hero-stats__label">Last Updated</span>
            <strong class="hero-stats__value">{formatDate(lastUpdated)}</strong>
            <a href="/search/">See what's new</a>
          </span>
        </div>
      </div>

      <section class="page-section dashboard-section-block" aria-labelledby="categories-heading">
        <div class="dashboard-section-heading">
          <h2 id="categories-heading">Browse by Category</h2>
          <a href="/categories/">View all categories -></a>
        </div>
        <div class="category-grid dashboard-category-grid">
          {
            categoryCounts.slice(0, 5).map((category) => (
              <CategoryCard
                name={category.name}
                slug={category.slug}
                description={category.description}
                icon={category.icon}
                color={category.color}
                count={category.count}
              />
            ))
          }
        </div>
      </section>

      <section class="page-section dashboard-section-block" aria-labelledby="recent-heading">
        <div class="dashboard-section-heading">
          <h2 id="recent-heading">Recently Updated SOPs</h2>
          <a href="/search/">View all SOPs -></a>
        </div>
        <div class="table-wrap dashboard-table">
          <table>
            <thead>
              <tr>
                <th scope="col">SOP Title</th>
                <th scope="col">Category</th>
                <th scope="col">Updated</th>
              </tr>
            </thead>
            <tbody>
              {
                recentlyUpdated.map((sop) => (
                  <tr>
                    <td data-label="SOP">
                      <div class="dashboard-sop-title-row">
                        <a href={getSopUrl(sop)}>{sop.data.title}</a>
                      </div>
                      <span class="dashboard-sop-purpose">{sop.data.purpose}</span>
                    </td>
                    <td data-label="Category">
                      <span class="category-pill">
                        <AppIcon name={categoryIconByName[sop.data.category] ?? "document"} variant="illustrated" />
                        {sop.data.category}
                      </span>
                    </td>
                    <td data-label="Updated">{formatDate(sop.data.lastUpdated)}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <aside class="dashboard-rail" aria-label="Dashboard tools">
      {
        (Object.entries(dashboardConfigs) as [DashboardRole, (typeof dashboardConfigs)[DashboardRole]][]).map(
          ([role, config]) => (
            <section class="dashboard-panel role-dashboard-panel" data-dashboard-role={role} aria-labelledby={`dashboard-${role}-heading`}>
              <h2 id={`dashboard-${role}-heading`}>{config.title}</h2>
              <div class="work-summary-grid">
                {config.cards.map((item) => (
                  <a
                    class:list={["work-summary-card", `work-summary-card--${item.tone}`]}
                    href={item.href}
                    aria-label={`${item.label}: ${item.value}. ${item.description}`}
                  >
                    <span class="work-summary-card__icon" aria-hidden="true"><AppIcon name={item.icon} /></span>
                    <span class="work-summary-card__body">
                      <span class="work-summary-card__label">{item.label}</span>
                      <strong>{item.value}</strong>
                      <small>{item.description}</small>
                    </span>
                    {item.status && <span class="work-summary-card__status">{item.status}</span>}
                  </a>
                ))}
              </div>
            </section>
          ),
        )
      }

      <section class="dashboard-panel">
        <div class="dashboard-panel__heading">
          <h2>Announcements</h2>
          <a href="/search/">View all</a>
        </div>
        <ol class="announcement-list">
          {
            announcements.map(([title, body, date]) => (
              <li>
                <strong>{title}</strong>
                <p>{body}</p>
                <time>{date}</time>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="dashboard-panel">
        <h2>Helpful Resources</h2>
        <div class="resource-list">
          {
            resources.map(([href, title, body, role]) => (
              <a href={href} data-role-option={role}>
                <span>
                  <strong>{title}</strong>
                  <small>{body}</small>
                </span>
                <span aria-hidden="true">></span>
              </a>
            ))
          }
        </div>
      </section>
    </aside>
  </div>
</Layout>
