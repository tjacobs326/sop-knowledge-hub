---
import Layout from "../../components/Layout.astro";
import AppIllustration from "../../components/AppIllustration.astro";
import { priorityBadgeDefinitions, statusBadgeDefinitions } from "../../lib/badges";
---

<Layout title="My Work" wide>
  <section class="tool-surface" aria-labelledby="my-work-heading">
    <div class="section-heading surface-intro">
      <div>
        <p class="eyebrow">Workflow Dashboard</p>
        <h1 id="my-work-heading">My Work</h1>
        <p>See the requests, drafts, assignments, owned SOPs, reviews, and overdue work tied to the current Creator / Reviewer sub-role.</p>
      </div>
      <AppIllustration name="work" size="md" />
    </div>

    <div class="form-grid work-user-panel">
      <div class="field">
        <label for="current-user">View work for</label>
        <select id="current-user">
          <option value="">Loading backend users...</option>
        </select>
      </div>
      <div class="field">
        <label>Current work scope</label>
        <input id="current-access-level" type="text" readonly value="Loading..." />
      </div>
    </div>

    <div class="stat-grid user-summary" aria-label="My work summary">
      <a
        class="stat-card work-summary-card"
        href="/my-work/?workFilter=submitted#work-section-submitted"
        data-work-summary-link
        data-work-filter="submitted"
        aria-label="View submitted requests for the current work scope"
      >
        <span>Submitted requests</span>
        <strong id="count-submitted">0</strong>
      </a>
      <a
        class="stat-card work-summary-card"
        href="/drafts/?source=my-work"
        data-work-summary-link
        data-work-filter="drafts"
        aria-label="View draft SOPs for the current work scope"
      >
        <span>Draft SOPs</span>
        <strong id="count-drafts">0</strong>
      </a>
      <a
        class="stat-card work-summary-card"
        href="/my-work/?workFilter=assigned#work-section-assigned"
        data-work-summary-link
        data-work-filter="assigned"
        aria-label="View SOPs assigned to the current team"
      >
        <span>Assigned to team</span>
        <strong id="count-assigned">0</strong>
      </a>
      <a
        class="stat-card work-summary-card"
        href="/admin/review/?filter=review-needed"
        data-work-summary-link
        data-work-filter="review"
        aria-label="View team reviews needed for the current work scope"
      >
        <span>Team reviews needed</span>
        <strong id="count-review">0</strong>
      </a>
      <a
        class="stat-card work-summary-card"
        href="/admin/review/?filter=overdue"
        data-work-summary-link
        data-work-filter="overdue"
        aria-label="View overdue team reviews for the current work scope"
      >
        <span>Team overdue reviews</span>
        <strong id="count-overdue">0</strong>
      </a>
    </div>
    <p class="work-summary-status" id="work-summary-status" role="status" aria-live="polite"></p>

    <div class="work-grid">
      <section class="dashboard-section work-section" id="work-section-submitted" data-work-section="submitted" aria-labelledby="submitted-heading">
        <h2 id="submitted-heading">My Submitted Requests</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Request</th>
                <th scope="col">Status</th>
                <th scope="col">Priority</th>
                <th scope="col">Updated</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody id="submitted-list"></tbody>
          </table>
        </div>
      </section>

      <section class="dashboard-section work-section" id="work-section-drafts" data-work-section="drafts" aria-labelledby="drafts-heading">
        <h2 id="drafts-heading">My Draft SOPs</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Draft</th>
                <th scope="col">Status</th>
                <th scope="col">Review Date</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody id="draft-list"></tbody>
          </table>
        </div>
      </section>

      <section class="dashboard-section work-section" id="work-section-assigned" data-work-section="assigned" aria-labelledby="assigned-heading">
        <h2 id="assigned-heading">SOPs Assigned to Me</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Item</th>
                <th scope="col">Status</th>
                <th scope="col">Review Date</th>
                <th scope="col">Owner</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody id="assigned-list"></tbody>
          </table>
        </div>
      </section>

      <section class="dashboard-section work-section" id="work-section-owned" data-work-section="owned" aria-labelledby="owned-heading">
        <h2 id="owned-heading">SOPs I Own</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">SOP</th>
                <th scope="col">Category</th>
                <th scope="col">Status</th>
                <th scope="col">Review Date</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody id="owned-list"></tbody>
          </table>
        </div>
      </section>

      <section class="dashboard-section work-section" id="work-section-review" data-work-section="review" aria-labelledby="review-heading">
        <h2 id="review-heading">SOPs Needing My Review</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Item</th>
                <th scope="col">Status</th>
                <th scope="col">Priority</th>
                <th scope="col">Due</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody id="review-list"></tbody>
          </table>
        </div>
      </section>

      <section class="dashboard-section work-section" id="work-section-overdue" data-work-section="overdue" aria-labelledby="overdue-heading">
        <h2 id="overdue-heading">Overdue Reviews</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">SOP</th>
                <th scope="col">Owner</th>
                <th scope="col">Review Date</th>
                <th scope="col">Status</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody id="overdue-list"></tbody>
          </table>
        </div>
      </section>
    </div>
  </section>
</Layout>

<script is:inline type="application/json" id="my-work-data-json" set:html={JSON.stringify({
  priorityBadgeDefinitions,
  statusBadgeDefinitions,
})}></script>

<script>
  // @ts-nocheck
  const ROLE_CONTEXT_EVENT = "sop-role-context-change";
  const SUB_ROLE_KEY = "sopHubSelectedCreatorSubRole";
  const WORK_SCOPE_KEY = "sopHubMyWorkScope";
  const currentUserSelect = document.getElementById("current-user");
  const currentAccessLevel = document.getElementById("current-access-level");
  const workSummaryLinks = Array.from(document.querySelectorAll("[data-work-summary-link]"));
  const workSummaryStatus = document.getElementById("work-summary-status");
  const tableIds = ["submitted-list", "draft-list", "assigned-list", "owned-list", "review-list", "overdue-list"];
  const workFilterLabels = {
    submitted: "submitted requests",
    drafts: "draft SOPs",
    assigned: "team assignments",
    review: "team reviews needed",
    overdue: "overdue team reviews",
  };
  let activeRequestId = 0;
  let selectedScope = "";

  function readJson(id, fallback) {
    const element = document.getElementById(id);
    if (!element?.textContent) return fallback;
    try {
      return JSON.parse(element.textContent);
    } catch {
      return fallback;
    }
  }

  const myWorkData = readJson("my-work-data-json", {});
  const priorityBadgeDefinitions = myWorkData.priorityBadgeDefinitions || {};
  const statusBadgeDefinitions = myWorkData.statusBadgeDefinitions || {};

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function formatDateClient(value) {
    if (!value) return "Not set";
    const date = new Date(`${String(value).slice(0, 10)}T00:00:00`);
    if (Number.isNaN(date.getTime())) return value;
    return new Intl.DateTimeFormat("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    }).format(date);
  }

  function actionButton(href, label) {
    return `<a class="button button--secondary" href="${escapeHtml(href)}">${escapeHtml(label)}</a>`;
  }

  function badge(definitions, value, fallbackLabel, fallbackClass, baseClass) {
    const key = String(value || "").toLowerCase().replace(/[^a-z0-9]+/g, "-");
    const definition = definitions[key] || {
      label: value || fallbackLabel,
      className: fallbackClass,
    };
    return `<span class="badge ${escapeHtml(baseClass)} ${escapeHtml(definition.className)}">${escapeHtml(definition.label)}</span>`;
  }

  function statusBadge(status) {
    return badge(statusBadgeDefinitions, status, "New", "status-badge--new", "status-badge");
  }

  function priorityBadge(priority) {
    return badge(priorityBadgeDefinitions, priority, "Medium", "priority-badge--medium", "priority-badge");
  }

  function renderRows(id, rows, columns, emptyText) {
    const list = document.getElementById(id);
    if (!list) return;

    list.innerHTML = rows.length
      ? rows
          .map(
            (row) => `
              <tr>
                ${columns.map((column) => `<td>${column(row)}</td>`).join("")}
              </tr>
            `,
          )
          .join("")
      : `<tr><td colspan="${columns.length}"><div class="empty-state empty-state--table"><strong>No work here</strong><p>${escapeHtml(emptyText)}</p></div></td></tr>`;
  }

  function setCount(id, value) {
    const element = document.getElementById(id);
    if (element) element.textContent = String(Number(value || 0));
  }

  function updateWorkSummaryLabels() {
    const scopeLabel = currentAccessLevel instanceof HTMLInputElement ? currentAccessLevel.value : "current work scope";
    workSummaryLinks.forEach((link) => {
      const filter = link instanceof HTMLElement ? link.dataset.workFilter || "" : "";
      const count = link.querySelector("strong")?.textContent?.trim() || "0";
      const label = workFilterLabels[filter] || "work records";
      link.setAttribute("aria-label", `View ${count} ${label} for ${scopeLabel}`);
    });
  }

  function preserveWorkScope() {
    if (!selectedScope) return;
    try {
      sessionStorage.setItem(WORK_SCOPE_KEY, selectedScope);
    } catch {
      // Session storage is a convenience for navigation only; the API still validates the scope.
    }
  }

  function requestedWorkFilter() {
    const params = new URLSearchParams(window.location.search);
    const filter = params.get("workFilter") || "";
    return Object.prototype.hasOwnProperty.call(workFilterLabels, filter) ? filter : "";
  }

  function focusRequestedWorkSection() {
    const filter = requestedWorkFilter();
    if (!filter) {
      if (workSummaryStatus) workSummaryStatus.textContent = "";
      return;
    }
    const section = document.querySelector(`[data-work-section="${CSS.escape(filter)}"]`);
    const label = workFilterLabels[filter] || "work records";
    workSummaryLinks.forEach((link) => {
      link.toggleAttribute("aria-current", link instanceof HTMLElement && link.dataset.workFilter === filter);
    });
    if (workSummaryStatus) {
      workSummaryStatus.textContent = `Showing ${label} for the selected work scope.`;
    }
    if (section instanceof HTMLElement) {
      section.setAttribute("tabindex", "-1");
      requestAnimationFrame(() => {
        section.scrollIntoView({ behavior: "smooth", block: "start" });
        section.focus({ preventScroll: true });
      });
    }
  }

  function clearDashboard(message = "Loading backend work records...") {
    setCount("count-submitted", 0);
    setCount("count-drafts", 0);
    setCount("count-assigned", 0);
    setCount("count-review", 0);
    setCount("count-overdue", 0);
    tableIds.forEach((id) => {
      const list = document.getElementById(id);
      if (list) {
        list.innerHTML = `<tr><td colspan="5"><div class="empty-state empty-state--table"><strong>Loading</strong><p>${escapeHtml(message)}</p></div></td></tr>`;
      }
    });
  }

  function parseScopeValue(value) {
    const raw = String(value || "");
    if (raw.startsWith("user:")) {
      return { scope: "user", userId: raw.slice(5) };
    }
    return { scope: raw || "team", userId: "" };
  }

  function currentScopeValue(context) {
    if (context?.workScope === "user" && context?.selectedUser?.id) {
      return `user:${context.selectedUser.id}`;
    }
    return context?.workScope || "team";
  }

  function renderUserOptions(payload) {
    if (!(currentUserSelect instanceof HTMLSelectElement)) return;
    const context = payload.context || {};
    const scopes = payload.viewOptions?.scopes || [];
    if (!scopes.length) {
      currentUserSelect.innerHTML = `<option value="">No authorized work scopes</option>`;
      selectedScope = "";
      return;
    }

    const nextSelectedScope = currentScopeValue(context);
    selectedScope = nextSelectedScope;
    currentUserSelect.innerHTML = scopes
      .map(
        (scope) =>
          `<option value="${escapeHtml(scope.id)}" ${scope.id === nextSelectedScope ? "selected" : ""}>${escapeHtml(
            scope.label,
          )}</option>`,
      )
      .join("");
  }

  function renderDashboard(payload) {
    const counts = payload.counts || {};
    const sections = payload.sections || {};
    const context = payload.context || {};

    renderUserOptions(payload);
    if (currentAccessLevel instanceof HTMLInputElement) {
      currentAccessLevel.value = context.workScopeLabel || context.accessLevel || "Creator / Reviewer";
      currentAccessLevel.title = context.workScopeDescription || "";
    }

    setCount("count-submitted", counts.submittedRequests);
    setCount("count-drafts", counts.draftSops);
    setCount("count-assigned", counts.assignedToTeam ?? counts.assignedToMe);
    setCount("count-review", counts.teamReviewsNeeded ?? counts.needMyReview);
    setCount("count-overdue", counts.overdueReviews);
    updateWorkSummaryLabels();

    renderRows(
      "submitted-list",
      sections.submittedRequests || [],
      [
        (item) => escapeHtml(item.title),
        (item) => statusBadge(item.status),
        (item) => priorityBadge(item.priority),
        (item) => escapeHtml(formatDateClient(item.updatedDate)),
        (item) => actionButton(item.url || `/admin/review/?request=${encodeURIComponent(item.id)}`, "Review Request"),
      ],
      "No backend SOP requests are assigned to this sub-role or selected user.",
    );

    renderRows(
      "draft-list",
      sections.draftSops || [],
      [
        (item) => escapeHtml(item.title),
        (item) => statusBadge(item.status),
        (item) => escapeHtml(formatDateClient(item.reviewDate)),
        (item) => actionButton(item.editUrl || `/create/?edit=draft&id=${encodeURIComponent(item.id)}`, "Edit Draft"),
      ],
      "No backend draft SOPs are owned by this sub-role or selected user.",
    );

    renderRows(
      "assigned-list",
      sections.assignedItems || [],
      [
        (item) => escapeHtml(item.title),
        (item) => statusBadge(item.status),
        (item) => escapeHtml(formatDateClient(item.reviewDate)),
        (item) => escapeHtml(item.owner || "Unassigned"),
        (item) => actionButton(item.url || "/admin/needs-review/", "Open Item"),
      ],
      "No backend SOPs are assigned to this sub-role or selected user.",
    );

    renderRows(
      "owned-list",
      sections.ownedSops || [],
      [
        (item) => `<a href="${escapeHtml(item.url)}">${escapeHtml(item.title)}</a>`,
        (item) => escapeHtml(item.category || "Uncategorized"),
        (item) => statusBadge(item.status),
        (item) => escapeHtml(formatDateClient(item.reviewDate)),
        (item) => actionButton(item.editUrl || `/create/?edit=draft&id=${encodeURIComponent(item.id)}&origin=owned-sops`, "Edit SOP"),
      ],
      "No backend SOPs are owned by this selected sub-role.",
    );

    renderRows(
      "review-list",
      sections.reviewItems || [],
      [
        (item) => escapeHtml(item.title),
        (item) => statusBadge(item.status),
        (item) => priorityBadge(item.priority || "Medium"),
        (item) => escapeHtml(formatDateClient(item.reviewDate)),
        (item) => actionButton(item.url || "/admin/needs-review/", "Open Review"),
      ],
      "No backend SOPs currently need review for this sub-role or selected user.",
    );

    renderRows(
      "overdue-list",
      sections.overdueReviews || [],
      [
        (item) => (item.url ? `<a href="${escapeHtml(item.url)}">${escapeHtml(item.title)}</a>` : escapeHtml(item.title)),
        (item) => escapeHtml(item.owner || "Unassigned"),
        (item) => escapeHtml(formatDateClient(item.reviewDate)),
        () => statusBadge("Past Due"),
        (item) => actionButton(item.url || "/admin/needs-review/", "Open Review"),
      ],
      "No backend overdue reviews for this sub-role or selected user.",
    );
    focusRequestedWorkSection();
  }

  async function loadMyWork({ preserveUser = false } = {}) {
    const requestId = ++activeRequestId;
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    const params = new URLSearchParams();
    if (!preserveUser) {
      try {
        const savedScope = sessionStorage.getItem(WORK_SCOPE_KEY) || "";
        if (savedScope) {
          selectedScope = savedScope;
          preserveUser = true;
        }
      } catch {
        // Ignore unavailable session storage.
      }
    }
    if (preserveUser && selectedScope) {
      const parsedScope = parseScopeValue(selectedScope);
      params.set("scope", parsedScope.scope);
      if (parsedScope.userId) params.set("userId", parsedScope.userId);
    } else {
      params.set("scope", "team");
    }
    if (subRole) params.set("subRole", subRole);

    clearDashboard();

    try {
      const response = await fetch(`/api/my-work?${params.toString()}`, {
        headers: {
          accept: "application/json",
          ...(subRole ? { "x-sop-sub-role": subRole } : {}),
        },
        cache: "no-store",
      });
      const data = await response.json().catch(() => ({}));
      if (requestId !== activeRequestId) return;
      if (!response.ok || data?.success === false) {
        throw new Error(data?.error?.message || "The My Work dashboard could not load.");
      }
      renderDashboard(data.data || data);
    } catch (error) {
      if (requestId !== activeRequestId) return;
      clearDashboard(error instanceof Error ? error.message : "The My Work dashboard could not load.");
      if (currentAccessLevel instanceof HTMLInputElement) currentAccessLevel.value = "Unavailable";
      if (currentUserSelect instanceof HTMLSelectElement) {
        currentUserSelect.innerHTML = `<option value="">Backend users unavailable</option>`;
      }
    }
  }

  currentUserSelect?.addEventListener("change", () => {
    selectedScope = currentUserSelect instanceof HTMLSelectElement ? currentUserSelect.value : "";
    preserveWorkScope();
    loadMyWork({ preserveUser: true });
  });

  workSummaryLinks.forEach((link) => {
    link.addEventListener("click", preserveWorkScope);
  });

  window.addEventListener(ROLE_CONTEXT_EVENT, (event) => {
    const detail = event instanceof CustomEvent ? event.detail || {} : {};
    if (detail.previousSubRole !== detail.subRole || detail.previousRole !== detail.role) {
      selectedScope = "";
      try {
        sessionStorage.removeItem(WORK_SCOPE_KEY);
      } catch {
        // Ignore unavailable session storage.
      }
      loadMyWork();
    }
  });

  loadMyWork();
</script>
