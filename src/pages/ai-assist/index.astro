---
import Layout from "../../components/Layout.astro";

const assistActions = [
  {
    id: "ask",
    title: "Ask AI Assist",
    description: "Ask a source-grounded question about an authorized SOP.",
  },
  {
    id: "draft-sop",
    title: "Draft SOP",
    description: "Turn notes and selected source material into a draft starter.",
  },
  {
    id: "improve-draft",
    title: "Improve Draft",
    description: "Tighten wording, order, and clarity without inventing facts.",
  },
  {
    id: "summarize-sop",
    title: "Summarize SOP",
    description: "Create a short summary from the selected backend SOP.",
  },
  {
    id: "review-gaps",
    title: "Review Gaps",
    description: "Flag missing steps, owners, risks, and review needs.",
  },
  {
    id: "review-comments",
    title: "Review Comments",
    description: "Draft review comments for an SOP, draft, or request.",
  },
  {
    id: "suggest-taxonomy",
    title: "Suggest Tags / Category",
    description: "Suggest searchable tags and category signals from real source data.",
  },
];
---

<Layout title="AI Assist" wide>
  <section class="tool-surface" aria-labelledby="ai-assist-heading">
    <div class="section-heading">
      <p class="eyebrow">Controlled AI</p>
      <h1 id="ai-assist-heading">AI Assist</h1>
      <p>
        Use Cloudflare Workers AI for SOP drafting, cleanup, review, and discovery. Every
        answer is limited to the backend records available to your current role and department.
      </p>
    </div>

    <div class="analytics-note ai-policy" role="note">
      <strong>Source rule:</strong>
      <span id="source-rule">Loading authorized SOP sources...</span>
    </div>

    <div class="form-grid ai-control-panel" aria-label="AI Assist controls">
      <div class="field">
        <label for="assist-role">Using AI Assist as</label>
        <select id="assist-role" disabled>
          <option>Loading role...</option>
        </select>
      </div>
      <div class="field">
        <label for="assist-source">Primary source</label>
        <select id="assist-source" disabled>
          <option>Loading sources...</option>
        </select>
      </div>
      <div class="field field--full">
        <label for="assist-notes">Notes, question, or draft text</label>
        <textarea
          id="assist-notes"
          rows="5"
          maxlength="4000"
          placeholder="Paste notes, ask a question, or describe the SOP you want help with."
        ></textarea>
      </div>
    </div>

    <section class="dashboard-section" aria-labelledby="ai-actions-heading">
      <h2 id="ai-actions-heading">AI Assist Actions</h2>
      <div class="quick-link-grid ai-action-grid" id="assist-actions">
        {assistActions.map((action) => (
          <button class="quick-link quick-link--panel role-card" type="button" data-assist-action={action.id} disabled>
            <strong>{action.title}</strong>
            <span>{action.description}</span>
          </button>
        ))}
      </div>
    </section>

    <section class="dashboard-section ai-output" aria-labelledby="ai-output-heading">
      <div class="section-heading">
        <h2 id="ai-output-heading">AI Assist Output</h2>
        <p id="source-summary">Select an action after the backend sources load.</p>
      </div>
      <div class="sop-content" id="assist-output" aria-live="polite">
        <p>Loading authorized backend sources...</p>
      </div>
    </section>
  </section>
</Layout>

<script>
  // @ts-nocheck
  const SUB_ROLE_KEY = "sopHubSelectedCreatorSubRole";
  const sourceSelect = document.getElementById("assist-source");
  const roleSelect = document.getElementById("assist-role");
  const notesInput = document.getElementById("assist-notes");
  const actions = document.getElementById("assist-actions");
  const output = document.getElementById("assist-output");
  const sourceRule = document.getElementById("source-rule");
  const sourceSummary = document.getElementById("source-summary");

  let sources = [];
  let currentUser = null;
  let activeRequestId = 0;
  let selectedSubRole = readSelectedSubRole();

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  const markdownishToHtml = (value) => {
    const lines = String(value || "").split(/\n/);
    const html = [];
    let listOpen = false;

    for (const rawLine of lines) {
      const line = rawLine.trim();
      if (!line) {
        if (listOpen) {
          html.push("</ul>");
          listOpen = false;
        }
        continue;
      }

      const heading = line.match(/^#{1,4}\s+(.+)/);
      if (heading) {
        if (listOpen) {
          html.push("</ul>");
          listOpen = false;
        }
        html.push(`<h3>${escapeHtml(heading[1])}</h3>`);
        continue;
      }

      const bullet = line.match(/^[-*]\s+(.+)/) || line.match(/^\d+\.\s+(.+)/);
      if (bullet) {
        if (!listOpen) {
          html.push("<ul>");
          listOpen = true;
        }
        html.push(`<li>${escapeHtml(bullet[1])}</li>`);
        continue;
      }

      if (listOpen) {
        html.push("</ul>");
        listOpen = false;
      }
      html.push(`<p>${escapeHtml(line)}</p>`);
    }

    if (listOpen) html.push("</ul>");
    return html.join("");
  };

  function readSelectedSubRole() {
    try {
      return localStorage.getItem(SUB_ROLE_KEY) || "";
    } catch {
      return "";
    }
  }

  function selectedSubRoleQuery() {
    const value = readSelectedSubRole();
    return value ? `?subRole=${encodeURIComponent(value)}` : "";
  }

  function apiHeaders() {
    const headers = {
      "content-type": "application/json",
      "cache-control": "no-store",
    };
    const subRole = readSelectedSubRole();
    if (subRole) headers["x-sop-sub-role"] = subRole;
    return headers;
  }

  function setActionsEnabled(enabled) {
    actions?.querySelectorAll("[data-assist-action]").forEach((button) => {
      button.disabled = !enabled;
    });
  }

  function setOutput(html) {
    if (output) output.innerHTML = html;
  }

  function renderRoleOptions(roleOptions = []) {
    if (!(roleSelect instanceof HTMLSelectElement)) return;
    const selectedSubRoleLabel = currentUser?.selectedSubRole?.label;
    roleSelect.innerHTML = roleOptions.length
      ? roleOptions
          .map((option) => {
            const label = selectedSubRoleLabel ? `${option.label} - ${selectedSubRoleLabel}` : option.label;
            return `<option value="${escapeHtml(option.id)}" selected>${escapeHtml(label)}</option>`;
          })
          .join("")
      : `<option>Normal User</option>`;
  }

  function renderSourceOptions() {
    if (!(sourceSelect instanceof HTMLSelectElement)) return;

    if (!sources.length) {
      sourceSelect.innerHTML = `<option value="">No authorized SOP sources found</option>`;
      sourceSelect.disabled = true;
      return;
    }

    sourceSelect.innerHTML = [
      `<option value="">Use notes only</option>`,
      ...sources.map(
        (source) => `
          <option value="${escapeHtml(source.id)}">
            ${escapeHtml(source.title)} (${escapeHtml(source.status || "SOP")})
          </option>
        `,
      ),
    ].join("");
    sourceSelect.disabled = false;
  }

  function renderLoadedState(payload) {
    sources = payload.sources || [];
    currentUser = payload.currentUser || null;
    renderRoleOptions(payload.roleOptions || []);
    renderSourceOptions();

    if (sourceRule) {
      sourceRule.textContent = payload.sourcePolicy || "Only authorized backend SOP records are available.";
    }
    if (sourceSummary) {
      const subRole = currentUser?.selectedSubRole?.label ? ` for ${currentUser.selectedSubRole.label}` : "";
      sourceSummary.textContent = `${sources.length} backend source${sources.length === 1 ? "" : "s"} available${subRole}.`;
    }

    setActionsEnabled(true);
    setOutput(
      sources.length
        ? "<p>Select a source or use notes only, then choose an AI Assist action.</p>"
        : "<p>No authorized SOP sources are available for this role. You can still provide notes and ask AI Assist to help identify what information is missing.</p>",
    );
  }

  function renderError(message) {
    setActionsEnabled(false);
    if (sourceRule) sourceRule.textContent = "AI Assist could not load authorized backend sources.";
    if (sourceSummary) sourceSummary.textContent = "";
    if (sourceSelect instanceof HTMLSelectElement) {
      sourceSelect.innerHTML = `<option value="">Sources unavailable</option>`;
      sourceSelect.disabled = true;
    }
    setOutput(`<div class="form-status form-status--error">${escapeHtml(message)}</div>`);
  }

  async function loadAssistOptions() {
    const requestId = ++activeRequestId;
    setActionsEnabled(false);
    setOutput("<p>Loading authorized backend sources...</p>");

    try {
      const response = await fetch(`/api/ai-assist${selectedSubRoleQuery()}`, {
        headers: apiHeaders(),
        cache: "no-store",
      });
      const payload = await response.json();
      if (requestId !== activeRequestId) return;
      if (!response.ok || !payload.success) {
        throw new Error(payload.error?.message || "AI Assist sources could not be loaded.");
      }
      renderLoadedState(payload.data || {});
    } catch (error) {
      if (requestId !== activeRequestId) return;
      renderError(error.message || "AI Assist sources could not be loaded.");
    }
  }

  function selectedSourceId() {
    return sourceSelect instanceof HTMLSelectElement ? sourceSelect.value : "";
  }

  function userNotes() {
    return notesInput instanceof HTMLTextAreaElement ? notesInput.value.trim() : "";
  }

  function renderAssistResult(data) {
    const source = data.source;
    const sourceHtml = source
      ? `<p class="ai-source-line">Source: <a href="${escapeHtml(source.url || "#")}">${escapeHtml(source.title)}</a> <span class="status-badge">${escapeHtml(source.status)}</span></p>`
      : `<p class="ai-source-line">Source: User notes only</p>`;
    const nextAction = data.suggestedNextAction
      ? `<p><strong>Suggested next action:</strong> ${escapeHtml(data.suggestedNextAction)}</p>`
      : "";
    const limitation = data.limitation ? `<p><strong>Grounding:</strong> ${escapeHtml(data.limitation)}</p>` : "";

    setOutput(`
      ${sourceHtml}
      <div class="ai-answer">${markdownishToHtml(data.answer || "No response was returned.")}</div>
      ${limitation}
      ${nextAction}
      <div class="form-actions">
        ${source ? `<a class="button button--secondary" href="${escapeHtml(source.url)}">Open Source</a>` : ""}
        ${data.action === "draft-sop" ? `<a class="button button--secondary" href="/create/">Open Create SOP</a>` : ""}
      </div>
    `);
  }

  async function runAction(action) {
    if (!action) return;
    const requestId = ++activeRequestId;
    const sourceId = selectedSourceId();
    const prompt = userNotes();

    if (!sourceId && !prompt) {
      setOutput(`<div class="form-status form-status--error">Choose a source or enter notes before using AI Assist.</div>`);
      return;
    }

    setActionsEnabled(false);
    setOutput("<p>AI Assist is reviewing authorized backend data...</p>");

    try {
      const response = await fetch(`/api/ai-assist${selectedSubRoleQuery()}`, {
        method: "POST",
        headers: apiHeaders(),
        cache: "no-store",
        body: JSON.stringify({ action, sourceId, prompt }),
      });
      const payload = await response.json();
      if (requestId !== activeRequestId) return;
      if (!response.ok || !payload.success) {
        throw new Error(payload.error?.message || "AI Assist could not complete that action.");
      }
      renderAssistResult(payload.data || {});
    } catch (error) {
      if (requestId !== activeRequestId) return;
      setOutput(`<div class="form-status form-status--error">${escapeHtml(error.message || "AI Assist could not complete that action.")}</div>`);
    } finally {
      if (requestId === activeRequestId) setActionsEnabled(true);
    }
  }

  actions?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest("[data-assist-action]");
    if (!(button instanceof HTMLElement) || button.hasAttribute("disabled")) return;
    runAction(button.dataset.assistAction);
  });

  function maybeReloadForSubRoleChange() {
    const next = readSelectedSubRole();
    if (next === selectedSubRole) return;
    selectedSubRole = next;
    sources = [];
    loadAssistOptions();
  }

  window.addEventListener("storage", (event) => {
    if (event.key === SUB_ROLE_KEY) maybeReloadForSubRoleChange();
  });
  window.addEventListener("sop-role-change", maybeReloadForSubRoleChange);
  window.addEventListener("sop-sub-role-change", maybeReloadForSubRoleChange);
  document.addEventListener("visibilitychange", () => {
    if (!document.hidden) maybeReloadForSubRoleChange();
  });

  loadAssistOptions();
</script>
