---
import Layout from "../components/Layout.astro";
import AppIcon from "../components/AppIcon.astro";
import SopCard from "../components/SopCard.astro";
import { PUBLISHED_SOPS_STORAGE_KEY } from "../lib/drafts";
import { getAllSops, getSopUrl } from "../lib/sops";
import { uniqueSorted } from "../lib/search";

const sops = await getAllSops();
const initialQuery = Astro.url.searchParams.get("q") ?? "";
const categories = uniqueSorted(sops.map((sop) => sop.data.category));
const tools = uniqueSorted(sops.flatMap((sop) => sop.data.tools));
const owners = uniqueSorted(sops.map((sop) => sop.data.owner));
const statuses = uniqueSorted(sops.map((sop) => sop.data.status));
const tags = uniqueSorted(sops.flatMap((sop) => sop.data.tags));
const recentlyViewedSop = sops.find((sop) => sop.data.id === "sop-ivanti-submit-ticket") ?? sops[0];
const popularSop = sops.find((sop) => sop.data.category === "QA Processes") ?? sops[1] ?? sops[0];
const popularSearches = [
  "D2L course copy",
  "Ivanti ticket",
  "Course QA checklist",
  "New employee onboarding",
  "Gradebook export",
];
---

<Layout title="Search SOPs" wide>
  <section class="page-section search-dashboard-page" aria-labelledby="search-page-title">
    <div class="search-page-hero">
      <div class="search-page-hero__content">
        <p class="eyebrow">Search</p>
        <h1 id="search-page-title">Search SOPs</h1>
        <p>
          Find the process, guide, or template you need quickly. Use keywords or filters to narrow
          your results.
        </p>
        <div class="search-page-hero__features" aria-label="Search benefits">
          <div class="search-page-feature">
            <span class="search-page-feature__icon search-page-feature__icon--blue" aria-hidden="true">
              <AppIcon name="search" />
            </span>
            <span>
              <strong>Search everything</strong>
              <small>Titles, tags, tools, owners, and more</small>
            </span>
          </div>
          <div class="search-page-feature">
            <span class="search-page-feature__icon search-page-feature__icon--green" aria-hidden="true">
              <AppIcon name="settings" />
            </span>
            <span>
              <strong>Refine your results</strong>
              <small>Use filters to find exactly what you need</small>
            </span>
          </div>
          <div class="search-page-feature">
            <span class="search-page-feature__icon search-page-feature__icon--purple" aria-hidden="true">
              <AppIcon name="tags" />
            </span>
            <span>
              <strong>Save for later</strong>
              <small>Bookmark and revisit important SOPs</small>
            </span>
          </div>
        </div>
      </div>
      <div class="search-page-hero__visual" aria-hidden="true">
        <div class="search-visual">
          <span class="search-visual__spark search-visual__spark--left">+</span>
          <span class="search-visual__spark search-visual__spark--right">+</span>
          <div class="search-visual__document">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="search-visual__window">
            <div class="search-visual__bar"><span></span><span></span><span></span></div>
            <div class="search-visual__search-line"></div>
            <div class="search-visual__line search-visual__line--wide"></div>
            <div class="search-visual__line"></div>
            <div class="search-visual__line search-visual__line--short"></div>
          </div>
          <svg class="search-visual__magnifier" viewBox="0 0 170 170" focusable="false" aria-hidden="true">
            <defs>
              <linearGradient id="searchMagnifierHandle" x1="96" y1="96" x2="154" y2="154" gradientUnits="userSpaceOnUse">
                <stop stop-color="#17386f" />
                <stop offset="1" stop-color="#2f6fed" />
              </linearGradient>
              <radialGradient id="searchMagnifierGlass" cx="35%" cy="30%" r="65%">
                <stop stop-color="#ffffff" />
                <stop offset="0.58" stop-color="#f8fbff" stop-opacity="0.88" />
                <stop offset="1" stop-color="#dce9fb" stop-opacity="0.72" />
              </radialGradient>
            </defs>
            <path class="search-visual__handle" d="M101 101h0c5.3-5.3 13.8-5.3 19.1 0l36 36c5.3 5.3 5.3 13.8 0 19.1h0c-5.3 5.3-13.8 5.3-19.1 0l-36-36c-5.3-5.3-5.3-13.8 0-19.1Z" />
            <circle class="search-visual__lens" cx="67" cy="67" r="52" />
            <circle class="search-visual__handle-joint" cx="103" cy="103" r="14" />
            <path class="search-visual__shine" d="M45 44c10-11 27-14 42-8" />
          </svg>
          <div class="search-visual__checklist">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      </div>
    </div>

    <div class="search-filter-panel no-print">
      <form class="search-filters search-filters--dashboard" id="sop-search-form">
        <div class="field field--full search-query-field">
          <label for="search-query">Search</label>
          <div class="search-query-row">
            <span aria-hidden="true"><AppIcon name="search" /></span>
            <input
              id="search-query"
              type="search"
              value={initialQuery}
              autocomplete="off"
              placeholder="Search by title, tag, tool, owner, category, or keyword..."
            />
            <button class="button button--ghost search-tips-button" type="button">
              <AppIcon name="ai" />
              Search tips
            </button>
          </div>
        </div>
        <div class="search-filter-grid field--full">
          <div class="field">
            <label for="filter-category">Category</label>
            <div class="select-with-icon">
              <span aria-hidden="true"><AppIcon name="categories" /></span>
              <select id="filter-category">
                <option value="">All categories</option>
                {categories.map((category) => <option value={category}>{category}</option>)}
              </select>
            </div>
          </div>
          <div class="field">
            <label for="filter-tool">Tool</label>
            <div class="select-with-icon">
              <span aria-hidden="true"><AppIcon name="settings" /></span>
              <select id="filter-tool">
                <option value="">All tools</option>
                {tools.map((tool) => <option value={tool}>{tool}</option>)}
              </select>
            </div>
          </div>
          <div class="field">
            <label for="filter-owner">Owner</label>
            <div class="select-with-icon">
              <span aria-hidden="true"><AppIcon name="users" /></span>
              <select id="filter-owner">
                <option value="">All owners</option>
                {owners.map((owner) => <option value={owner}>{owner}</option>)}
              </select>
            </div>
          </div>
          <div class="field">
            <label for="filter-status">Status</label>
            <div class="select-with-icon">
              <span aria-hidden="true"><AppIcon name="qa" /></span>
              <select id="filter-status">
                <option value="">All statuses</option>
                {statuses.map((status) => <option value={status}>{status}</option>)}
              </select>
            </div>
          </div>
          <div class="field">
            <label for="filter-tag">Tag</label>
            <div class="select-with-icon">
              <span aria-hidden="true"><AppIcon name="tags" /></span>
              <select id="filter-tag">
                <option value="">All tags</option>
                {tags.map((tag) => <option value={tag}>{tag}</option>)}
              </select>
            </div>
          </div>
          <div class="field">
            <label for="filter-updated">Last updated</label>
            <div class="select-with-icon">
              <span aria-hidden="true"><AppIcon name="analytics" /></span>
              <select id="filter-updated">
                <option value="">Any time</option>
                <option value="30">Past 30 days</option>
                <option value="90">Past 90 days</option>
                <option value="180">Past 6 months</option>
              </select>
            </div>
          </div>
        </div>
        <div class="search-filter-actions field--full">
          <button class="button button--text" type="reset">
            <AppIcon name="finder" />
            Clear all filters
          </button>
          <div>
            <button class="button button--ghost" type="button">
              <AppIcon name="tags" />
              Save search
            </button>
            <button class="button button--primary" type="submit">
              <AppIcon name="search" />
              Search SOPs
            </button>
          </div>
        </div>
      </form>
      <div class="popular-searches" aria-label="Popular searches">
        <strong><AppIcon name="analytics" /> Popular searches</strong>
        <div class="popular-searches__pills">
          {
            popularSearches.map((searchTerm) => (
              <a href={`/search/?q=${encodeURIComponent(searchTerm)}`}>
                <AppIcon name="search" />
                {searchTerm}
              </a>
            ))
          }
        </div>
        <a class="popular-searches__view-all" href="/admin/analytics/">View all</a>
      </div>
    </div>

    <div class="search-helper-grid no-print" aria-label="Search shortcuts">
      <a class="search-helper-card" href={recentlyViewedSop ? getSopUrl(recentlyViewedSop) : "/search/"}>
        <span class="search-helper-card__icon search-helper-card__icon--green" aria-hidden="true">
          <AppIcon name="tags" />
        </span>
        <span>
          <strong>Recently viewed</strong>
          <small>
            {recentlyViewedSop ? `Continue with ${recentlyViewedSop.data.title}` : "Continue where you left off"}
          </small>
        </span>
        <span aria-hidden="true">-&gt;</span>
      </a>
      <a class="search-helper-card" href={popularSop ? getSopUrl(popularSop) : "/search/"}>
        <span class="search-helper-card__icon search-helper-card__icon--blue" aria-hidden="true">
          <AppIcon name="analytics" />
        </span>
        <span>
          <strong>Popular this week</strong>
          <small>{popularSop ? popularSop.data.title : "Most viewed by your team"}</small>
        </span>
        <span aria-hidden="true">-&gt;</span>
      </a>
      <a class="search-helper-card search-helper-card--request" href="/submit/">
        <span class="search-helper-card__icon search-helper-card__icon--purple" aria-hidden="true">
          <AppIcon name="support" />
        </span>
        <span>
          <strong>Can't find what you need?</strong>
          <small>Request a new SOP</small>
        </span>
        <span aria-hidden="true">-&gt;</span>
      </a>
    </div>

    <p class="result-count" id="result-count"></p>
    <div class="empty-state empty-state--search" id="search-empty" hidden>
      <strong>No SOPs found</strong>
      <p>Try clearing a filter or searching by a broader tool, tag, owner, or keyword.</p>
    </div>
    <div class="sop-grid" id="search-results">
      {
        sops.map((sop) => (
          <div
            data-search-card
            data-sop-id={sop.data.id}
            data-category={sop.data.category}
            data-tools={sop.data.tools.join("|")}
            data-owner={sop.data.owner}
            data-status={sop.data.status}
            data-tags={sop.data.tags.join("|")}
            data-updated={sop.data.lastUpdated}
            data-search={`${sop.data.title} ${sop.data.purpose} ${sop.data.category} ${sop.data.tags.join(" ")} ${sop.data.tools.join(" ")} ${sop.data.owner} ${sop.data.audience.join(" ")} ${sop.data.relatedSops.join(" ")} ${sop.body}`.toLowerCase()}
          >
            <SopCard
              title={sop.data.title}
              purpose={sop.data.purpose}
              category={sop.data.category}
              tags={sop.data.tags}
              owner={sop.data.owner}
              lastUpdated={sop.data.lastUpdated}
              reviewDate={sop.data.reviewDate}
              tools={sop.data.tools}
              status={sop.data.status}
              url={getSopUrl(sop)}
            />
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<script is:inline define:vars={{ PUBLISHED_SOPS_STORAGE_KEY }}>
  const form = document.getElementById("sop-search-form");
  const queryInput = document.getElementById("search-query");
  const categoryFilter = document.getElementById("filter-category");
  const toolFilter = document.getElementById("filter-tool");
  const ownerFilter = document.getElementById("filter-owner");
  const statusFilter = document.getElementById("filter-status");
  const tagFilter = document.getElementById("filter-tag");
  const updatedFilter = document.getElementById("filter-updated");
  const resultCount = document.getElementById("result-count");
  const emptyState = document.getElementById("search-empty");
  const results = document.getElementById("search-results");
  let cards = Array.from(document.querySelectorAll("[data-search-card]"));

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function readPublishedSops() {
    try {
      const records = JSON.parse(localStorage.getItem(PUBLISHED_SOPS_STORAGE_KEY) || "[]");
      return Array.isArray(records) ? records : [];
    } catch {
      return [];
    }
  }

  function normalizeList(value) {
    if (Array.isArray(value)) return value.map(String).map((item) => item.trim()).filter(Boolean);
    if (typeof value === "string") {
      return value
        .split(/[\n,|]/)
        .map((item) => item.trim())
        .filter(Boolean);
    }
    return [];
  }

  function formatDate(value) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? value : `${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return value;
    return date.toLocaleDateString(undefined, {
      month: "short",
      day: "numeric",
      year: "numeric",
    });
  }

  function optionExists(select, value) {
    return Array.from(select?.options || []).some((option) => option.value === value);
  }

  function addFilterOption(select, value) {
    if (!(select instanceof HTMLSelectElement) || !value || optionExists(select, value)) return;
    const option = document.createElement("option");
    option.value = value;
    option.textContent = value;
    select.append(option);
  }

  function searchTextFor(record) {
    const stepText = normalizeList(record.procedureSteps).join(" ");
    const structuredStepText = Array.isArray(record.procedureSteps)
      ? record.procedureSteps
          .map((step) => [step?.title, step?.instructions, step?.note].filter(Boolean).join(" "))
          .join(" ")
      : "";
    return [
      record.title,
      record.purpose,
      record.category,
      record.owner,
      record.beforeYouBegin,
      record.troubleshootingNotes,
      record.changeSummary,
      normalizeList(record.tags).join(" "),
      normalizeList(record.tools).join(" "),
      normalizeList(record.audience).join(" "),
      normalizeList(record.relatedSops).join(" "),
      normalizeList(record.screenshots).join(" "),
      stepText,
      structuredStepText,
    ]
      .filter(Boolean)
      .join(" ")
      .toLowerCase();
  }

  function statusBadgeHtml(status) {
    const className = String(status || "Published").toLowerCase().replace(/[^a-z0-9]+/g, "-");
    return `<span class="status-badge status-badge--${escapeHtml(className)}"><span class="sr-only">Status:</span>${escapeHtml(
      status || "Published",
    )}</span>`;
  }

  function renderPublishedCard(record) {
    const tags = normalizeList(record.tags);
    const tools = normalizeList(record.tools);
    const audience = normalizeList(record.audience);
    const relatedSops = normalizeList(record.relatedSops);
    const status = record.status || "Published";
    const lastUpdated = record.lastUpdated || record.updatedDate || record.publishedAt;
    const url = record.url || `/published/?id=${encodeURIComponent(record.id)}`;
    const card = document.createElement("div");
    card.dataset.searchCard = "";
    card.dataset.sopId = record.sourceId || record.id;
    card.dataset.category = record.category || "";
    card.dataset.tools = tools.join("|");
    card.dataset.owner = record.owner || "";
    card.dataset.status = status;
    card.dataset.tags = tags.join("|");
    card.dataset.updated = lastUpdated || "";
    card.dataset.search = searchTextFor({ ...record, tags, tools, audience, relatedSops });
    card.innerHTML = `
      <article class="sop-card">
        <div class="sop-card__topline">
          <span class="sop-card__category">${escapeHtml(record.category || "Uncategorized")}</span>
          ${statusBadgeHtml(status)}
        </div>
        <h2><a href="${escapeHtml(url)}">${escapeHtml(record.title || "Untitled SOP")}</a></h2>
        <p class="sop-card__purpose">${escapeHtml(record.purpose || "No purpose provided.")}</p>
        <dl class="compact-meta">
          <div><dt>Owner</dt><dd>${escapeHtml(record.owner || "Unassigned")}</dd></div>
          <div><dt>Updated</dt><dd>${escapeHtml(formatDate(lastUpdated))}</dd></div>
          <div><dt>Review</dt><dd>${escapeHtml(formatDate(record.reviewDate))}</dd></div>
        </dl>
        ${
          record.estimatedCompletionTime
            ? `<p class="sop-card__time"><span class="sop-card__time-icon" aria-hidden="true">Time</span>${escapeHtml(
                record.estimatedCompletionTime,
              )}</p>`
            : ""
        }
        ${
          tools.length > 0
            ? `<p class="sop-card__tools"><strong>Tools:</strong> ${escapeHtml(tools.join(", "))}</p>`
            : ""
        }
        ${
          tags.length > 0
            ? `<ul class="tag-list" aria-label="Tags">${tags
                .map((tag) => `<li>${escapeHtml(tag)}</li>`)
                .join("")}</ul>`
            : ""
        }
      </article>
    `;
    return card;
  }

  function hydratePublishedSops() {
    if (!results) return;

    readPublishedSops().forEach((record) => {
      if (!record?.id || !record?.title) return;

      const card = renderPublishedCard(record);
      const existing = results.querySelector(
        `[data-search-card][data-sop-id="${CSS.escape(card.dataset.sopId || record.id)}"]`,
      );
      if (existing) {
        existing.replaceWith(card);
      } else {
        results.prepend(card);
      }

      addFilterOption(categoryFilter, card.dataset.category);
      addFilterOption(ownerFilter, card.dataset.owner);
      addFilterOption(statusFilter, card.dataset.status);
      normalizeList(card.dataset.tools).forEach((tool) => addFilterOption(toolFilter, tool));
      normalizeList(card.dataset.tags).forEach((tag) => addFilterOption(tagFilter, tag));
    });

    cards = Array.from(document.querySelectorAll("[data-search-card]"));
  }

  function valueOf(element) {
    return element instanceof HTMLInputElement || element instanceof HTMLSelectElement
      ? element.value.trim()
      : "";
  }

  function matchesToken(dataValue, filterValue) {
    if (!filterValue) return true;
    return String(dataValue || "")
      .split("|")
      .includes(filterValue);
  }

  function matchesUpdated(dateValue, daysBack) {
    if (!daysBack) return true;
    if (!dateValue) return false;
    const date = new Date(String(dateValue).includes("T") ? dateValue : `${dateValue}T00:00:00`);
    if (Number.isNaN(date.getTime())) return false;
    const now = new Date();
    const cutoff = new Date(now);
    cutoff.setDate(now.getDate() - Number(daysBack));
    return date >= cutoff;
  }

  function applySearch() {
    const query = valueOf(queryInput).toLowerCase();
    const category = valueOf(categoryFilter);
    const tool = valueOf(toolFilter);
    const owner = valueOf(ownerFilter);
    const status = valueOf(statusFilter);
    const tag = valueOf(tagFilter);
    const updated = valueOf(updatedFilter);
    let visibleCount = 0;

    cards.forEach((card) => {
      const visible =
        (!query || card.dataset.search.includes(query)) &&
        (!category || card.dataset.category === category) &&
        matchesToken(card.dataset.tools, tool) &&
        (!owner || card.dataset.owner === owner) &&
        (!status || card.dataset.status === status) &&
        matchesToken(card.dataset.tags, tag) &&
        matchesUpdated(card.dataset.updated, updated);

      card.hidden = !visible;
      if (visible) visibleCount += 1;
    });

    if (resultCount) {
      resultCount.textContent = `${visibleCount} SOP${visibleCount === 1 ? "" : "s"} found`;
    }
    if (emptyState) {
      emptyState.hidden = visibleCount !== 0;
    }
  }

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    applySearch();
  });

  form?.addEventListener("reset", () => {
    window.setTimeout(applySearch, 0);
  });

  [queryInput, categoryFilter, toolFilter, ownerFilter, statusFilter, tagFilter, updatedFilter].forEach(
    (element) => {
      element?.addEventListener("input", applySearch);
      element?.addEventListener("change", applySearch);
    },
  );

  hydratePublishedSops();
  applySearch();
</script>
