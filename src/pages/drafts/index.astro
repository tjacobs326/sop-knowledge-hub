---
import Layout from "../../components/Layout.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import { mockDrafts } from "../../data/mock-drafts";
import { statusBadgeDefinitions } from "../../lib/badges";
import { DRAFTS_STORAGE_KEY, EDIT_SOP_STORAGE_KEY } from "../../lib/drafts";

// Future access note: restrict this route to SOP creators and reviewers with Cloudflare Access.
---

<Layout title="My Drafts" wide>
  <section class="tool-surface" aria-labelledby="drafts-heading">
    <div class="section-heading">
      <p class="eyebrow">Creators / Reviewers</p>
      <h1 id="drafts-heading">My Drafts</h1>
      <p>Review saved SOP drafts and continue work before submitting them for review.</p>
    </div>

    <div class="form-actions">
      <a class="button button--primary" href="/create/">Create SOP</a>
      <a class="button button--secondary" href="/admin/review/">Review Queue</a>
    </div>

    <div class="table-wrap" data-drafts-table>
      <table>
        <thead>
          <tr>
            <th scope="col">Draft</th>
            <th scope="col">Category</th>
            <th scope="col">Status</th>
            <th scope="col">Owner</th>
            <th scope="col">Review Date</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody id="drafts-list">
          {mockDrafts.map((draft) => (
            <tr>
              <td>{draft.title}</td>
              <td>{draft.category}</td>
              <td><StatusBadge status={draft.status} /></td>
              <td>{draft.owner}</td>
              <td>{draft.reviewDate}</td>
              <td>
                <button class="button button--secondary" type="button" data-edit-draft={draft.id}>
                  Edit Draft
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<script
  is:inline
  define:vars={{ DRAFTS_STORAGE_KEY, EDIT_SOP_STORAGE_KEY, mockDrafts, statusBadgeDefinitions }}
>
  const list = document.getElementById("drafts-list");
  let currentDrafts = [...mockDrafts];

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function statusBadge(status) {
    const key = String(status || "").toLowerCase().replace(/[^a-z0-9]+/g, "-");
    const badge = statusBadgeDefinitions[key] || {
      label: status || "New",
      className: "status-badge--new",
    };
    return `<span class="badge status-badge ${escapeHtml(badge.className)}"><span class="sr-only">Status:</span>${escapeHtml(
      badge.label,
    )}</span>`;
  }

  try {
    const localDrafts = JSON.parse(localStorage.getItem(DRAFTS_STORAGE_KEY) || "[]");
    if (Array.isArray(localDrafts) && localDrafts.length > 0 && list) {
      currentDrafts = localDrafts;
      list.innerHTML = localDrafts
        .map(
          (draft) => `
            <tr>
              <td>${escapeHtml(draft.title)}</td>
              <td>${escapeHtml(draft.category)}</td>
              <td>${statusBadge(draft.status)}</td>
              <td>${escapeHtml(draft.owner)}</td>
              <td>${escapeHtml(draft.reviewDate)}</td>
              <td>
                <button class="button button--secondary" type="button" data-edit-draft="${escapeHtml(
                  draft.id,
                )}">
                  Edit Draft
                </button>
              </td>
            </tr>
          `,
        )
        .join("");
    }
  } catch {
    // Keep the sample rows if local draft storage is unavailable.
  }

  list?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const button = target.closest("[data-edit-draft]");
    if (!(button instanceof HTMLElement)) return;

    const draft = currentDrafts.find((item) => item.id === button.dataset.editDraft);
    if (!draft) return;

    sessionStorage.setItem(
      EDIT_SOP_STORAGE_KEY,
      JSON.stringify({
        ...draft,
        editMode: "draft",
      }),
    );
    window.location.href = `/create/?edit=draft&id=${encodeURIComponent(draft.id)}`;
  });
</script>
