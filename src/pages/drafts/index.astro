---
import Layout from "../../components/Layout.astro";
import AppIllustration from "../../components/AppIllustration.astro";
import { statusBadgeDefinitions } from "../../lib/badges";
---

<Layout title="My Drafts" wide>
  <section class="tool-surface" aria-labelledby="drafts-heading">
    <div class="section-heading surface-intro">
      <div>
        <p class="eyebrow">Creators / Reviewers</p>
        <h1 id="drafts-heading">My Drafts</h1>
        <p>Review backend SOP drafts you are allowed to edit, continue, submit, preview, or archive.</p>
      </div>
      <AppIllustration name="drafts" size="md" />
    </div>

    <div class="form-actions">
      <a class="button button--primary" href="/create/">Create SOP</a>
      <a class="button button--secondary" href="/review-queue/">Review Queue</a>
      <a class="button button--ghost" href="/my-work/">My Work</a>
    </div>

    <div class="drafts-context" id="drafts-context" role="status">Loading draft workflow context...</div>

    <div class="table-wrap" data-drafts-table>
      <table>
        <thead>
          <tr>
            <th scope="col">Draft</th>
            <th scope="col">Category</th>
            <th scope="col">Status</th>
            <th scope="col">Owner</th>
            <th scope="col">Review Date</th>
            <th scope="col">Assigned Reviewer</th>
            <th scope="col">Last Updated</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody id="drafts-list">
          <tr>
            <td colspan="8">
              <div class="empty-state empty-state--table">
                <strong>Loading drafts</strong>
                <p>Connecting to the live Cloudflare database.</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="form-errors" id="drafts-errors" role="alert" hidden></div>
    <div class="confirmation" id="drafts-confirmation" role="status" hidden></div>
  </section>

  <dialog id="archive-draft-dialog" aria-labelledby="archive-draft-heading" aria-describedby="archive-draft-description">
    <form method="dialog" class="archive-draft-dialog">
      <h2 id="archive-draft-heading">Archive this SOP draft?</h2>
      <p id="archive-draft-description">The SOP will be removed from My Drafts and added to Archived SOPs. Its content, attachments, and history will be preserved.</p>
      <label class="field"><span>Archive reason <span aria-hidden="true">*</span></span><textarea id="archive-draft-reason" rows="4" required aria-required="true"></textarea></label>
      <p class="form-errors" id="archive-draft-error" role="alert" hidden>Enter an archive reason.</p>
      <div class="form-actions"><button class="button button--ghost" value="cancel">Cancel</button><button class="button button--danger" value="confirm">Archive SOP</button></div>
    </form>
  </dialog>
</Layout>

<script is:inline define:vars={{ statusBadgeDefinitions }}>
  const list = document.getElementById("drafts-list");
  const contextEl = document.getElementById("drafts-context");
  const errorsEl = document.getElementById("drafts-errors");
  const confirmation = document.getElementById("drafts-confirmation");
  const archiveDialog = document.getElementById("archive-draft-dialog");
  const archiveReason = document.getElementById("archive-draft-reason");
  const archiveError = document.getElementById("archive-draft-error");
  const ROLE_CONTEXT_EVENT = "sop-role-context-change";
  const ROLE_KEY = "sopHubSelectedRole";
  const SUB_ROLE_KEY = "sopHubSelectedCreatorSubRole";
  const WORK_SCOPE_KEY = "sopHubMyWorkScope";
  let currentDrafts = [];
  let activeDraftRequestId = 0;
  let pendingArchiveId = "";
  let pendingArchiveButton = null;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
      return replacements[character];
    });

  function apiHeaders() {
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    return {
      accept: "application/json",
      "content-type": "application/json",
      ...(subRole ? { "x-sop-sub-role": subRole } : {}),
    };
  }

  function selectedSubRoleQuery() {
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    const params = new URLSearchParams();
    if (subRole) params.set("subRole", subRole);
    try {
      const savedScope = sessionStorage.getItem(WORK_SCOPE_KEY) || "";
      if (savedScope.startsWith("user:")) {
        params.set("scope", "user");
        params.set("userId", savedScope.slice(5));
      } else if (savedScope) {
        params.set("scope", savedScope);
      }
    } catch {
      // Scope persistence is only a navigation hint; the backend validates every request.
    }
    const query = params.toString();
    return query ? `?${query}` : "";
  }

  function selectedSubRole() {
    return localStorage.getItem(SUB_ROLE_KEY) || "";
  }

  async function parseApiResponse(response) {
    const data = await response.json().catch(() => ({}));
    if (!response.ok || data?.success === false) {
      throw new Error(data?.error?.message || data?.error || `Request failed: ${response.status}`);
    }
    return data.data || data;
  }

  function statusBadge(status) {
    const key = String(status || "").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
    const badge = statusBadgeDefinitions[key] || {
      label: status || "Draft",
      className: "status-badge--draft",
    };
    return `<span class="badge status-badge ${escapeHtml(badge.className)}"><span class="sr-only">Status:</span>${escapeHtml(
      badge.label,
    )}</span>`;
  }

  function formatDate(value) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? value : `${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
  }

  function emptyRow(title, message) {
    return `<tr><td colspan="8"><div class="empty-state empty-state--table"><strong>${escapeHtml(
      title,
    )}</strong><p>${escapeHtml(message)}</p></div></td></tr>`;
  }

  function renderContext(data) {
    const context = data.context || {};
    const user = context.selectedUser?.name || "Selected creator/reviewer";
    const subRole = context.selectedSubRole?.label || "selected department";
    const count = Number(data.counts?.drafts || currentDrafts.length || 0);
    const editable = Number(data.counts?.editableDrafts || 0);
    const previewable = Number(data.counts?.previewableDrafts || 0);
    const readyToPublish = Number(data.counts?.readyToPublish || 0);
    if (contextEl) {
      contextEl.textContent = `${count} draft workflow item${count === 1 ? "" : "s"} loaded for ${user} in ${subRole}. Editable: ${editable}. Previewable: ${previewable}. Ready to publish: ${readyToPublish}.`;
    }
  }

  function actionButton(label, attributes, className = "button--secondary") {
    return `<button class="button ${className}" type="button" ${attributes}>${escapeHtml(label)}</button>`;
  }

  function actionLink(label, href, className = "button--secondary") {
    return `<a class="button ${className}" href="${escapeHtml(href)}">${escapeHtml(label)}</a>`;
  }

  function renderDraftActions(draft) {
    const capabilities = draft.capabilities || {};
    const actions = [];
    if (capabilities.canEdit) actions.push(actionLink("Edit Draft", draft.editUrl));
    if (capabilities.canPreview) actions.push(actionLink("Preview", draft.previewUrl, "button--ghost"));
    if (capabilities.canSubmitForReview) {
      actions.push(actionButton("Submit for Review", `data-draft-workflow="submit-review" data-draft-id="${escapeHtml(draft.id)}"`));
    }
    if (capabilities.canReview) actions.push(actionLink("Review Draft", draft.reviewUrl, "button--secondary"));
    if (capabilities.canRequestChanges) {
      actions.push(actionButton("Request Changes", `data-draft-workflow="request-changes" data-draft-id="${escapeHtml(draft.id)}"`, "button--secondary"));
    }
    if (capabilities.canApprove) {
      actions.push(actionButton("Approve SOP", `data-draft-workflow="approve" data-draft-id="${escapeHtml(draft.id)}"`, "button--secondary"));
    }
    if (capabilities.canPublish) {
      actions.push(actionButton("Publish SOP", `data-draft-workflow="publish" data-draft-id="${escapeHtml(draft.id)}"`, "button--primary"));
    }
    if (capabilities.canArchive) {
      actions.push(actionButton("Archive", `data-draft-workflow="archive" data-draft-id="${escapeHtml(draft.id)}"`, "button--danger"));
    }
    return actions.length ? actions.join("") : `<span class="muted">No actions available</span>`;
  }

  function renderDrafts(data) {
    currentDrafts = Array.isArray(data.drafts) ? data.drafts : [];
    renderContext(data);
    if (!list) return;
    if (!currentDrafts.length) {
      list.innerHTML = emptyRow(
        "No editable drafts",
        "There are no backend drafts assigned to this user, role, department, or selected sub-role.",
      );
      return;
    }

    list.innerHTML = currentDrafts
      .map(
        (draft) => `
          <tr>
            <td><strong>${escapeHtml(draft.title)}</strong></td>
            <td>${escapeHtml(draft.category)}</td>
            <td>${statusBadge(draft.status)}</td>
            <td>${escapeHtml(draft.owner)}</td>
            <td>${escapeHtml(formatDate(draft.reviewDate))}</td>
            <td>${escapeHtml(draft.assignedReviewer || "Unassigned")}</td>
            <td>${escapeHtml(formatDate(draft.updatedDate))}</td>
            <td>
              <div class="table-actions">
                ${renderDraftActions(draft)}
              </div>
            </td>
          </tr>
        `,
      )
      .join("");
  }

  function clearDraftState(message = "Connecting to the live Cloudflare database.") {
    currentDrafts = [];
    if (contextEl) {
      contextEl.textContent = "Loading draft workflow context...";
    }
    if (list) {
      list.innerHTML = emptyRow("Loading drafts", message);
    }
  }

  function showError(error) {
    currentDrafts = [];
    if (errorsEl) {
      errorsEl.hidden = false;
      errorsEl.innerHTML = `<p>${escapeHtml(error instanceof Error ? error.message : "Drafts could not load.")}</p>`;
    }
    if (list) {
      list.innerHTML = emptyRow("Drafts unavailable", "The backend draft list could not be loaded. Please refresh and try again.");
    }
  }

  async function loadDrafts() {
    const requestId = ++activeDraftRequestId;
    const requestedSubRole = selectedSubRole();
    if (errorsEl) errorsEl.hidden = true;
    if (confirmation) confirmation.hidden = true;
    clearDraftState();
    const response = await fetch(`/api/my-drafts${selectedSubRoleQuery()}`, {
      headers: apiHeaders(),
      cache: "no-store",
    });
    const data = await parseApiResponse(response);
    if (requestId !== activeDraftRequestId || requestedSubRole !== selectedSubRole()) return;
    renderDrafts(data);
  }

  function workflowMessage(action, draft) {
    if (action === "submit-review") return `Submit "${draft.title}" for review?`;
    if (action === "request-changes") return `Request changes for "${draft.title}"?`;
    if (action === "approve") return `Approve "${draft.title}"?`;
    if (action === "publish") return `Publish "${draft.title}"? Publishing will make this SOP available in the knowledge hub and remove it from active draft lists.`;
    if (action === "archive") return `Archive "${draft.title}"? This removes it from active draft queues.`;
    return `Update "${draft.title}"?`;
  }

  function workflowEndpoint(action) {
    if (action === "submit-review") return "submit-review";
    if (action === "request-changes") return "request-changes";
    return action;
  }

  async function runDraftWorkflow(id, action, button, reason = "") {
    const draft = currentDrafts.find((item) => item.id === id);
    if (!draft || (action !== "archive" && !window.confirm(workflowMessage(action, draft)))) return;
    if (button instanceof HTMLButtonElement) button.disabled = true;
    const response = await fetch(`/api/sops/${encodeURIComponent(id)}/${workflowEndpoint(action)}`, {
      method: "POST",
      headers: apiHeaders(),
      body: JSON.stringify(action === "archive" ? { reason, notes: reason } : { notes: `${action} from My Drafts.` }),
    });
    await parseApiResponse(response);
    if (confirmation) {
      confirmation.hidden = false;
      const publishedLink =
        action === "publish"
          ? `<p><a class="button button--secondary" href="${escapeHtml(draft.detailUrl)}">View Published SOP</a></p>`
          : "";
      confirmation.innerHTML = `<strong>${escapeHtml(draft.title)} updated.</strong><p>The backend workflow action completed successfully.</p>${publishedLink}`;
    }
    await loadDrafts();
  }

  list?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const workflowButton = target.closest("[data-draft-workflow]");
    if (workflowButton instanceof HTMLElement) {
      if (workflowButton.dataset.draftWorkflow === "archive" && archiveDialog instanceof HTMLDialogElement) {
        pendingArchiveId = workflowButton.dataset.draftId || "";
        pendingArchiveButton = workflowButton instanceof HTMLButtonElement ? workflowButton : null;
        if (archiveReason instanceof HTMLTextAreaElement) archiveReason.value = "";
        if (archiveError) archiveError.hidden = true;
        archiveDialog.showModal();
        window.requestAnimationFrame(() => archiveReason?.focus());
        return;
      }
      runDraftWorkflow(
        workflowButton.dataset.draftId || "",
        workflowButton.dataset.draftWorkflow || "",
        workflowButton instanceof HTMLButtonElement ? workflowButton : null,
      ).catch(showError);
    }
  });

  archiveDialog?.addEventListener("close", () => {
    if (archiveDialog.returnValue !== "confirm") return;
    const reason = archiveReason instanceof HTMLTextAreaElement ? archiveReason.value.trim() : "";
    if (!reason) {
      if (archiveError) archiveError.hidden = false;
      archiveDialog.showModal();
      archiveReason?.focus();
      return;
    }
    runDraftWorkflow(pendingArchiveId, "archive", pendingArchiveButton, reason).catch(showError);
  });

  window.addEventListener("storage", (event) => {
    if (event.key === SUB_ROLE_KEY || event.key === ROLE_KEY) {
      activeDraftRequestId += 1;
      clearDraftState("Refreshing drafts for the newly selected role.");
      loadDrafts().catch(showError);
    }
  });

  window.addEventListener(ROLE_CONTEXT_EVENT, (event) => {
    const detail = event instanceof CustomEvent ? event.detail || {} : {};
    if (detail.previousSubRole !== detail.subRole || detail.previousRole !== detail.role) {
      activeDraftRequestId += 1;
      clearDraftState("Refreshing drafts for the newly selected role.");
      loadDrafts().catch(showError);
    }
  });

  loadDrafts().catch(showError);
</script>

<style>
  #archive-draft-dialog { width: min(calc(100% - 2rem), 38rem); border: 0; border-radius: 1rem; padding: 0; box-shadow: 0 24px 60px rgba(15,23,42,.28); }
  #archive-draft-dialog::backdrop { background: rgba(15,23,42,.58); }
  .archive-draft-dialog { padding: 1.5rem; }
  .archive-draft-dialog h2 { margin-top: 0; }
</style>
