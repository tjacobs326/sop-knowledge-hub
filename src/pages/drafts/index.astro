---
import Layout from "../../components/Layout.astro";
import { statusBadgeDefinitions } from "../../lib/badges";
---

<Layout title="My Drafts" wide>
  <section class="tool-surface" aria-labelledby="drafts-heading">
    <div class="section-heading">
      <p class="eyebrow">Creators / Reviewers</p>
      <h1 id="drafts-heading">My Drafts</h1>
      <p>Review backend SOP drafts you are allowed to edit, continue, submit, preview, or archive.</p>
    </div>

    <div class="form-actions">
      <a class="button button--primary" href="/create/">Create SOP</a>
      <a class="button button--secondary" href="/admin/review/">Review Queue</a>
      <a class="button button--ghost" href="/my-work/">My Work</a>
    </div>

    <div class="drafts-context" id="drafts-context" role="status">Loading draft access context...</div>

    <div class="table-wrap" data-drafts-table>
      <table>
        <thead>
          <tr>
            <th scope="col">Draft</th>
            <th scope="col">Category</th>
            <th scope="col">Status</th>
            <th scope="col">Owner</th>
            <th scope="col">Review Date</th>
            <th scope="col">Assigned Reviewer</th>
            <th scope="col">Last Updated</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody id="drafts-list">
          <tr>
            <td colspan="8">
              <div class="empty-state empty-state--table">
                <strong>Loading drafts</strong>
                <p>Connecting to the live Cloudflare database.</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="form-errors" id="drafts-errors" role="alert" hidden></div>
    <div class="confirmation" id="drafts-confirmation" role="status" hidden></div>
  </section>
</Layout>

<script is:inline define:vars={{ statusBadgeDefinitions }}>
  const list = document.getElementById("drafts-list");
  const contextEl = document.getElementById("drafts-context");
  const errorsEl = document.getElementById("drafts-errors");
  const confirmation = document.getElementById("drafts-confirmation");
  const ROLE_CONTEXT_EVENT = "sop-role-context-change";
  const ROLE_KEY = "sopHubSelectedRole";
  const SUB_ROLE_KEY = "sopHubSelectedCreatorSubRole";
  let currentDrafts = [];
  let canArchive = false;
  let activeDraftRequestId = 0;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" };
      return replacements[character];
    });

  function apiHeaders() {
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    return {
      accept: "application/json",
      "content-type": "application/json",
      ...(subRole ? { "x-sop-sub-role": subRole } : {}),
    };
  }

  function selectedSubRoleQuery() {
    const subRole = localStorage.getItem(SUB_ROLE_KEY) || "";
    return subRole ? `?subRole=${encodeURIComponent(subRole)}` : "";
  }

  function selectedSubRole() {
    return localStorage.getItem(SUB_ROLE_KEY) || "";
  }

  async function parseApiResponse(response) {
    const data = await response.json().catch(() => ({}));
    if (!response.ok || data?.success === false) {
      throw new Error(data?.error?.message || data?.error || `Request failed: ${response.status}`);
    }
    return data.data || data;
  }

  function statusBadge(status) {
    const key = String(status || "").toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
    const badge = statusBadgeDefinitions[key] || {
      label: status || "Draft",
      className: "status-badge--draft",
    };
    return `<span class="badge status-badge ${escapeHtml(badge.className)}"><span class="sr-only">Status:</span>${escapeHtml(
      badge.label,
    )}</span>`;
  }

  function formatDate(value) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? value : `${value}T00:00:00`);
    if (Number.isNaN(date.getTime())) return String(value);
    return date.toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
  }

  function emptyRow(title, message) {
    return `<tr><td colspan="8"><div class="empty-state empty-state--table"><strong>${escapeHtml(
      title,
    )}</strong><p>${escapeHtml(message)}</p></div></td></tr>`;
  }

  function renderContext(data) {
    const context = data.context || {};
    const user = context.selectedUser?.name || "Selected creator/reviewer";
    const subRole = context.selectedSubRole?.label || "selected department";
    const count = Number(data.counts?.drafts || currentDrafts.length || 0);
    if (contextEl) {
      contextEl.textContent = `${count} editable draft${count === 1 ? "" : "s"} loaded for ${user} in ${subRole}.`;
    }
  }

  function renderDrafts(data) {
    currentDrafts = Array.isArray(data.drafts) ? data.drafts : [];
    canArchive = Boolean(data.context?.canArchive);
    renderContext(data);
    if (!list) return;
    if (!currentDrafts.length) {
      list.innerHTML = emptyRow(
        "No editable drafts",
        "There are no backend drafts assigned to this user, role, department, or selected sub-role.",
      );
      return;
    }

    list.innerHTML = currentDrafts
      .map(
        (draft) => `
          <tr>
            <td><strong>${escapeHtml(draft.title)}</strong></td>
            <td>${escapeHtml(draft.category)}</td>
            <td>${statusBadge(draft.status)}</td>
            <td>${escapeHtml(draft.owner)}</td>
            <td>${escapeHtml(formatDate(draft.reviewDate))}</td>
            <td>${escapeHtml(draft.assignedReviewer || "Unassigned")}</td>
            <td>${escapeHtml(formatDate(draft.updatedDate))}</td>
            <td>
              <div class="table-actions">
                <a class="button button--secondary" href="${escapeHtml(draft.editUrl)}">Edit Draft</a>
                <a class="button button--ghost" href="${escapeHtml(draft.detailUrl)}">Preview</a>
                ${
                  canArchive
                    ? `<button class="button button--danger" type="button" data-archive-draft="${escapeHtml(draft.id)}">Archive</button>`
                    : ""
                }
              </div>
            </td>
          </tr>
        `,
      )
      .join("");
  }

  function clearDraftState(message = "Connecting to the live Cloudflare database.") {
    currentDrafts = [];
    canArchive = false;
    if (contextEl) {
      contextEl.textContent = "Loading draft access context...";
    }
    if (list) {
      list.innerHTML = emptyRow("Loading drafts", message);
    }
  }

  function showError(error) {
    currentDrafts = [];
    canArchive = false;
    if (errorsEl) {
      errorsEl.hidden = false;
      errorsEl.innerHTML = `<p>${escapeHtml(error instanceof Error ? error.message : "Drafts could not load.")}</p>`;
    }
    if (list) {
      list.innerHTML = emptyRow("Drafts unavailable", "The backend draft list could not be loaded. Please refresh and try again.");
    }
  }

  async function loadDrafts() {
    const requestId = ++activeDraftRequestId;
    const requestedSubRole = selectedSubRole();
    if (errorsEl) errorsEl.hidden = true;
    if (confirmation) confirmation.hidden = true;
    clearDraftState();
    const response = await fetch(`/api/my-drafts${selectedSubRoleQuery()}`, {
      headers: apiHeaders(),
      cache: "no-store",
    });
    const data = await parseApiResponse(response);
    if (requestId !== activeDraftRequestId || requestedSubRole !== selectedSubRole()) return;
    renderDrafts(data);
  }

  async function archiveDraft(id) {
    const draft = currentDrafts.find((item) => item.id === id);
    if (!draft || !window.confirm(`Archive "${draft.title}"? This removes it from active draft queues.`)) return;
    const response = await fetch(`/api/sops/${encodeURIComponent(id)}/archive`, {
      method: "POST",
      headers: apiHeaders(),
      body: JSON.stringify({ notes: "Archived from My Drafts." }),
    });
    await parseApiResponse(response);
    if (confirmation) {
      confirmation.hidden = false;
      confirmation.innerHTML = `<strong>Draft archived.</strong><p>${escapeHtml(draft.title)} was removed from active draft queues.</p>`;
    }
    await loadDrafts();
  }

  list?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const archiveButton = target.closest("[data-archive-draft]");
    if (archiveButton instanceof HTMLElement) {
      archiveDraft(archiveButton.dataset.archiveDraft || "").catch(showError);
    }
  });

  window.addEventListener("storage", (event) => {
    if (event.key === SUB_ROLE_KEY || event.key === ROLE_KEY) {
      activeDraftRequestId += 1;
      clearDraftState("Refreshing drafts for the newly selected role.");
      loadDrafts().catch(showError);
    }
  });

  window.addEventListener(ROLE_CONTEXT_EVENT, (event) => {
    const detail = event instanceof CustomEvent ? event.detail || {} : {};
    if (detail.previousSubRole !== detail.subRole || detail.previousRole !== detail.role) {
      activeDraftRequestId += 1;
      clearDraftState("Refreshing drafts for the newly selected role.");
      loadDrafts().catch(showError);
    }
  });

  loadDrafts().catch(showError);
</script>
