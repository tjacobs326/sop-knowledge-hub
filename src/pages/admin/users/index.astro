---
import Layout from "../../../components/Layout.astro";
import AppIllustration from "../../../components/AppIllustration.astro";

// Future access note: restrict this route to admins with Cloudflare Access.
const permissionOptions = [
  "Search SOPs",
  "Use Guided Finder",
  "Browse Categories",
  "Submit Requests",
  "Create SOPs",
  "Edit Drafts",
  "Review SOPs",
  "Request Changes",
  "Approve SOPs",
  "Publish SOPs",
  "Archive SOPs",
  "Manage Users",
  "Manage Categories",
  "Manage Tags",
  "View Analytics",
  "Upload Media",
  "Manage Media",
  "Settings",
];
const accessLevels = ["Normal User", "Creator / Reviewer", "Admin"];
---

<Layout title="Users" wide>
  <section class="tool-surface" aria-labelledby="users-heading">
    <div class="section-heading surface-intro">
      <div>
        <p class="eyebrow">Admin</p>
        <h1 id="users-heading">Users</h1>
        <p>Plan role access and user groups for the SOP Knowledge Hub.</p>
      </div>
      <AppIllustration name="users" size="md" />
    </div>

    <div class="quick-link-grid" id="role-list">
      <p class="empty-state">Loading roles from Cloudflare D1...</p>
    </div>

    <form class="form-grid" id="role-editor" hidden>
      <h2 class="form-section-title field--full" id="role-editor-heading">Edit Role</h2>
      <input id="role-id" name="id" type="hidden" />
      <div class="field">
        <label for="role-name">Role name</label>
        <input id="role-name" name="name" type="text" required />
      </div>
      <div class="field">
        <label for="role-access-group">Access group</label>
        <input id="role-access-group" name="accessGroup" type="text" required />
      </div>
      <div class="field">
        <label for="role-landing-page">Default landing page</label>
        <input id="role-landing-page" name="landingPage" type="text" required />
      </div>
      <div class="field field--full">
        <label for="role-description">Description</label>
        <textarea id="role-description" name="description" rows="3" required></textarea>
      </div>
      <fieldset class="field field--full checkbox-grid">
        <legend>Permissions</legend>
        {permissionOptions.map((permission) => (
          <label>
            <input type="checkbox" name="permissions" value={permission} />
            <span>{permission}</span>
          </label>
        ))}
      </fieldset>
      <div class="form-actions field--full">
        <button class="button button--primary" type="submit">Save Role</button>
        <button class="button button--ghost" type="button" id="cancel-role-edit">
          Cancel
        </button>
      </div>
      <div class="confirmation field--full" id="role-confirmation" role="status" hidden></div>
    </form>

    <section class="dashboard-section" aria-labelledby="user-accounts-heading">
      <div class="section-heading">
        <h2 id="user-accounts-heading">Enrolled Users</h2>
        <p>Track who has access to the SOP Knowledge Hub and what each account can do.</p>
      </div>

      <div class="stat-grid user-summary" id="user-summary" aria-label="User account summary">
        <article class="stat-card">
          <span>Total users</span>
          <strong id="total-users">0</strong>
        </article>
        <article class="stat-card">
          <span>Admins</span>
          <strong id="total-admins">0</strong>
        </article>
        <article class="stat-card">
          <span>Creators / Reviewers</span>
          <strong id="total-creators">0</strong>
        </article>
        <article class="stat-card">
          <span>Normal users</span>
          <strong id="total-normal-users">0</strong>
        </article>
      </div>

      <div class="form-actions admin-toolbar">
        <button class="button button--primary" type="button" id="create-user">
          Add User
        </button>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Name</th>
              <th scope="col">Email</th>
              <th scope="col">Department</th>
              <th scope="col">Level of access</th>
              <th scope="col">Permissions</th>
              <th scope="col">Status</th>
              <th scope="col">Action</th>
            </tr>
          </thead>
          <tbody id="user-account-list">
            <tr>
              <td colspan="7">Loading users from Cloudflare D1...</td>
            </tr>
          </tbody>
        </table>
      </div>

      <form class="form-grid" id="user-editor" hidden>
        <h2 class="form-section-title field--full" id="user-editor-heading">Edit User</h2>
        <input id="user-id" name="id" type="hidden" />
        <div class="field">
          <label for="user-name">User name</label>
          <input id="user-name" name="name" type="text" required />
        </div>
        <div class="field">
          <label for="user-email">Email</label>
          <input id="user-email" name="email" type="email" required />
        </div>
        <div class="field">
          <label for="user-department">Department</label>
          <select id="user-department" name="departmentId" required disabled aria-describedby="user-department-status">
            <option value="">Loading departments...</option>
          </select>
          <small id="user-department-status" role="status">Loading active departments from Cloudflare D1.</small>
        </div>
        <div class="field">
          <label for="user-access-level">Level of access</label>
          <select id="user-access-level" name="accessLevel">
            {accessLevels.map((level) => <option value={level}>{level}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="user-status">Status</label>
          <select id="user-status" name="status">
            <option value="Active">Active</option>
            <option value="Suspended">Suspended</option>
            <option value="Pending">Pending</option>
          </select>
        </div>
        <fieldset class="field field--full checkbox-grid" id="user-permissions">
          <legend>Account permissions</legend>
          {permissionOptions.map((permission) => (
            <label>
              <input type="checkbox" name="userPermissions" value={permission} />
              <span>{permission}</span>
            </label>
          ))}
        </fieldset>
        <div class="form-actions field--full">
          <button class="button button--primary" type="submit" id="save-user" disabled>Save User</button>
          <button class="button button--danger" type="button" id="delete-user">
            Remove User
          </button>
          <button class="button button--ghost" type="button" id="cancel-user-edit">
            Cancel
          </button>
        </div>
        <div class="confirmation field--full" id="user-confirmation" role="status" hidden></div>
      </form>
    </section>
  </section>
</Layout>

<script is:inline>
  const roleList = document.getElementById("role-list");
  const editor = document.getElementById("role-editor");
  const editorHeading = document.getElementById("role-editor-heading");
  const cancelButton = document.getElementById("cancel-role-edit");
  const confirmation = document.getElementById("role-confirmation");
  const userList = document.getElementById("user-account-list");
  const userEditor = document.getElementById("user-editor");
  const userEditorHeading = document.getElementById("user-editor-heading");
  const createUserButton = document.getElementById("create-user");
  const saveUserButton = document.getElementById("save-user");
  const departmentSelect = document.getElementById("user-department");
  const departmentStatus = document.getElementById("user-department-status");
  const deleteUserButton = document.getElementById("delete-user");
  const cancelUserButton = document.getElementById("cancel-user-edit");
  const userConfirmation = document.getElementById("user-confirmation");
  let roleCache = [];
  let userCache = [];
  let departmentCache = [];
  let departmentsLoaded = false;

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function readRoles() {
    return roleCache;
  }

  function readUsers() {
    return userCache;
  }

  function normalizeBackendRole(role) {
    return {
      ...role,
      accessGroup: role.accessGroup || "",
      landingPage: role.landingPage || "/",
      permissions: Array.isArray(role.permissions) ? role.permissions : [],
    };
  }

  function normalizeBackendUser(user) {
    return {
      ...user,
      accessLevel: user.accessLevel || "Normal User",
      department: user.department || "",
      departmentId: user.departmentId || user.teamId || "",
      teamId: user.teamId || user.departmentId || "",
      permissions: Array.isArray(user.permissions) ? user.permissions : [],
      roleIds: Array.isArray(user.roleIds) ? user.roleIds : user.roleId ? [user.roleId] : [],
    };
  }

  function normalizeBackendDepartment(department) {
    return {
      ...department,
      id: department.id || "",
      name: department.name || "",
      status: department.status || "Active",
    };
  }

  function validDepartmentIds() {
    return new Set(departmentCache.map((department) => department.id).filter(Boolean));
  }

  function selectedAccessLevelRequiresDepartment() {
    return ["Normal User", "Creator / Reviewer", "Admin"].includes(getUserField("accessLevel") || "Normal User");
  }

  function selectedDepartmentIsValid() {
    if (!(departmentSelect instanceof HTMLSelectElement)) return false;
    if (!selectedAccessLevelRequiresDepartment()) return true;
    return validDepartmentIds().has(departmentSelect.value);
  }

  function updateUserSaveState() {
    if (saveUserButton instanceof HTMLButtonElement) {
      saveUserButton.disabled = !departmentsLoaded || !selectedDepartmentIsValid();
    }
  }

  function renderDepartmentOptions(selectedId = "") {
    if (!(departmentSelect instanceof HTMLSelectElement)) return;

    if (!departmentsLoaded) {
      departmentSelect.innerHTML = `<option value="">Loading departments...</option>`;
      departmentSelect.disabled = true;
      updateUserSaveState();
      return;
    }

    departmentSelect.disabled = false;
    const selectedStillValid = departmentCache.some((department) => department.id === selectedId);
    departmentSelect.innerHTML = [
      `<option value="">Select a department.</option>`,
      ...departmentCache.map(
        (department) =>
          `<option value="${escapeHtml(department.id)}" ${department.id === selectedId ? "selected" : ""}>${escapeHtml(
            department.name,
          )}</option>`,
      ),
    ].join("");
    departmentSelect.value = selectedStillValid ? selectedId : "";
    if (departmentStatus) {
      departmentStatus.textContent = departmentCache.length
        ? `${departmentCache.length} active department${departmentCache.length === 1 ? "" : "s"} loaded.`
        : "No active departments are available.";
    }
    updateUserSaveState();
  }

  async function loadDepartments() {
    departmentsLoaded = false;
    renderDepartmentOptions("");
    try {
      const response = await fetch("/api/admin/departments", { cache: "no-store" });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data?.error || "Departments could not load from Cloudflare D1.");
      if (!Array.isArray(data.departments)) throw new Error("Department data was not returned by D1.");
      departmentCache = data.departments.map(normalizeBackendDepartment).filter((department) => department.id && department.name);
      departmentsLoaded = true;
      renderDepartmentOptions(getUserField("departmentId"));
    } catch (error) {
      departmentCache = [];
      departmentsLoaded = false;
      if (departmentSelect instanceof HTMLSelectElement) {
        departmentSelect.innerHTML = `<option value="">Departments unavailable</option>`;
        departmentSelect.disabled = true;
      }
      if (departmentStatus) {
        departmentStatus.textContent = error instanceof Error ? error.message : "Departments could not load from Cloudflare D1.";
      }
      updateUserSaveState();
    }
  }

  async function loadBackendUsers() {
    try {
      const [usersResponse] = await Promise.all([fetch("/api/admin/users"), loadDepartments()]);
      if (!usersResponse.ok) throw new Error("User data could not load from D1.");
      const data = await usersResponse.json();
      if (!Array.isArray(data.users) || !Array.isArray(data.roles)) {
        throw new Error("User and role data was not returned by D1.");
      }
      roleCache = data.roles.map(normalizeBackendRole);
      userCache = data.users.map(normalizeBackendUser);
      renderRoles();
      renderUsers();
    } catch (error) {
      if (roleList) roleList.innerHTML = `<p class="empty-state">${escapeHtml(error.message || "Roles could not load from Cloudflare D1.")}</p>`;
      if (userList) {
        userList.innerHTML = `
          <tr>
            <td colspan="7">${escapeHtml(error.message || "Users could not load from Cloudflare D1.")}</td>
          </tr>
        `;
      }
      updateUserSummary([]);
    }
  }

  async function saveBackendRole(role) {
    const response = await fetch("/api/admin/users?type=role", {
      method: "PUT",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(role),
    });
    if (!response.ok) throw new Error("Role could not be saved to D1.");
    const data = await response.json();
    if (data.role) {
      roleCache = roleCache.map((item) => (item.id === data.role.id ? normalizeBackendRole(data.role) : item));
      renderRoles();
    }
    return true;
  }

  async function saveBackendUser(user, existingId) {
    const response = await fetch("/api/admin/users", {
      method: existingId ? "PUT" : "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(user),
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok) throw new Error(data?.error || "User could not be saved to D1.");
    if (data.user) {
      const normalized = normalizeBackendUser(data.user);
      userCache = existingId
        ? userCache.map((item) => (item.id === existingId ? normalized : item))
        : [...userCache.filter((item) => item.id !== normalized.id), normalized];
      renderUsers();
    }
    return true;
  }

  async function deleteBackendUser(userId) {
    const response = await fetch(`/api/admin/users?id=${encodeURIComponent(userId)}`, {
      method: "DELETE",
    });
    if (!response.ok) throw new Error("User could not be removed from D1.");
    return true;
  }

  function setField(name, value) {
    const element = editor?.querySelector(`[name="${name}"]`);
    if (element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement) {
      element.value = String(value ?? "");
    }
  }

  function getField(name) {
    const element = editor?.querySelector(`[name="${name}"]`);
    return element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement
      ? element.value.trim()
      : "";
  }

  function setPermissions(permissions) {
    editor?.querySelectorAll('input[name="permissions"]').forEach((input) => {
      if (input instanceof HTMLInputElement) {
        input.checked = permissions.includes(input.value);
      }
    });
  }

  function getPermissions() {
    return Array.from(editor?.querySelectorAll('input[name="permissions"]:checked') || [])
      .filter((input) => input instanceof HTMLInputElement)
      .map((input) => input.value);
  }

  function setUserField(name, value) {
    const element = userEditor?.querySelector(`[name="${name}"]`);
    if (
      element instanceof HTMLInputElement ||
      element instanceof HTMLSelectElement ||
      element instanceof HTMLTextAreaElement
    ) {
      element.value = String(value ?? "");
    }
  }

  function getUserField(name) {
    const element = userEditor?.querySelector(`[name="${name}"]`);
    return element instanceof HTMLInputElement ||
      element instanceof HTMLSelectElement ||
      element instanceof HTMLTextAreaElement
      ? element.value.trim()
      : "";
  }

  function userIdFromEmail(email) {
    return String(email || "user")
      .toLowerCase()
      .trim()
      .replace(/@.*/, "")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");
  }

  function permissionsForAccessLevel(accessLevel) {
    const role = readRoles().find((item) => item.accessLevel === accessLevel);
    return role?.permissions || [];
  }

  function setUserPermissions(permissions) {
    userEditor?.querySelectorAll('input[name="userPermissions"]').forEach((input) => {
      if (input instanceof HTMLInputElement) {
        input.checked = permissions.includes(input.value);
      }
    });
  }

  function getUserPermissions() {
    return Array.from(userEditor?.querySelectorAll('input[name="userPermissions"]:checked') || [])
      .filter((input) => input instanceof HTMLInputElement)
      .map((input) => input.value);
  }

  function renderRoles() {
    if (!roleList) return;

    roleList.innerHTML = readRoles()
      .map(
        (role) => `
          <button class="quick-link quick-link--panel role-card" type="button" data-edit-role="${escapeHtml(
            role.id,
          )}">
            <strong>${escapeHtml(role.name)}</strong>
            <span>${escapeHtml(role.description)}</span>
            <small>${escapeHtml(role.accessGroup)}</small>
          </button>
        `,
      )
      .join("");
  }

  function updateUserSummary(users) {
    const totalUsers = document.getElementById("total-users");
    const totalAdmins = document.getElementById("total-admins");
    const totalCreators = document.getElementById("total-creators");
    const totalNormalUsers = document.getElementById("total-normal-users");

    if (totalUsers) totalUsers.textContent = String(users.length);
    if (totalAdmins) {
      totalAdmins.textContent = String(
        users.filter((user) => user.accessLevel === "Admin").length,
      );
    }
    if (totalCreators) {
      totalCreators.textContent = String(
        users.filter((user) => user.accessLevel === "Creator / Reviewer").length,
      );
    }
    if (totalNormalUsers) {
      totalNormalUsers.textContent = String(
        users.filter((user) => user.accessLevel === "Normal User").length,
      );
    }
  }

  function renderUsers() {
    if (!userList) return;

    const users = readUsers().sort((a, b) => a.name.localeCompare(b.name));
    updateUserSummary(users);

    userList.innerHTML = users
      .map(
        (user) => `
          <tr data-edit-user="${escapeHtml(user.id)}" tabindex="0">
            <td>${escapeHtml(user.name)}</td>
            <td>${escapeHtml(user.email)}</td>
            <td>${escapeHtml(user.department)}</td>
            <td>${escapeHtml(user.accessLevel)}</td>
            <td>${escapeHtml((user.permissions || []).join(", "))}</td>
            <td>${escapeHtml(user.status || "Active")}</td>
            <td>
              <button class="button button--secondary" type="button" data-edit-user="${escapeHtml(
                user.id,
              )}">
                Edit User
              </button>
            </td>
          </tr>
        `,
      )
      .join("");
  }

  function openEditor(roleId) {
    const role = readRoles().find((item) => item.id === roleId);
    if (!role || !(editor instanceof HTMLFormElement)) return;

    setField("id", role.id);
    setField("name", role.name);
    setField("accessGroup", role.accessGroup);
    setField("landingPage", role.landingPage);
    setField("description", role.description);
    setPermissions(role.permissions || []);

    if (editorHeading) editorHeading.textContent = `Edit ${role.name}`;
    if (confirmation) confirmation.hidden = true;
    editor.hidden = false;
    editor.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function openCreateUserEditor() {
    if (!(userEditor instanceof HTMLFormElement)) return;

    userEditor.reset();
    setUserField("id", "");
    setUserField("name", "");
    setUserField("email", "");
    renderDepartmentOptions("");
    setUserField("accessLevel", "Normal User");
    setUserField("status", "Active");
    setUserPermissions(permissionsForAccessLevel("Normal User"));
    updateUserSaveState();

    if (userEditorHeading) userEditorHeading.textContent = "Add User";
    if (deleteUserButton instanceof HTMLButtonElement) deleteUserButton.hidden = true;
    if (userConfirmation) userConfirmation.hidden = true;
    userEditor.hidden = false;
    userEditor.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function openUserEditor(userId) {
    const user = readUsers().find((item) => item.id === userId);
    if (!user || !(userEditor instanceof HTMLFormElement)) return;

    setUserField("id", user.id);
    setUserField("name", user.name);
    setUserField("email", user.email);
    renderDepartmentOptions(user.departmentId || "");
    setUserField("accessLevel", user.accessLevel);
    setUserField("status", user.status || "Active");
    setUserPermissions(user.permissions || permissionsForAccessLevel(user.accessLevel));
    updateUserSaveState();

    if (userEditorHeading) userEditorHeading.textContent = `Edit ${user.name}`;
    if (deleteUserButton instanceof HTMLButtonElement) deleteUserButton.hidden = false;
    if (userConfirmation) userConfirmation.hidden = true;
    userEditor.hidden = false;
    userEditor.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  roleList?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const button = target.closest("[data-edit-role]");
    if (!(button instanceof HTMLElement)) return;

    openEditor(button.dataset.editRole);
  });

  createUserButton?.addEventListener("click", openCreateUserEditor);

  userList?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const row = target.closest("[data-edit-user]");
    if (!(row instanceof HTMLElement)) return;

    openUserEditor(row.dataset.editUser);
  });

  userList?.addEventListener("keydown", (event) => {
    if (event.key !== "Enter" && event.key !== " ") return;

    const target = event.target;
    if (!(target instanceof HTMLElement) || !target.matches("tr[data-edit-user]")) return;

    event.preventDefault();
    openUserEditor(target.dataset.editUser);
  });

  userEditor?.querySelector('[name="accessLevel"]')?.addEventListener("change", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLSelectElement)) return;

    setUserPermissions(permissionsForAccessLevel(target.value));
    updateUserSaveState();
  });

  departmentSelect?.addEventListener("change", updateUserSaveState);

  editor?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const roleId = getField("id");
    const existingRole = readRoles().find((role) => role.id === roleId);
    const updated = {
      ...existingRole,
      id: roleId,
      name: getField("name"),
      accessGroup: getField("accessGroup"),
      landingPage: getField("landingPage"),
      description: getField("description"),
      permissions: getPermissions(),
      updatedAt: new Date().toISOString(),
    };

    if (confirmation) {
      confirmation.hidden = false;
      confirmation.innerHTML = "<strong>Saving role...</strong>";
    }

    try {
      await saveBackendRole(updated);
      if (editorHeading) editorHeading.textContent = `Edit ${updated.name}`;
      if (confirmation) {
        confirmation.hidden = false;
        confirmation.innerHTML =
          "<strong>Role saved.</strong><p>This user role configuration is saved in Cloudflare D1.</p>";
      }
    } catch {
      if (confirmation) {
        confirmation.hidden = false;
        confirmation.innerHTML =
          "<strong>Role was not saved.</strong><p>The Cloudflare D1 role update failed. Please try again.</p>";
      }
    }
  });

  cancelButton?.addEventListener("click", () => {
    if (editor instanceof HTMLFormElement) {
      editor.hidden = true;
      editor.reset();
    }
  });

  userEditor?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const existingId = getUserField("id");
    const existingUser = readUsers().find((user) => user.id === existingId);
    const accessLevel = getUserField("accessLevel");
    const role = readRoles().find((item) => item.accessLevel === accessLevel);
    const departmentId = getUserField("departmentId");
    if (!validDepartmentIds().has(departmentId)) {
      if (userConfirmation) {
        userConfirmation.hidden = false;
        userConfirmation.innerHTML =
          "<strong>Select a department.</strong><p>Choose an active department from the list before saving this account.</p>";
      }
      updateUserSaveState();
      return;
    }
    const updated = {
      ...existingUser,
      id: existingId || userIdFromEmail(getUserField("email")),
      name: getUserField("name"),
      email: getUserField("email"),
      departmentId,
      teamId: departmentId,
      accessLevel,
      roleIds: role ? [role.id] : existingUser?.roleIds || [],
      teamIds: existingUser?.teamIds || [],
      permissions: getUserPermissions(),
      status: getUserField("status") || "Active",
      createdAt: existingUser?.createdAt || new Date().toISOString(),
      updatedAt: new Date().toISOString(),
    };

    let users = readUsers();
    const emailAlreadyExists = users.some(
      (user) => user.email.toLowerCase() === updated.email.toLowerCase() && user.id !== existingId,
    );

    if (emailAlreadyExists) {
      if (userConfirmation) {
        userConfirmation.hidden = false;
        userConfirmation.innerHTML =
          "<strong>Email already exists.</strong><p>Use a unique email address before saving this account.</p>";
      }
      return;
    }

    if (userConfirmation) {
      userConfirmation.hidden = false;
      userConfirmation.innerHTML = "<strong>Saving user...</strong>";
    }

    try {
      await saveBackendUser(updated, existingId);
      setUserField("id", updated.id);

      if (userEditorHeading) userEditorHeading.textContent = `Edit ${updated.name}`;
      if (deleteUserButton instanceof HTMLButtonElement) deleteUserButton.hidden = false;
      if (userConfirmation) {
        userConfirmation.hidden = false;
        userConfirmation.innerHTML =
          "<strong>User saved.</strong><p>This account and permission update is saved in Cloudflare D1.</p>";
      }
    } catch {
      if (userConfirmation) {
        userConfirmation.hidden = false;
        userConfirmation.innerHTML =
          "<strong>User was not saved.</strong><p>The Cloudflare D1 user update failed. Please try again.</p>";
      }
    }
  });

  deleteUserButton?.addEventListener("click", async () => {
    const userId = getUserField("id");
    const userName = getUserField("name") || "this user";
    if (!userId) return;

    const confirmed = window.confirm(`Remove "${userName}" from the SOP Knowledge Hub?`);
    if (!confirmed) return;

    try {
      await deleteBackendUser(userId);
      const users = readUsers().filter((user) => user.id !== userId);
      userCache = users;
      renderUsers();

      if (userEditor instanceof HTMLFormElement) {
        userEditor.reset();
        userEditor.hidden = true;
      }
    } catch {
      if (userConfirmation) {
        userConfirmation.hidden = false;
        userConfirmation.innerHTML =
          "<strong>User was not removed.</strong><p>The Cloudflare D1 update failed. Please try again.</p>";
      }
    }
  });

  cancelUserButton?.addEventListener("click", () => {
    if (userEditor instanceof HTMLFormElement) {
      userEditor.hidden = true;
      userEditor.reset();
    }
  });

  loadBackendUsers();
</script>
