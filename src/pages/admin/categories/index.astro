---
import Layout from "../../../components/Layout.astro";
import AppIllustration from "../../../components/AppIllustration.astro";

// Future access note: restrict this route to admins with Cloudflare Access.
---

<Layout title="Admin Categories" wide>
  <section class="tool-surface" aria-labelledby="admin-categories-heading">
    <div class="section-heading surface-intro">
      <div>
        <p class="eyebrow">Admin</p>
        <h1 id="admin-categories-heading">Categories</h1>
        <p>Manage the SOP category structure used across search, finder, and request intake.</p>
      </div>
      <AppIllustration name="categories" size="md" />
    </div>

    <div class="form-actions">
      <button class="button button--primary" type="button" id="create-category">
        Create Category
      </button>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Category</th>
            <th scope="col">Description</th>
            <th scope="col">Action</th>
          </tr>
        </thead>
        <tbody id="admin-category-list">
          <tr>
            <td colspan="3">Loading categories from Cloudflare D1...</td>
          </tr>
        </tbody>
      </table>
    </div>

    <form class="form-grid admin-category-editor" id="category-editor" hidden>
      <h2 class="form-section-title field--full" id="category-editor-heading">Edit Category</h2>
      <input id="category-original-slug" name="originalSlug" type="hidden" />
      <input id="category-slug" name="slug" type="hidden" />
      <div class="field">
        <label for="category-name">Category name</label>
        <input id="category-name" name="name" type="text" required />
      </div>
      <div class="field">
        <label for="category-color">Color</label>
        <input id="category-color" name="color" type="color" />
      </div>
      <div class="field field--full">
        <label for="category-icon">Icon</label>
        <input id="category-icon" name="icon" type="text" />
      </div>
      <div class="field field--full">
        <label for="category-description">Description</label>
        <textarea id="category-description" name="description" rows="3" required></textarea>
      </div>
      <div class="form-actions field--full">
        <button class="button button--primary" type="submit">Save Category</button>
        <button class="button button--danger" type="button" id="delete-category">
          Delete Category
        </button>
        <button class="button button--ghost" type="button" id="cancel-category-edit">
          Cancel
        </button>
      </div>
      <div class="confirmation field--full" id="category-confirmation" role="status" hidden></div>
    </form>
  </section>
</Layout>

<script is:inline>
  const list = document.getElementById("admin-category-list");
  const editor = document.getElementById("category-editor");
  const editorHeading = document.getElementById("category-editor-heading");
  const createButton = document.getElementById("create-category");
  const deleteButton = document.getElementById("delete-category");
  const cancelButton = document.getElementById("cancel-category-edit");
  const confirmation = document.getElementById("category-confirmation");
  let categoryCache = [];

  const escapeHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  const slugify = (value) =>
    String(value)
      .toLowerCase()
      .trim()
      .replace(/&/g, "and")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");

  function readCategories() {
    return categoryCache;
  }

  async function loadBackendCategories() {
    try {
      const response = await fetch("/api/admin/categories");
      if (!response.ok) throw new Error("Category data could not load from D1.");
      const data = await response.json();
      if (!Array.isArray(data.categories)) throw new Error("Category data was not returned by D1.");
      categoryCache = data.categories;
      renderCategories();
    } catch (error) {
      if (list) {
        list.innerHTML = `
          <tr>
            <td colspan="3">${escapeHtml(error.message || "Categories could not load from Cloudflare D1.")}</td>
          </tr>
        `;
      }
    }
  }

  async function saveBackendCategory(category, originalSlug) {
    const response = await fetch("/api/admin/categories", {
      method: originalSlug ? "PUT" : "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ ...category, originalSlug }),
    });
    if (!response.ok) throw new Error("Category could not be saved to D1.");
    const data = await response.json();
    if (data.category) {
      categoryCache = originalSlug
        ? categoryCache.map((item) => (item.slug === originalSlug ? data.category : item))
        : [...categoryCache.filter((item) => item.slug !== data.category.slug), data.category];
      renderCategories();
    }
    return true;
  }

  async function deleteBackendCategory(slug) {
    const response = await fetch(`/api/admin/categories?slug=${encodeURIComponent(slug)}`, {
      method: "DELETE",
    });
    if (!response.ok) throw new Error("Category could not be deleted from D1.");
    return true;
  }

  function setField(name, value) {
    const element = editor?.querySelector(`[name="${name}"]`);
    if (element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement) {
      element.value = String(value ?? "");
    }
  }

  function getField(name) {
    const element = editor?.querySelector(`[name="${name}"]`);
    return element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement
      ? element.value.trim()
      : "";
  }

  function renderCategories() {
    if (!list) return;

    list.innerHTML = readCategories()
      .map(
        (category) => `
          <tr data-edit-category="${escapeHtml(category.slug)}" tabindex="0">
            <td>${escapeHtml(category.icon || "")} ${escapeHtml(category.name)}</td>
            <td>${escapeHtml(category.description)}</td>
            <td>
              <button class="button button--secondary" type="button" data-edit-category="${escapeHtml(
                category.slug,
              )}">
                Edit Category
              </button>
            </td>
          </tr>
        `,
      )
      .join("");
  }

  function showEditor() {
    if (!(editor instanceof HTMLFormElement)) return;

    editor.hidden = false;
    editor.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function openCreateEditor() {
    if (!(editor instanceof HTMLFormElement)) return;

    editor.reset();
    setField("originalSlug", "");
    setField("name", "");
    setField("slug", "");
    setField("description", "");
    setField("icon", "");
    setField("color", "#f8fafc");

    if (editorHeading) editorHeading.textContent = "Create Category";
    if (deleteButton instanceof HTMLButtonElement) deleteButton.hidden = true;
    if (confirmation) confirmation.hidden = true;
    showEditor();
  }

  function openEditor(slug) {
    const category = readCategories().find((item) => item.slug === slug);
    if (!category || !(editor instanceof HTMLFormElement)) return;

    setField("originalSlug", category.slug);
    setField("name", category.name);
    setField("slug", category.slug);
    setField("description", category.description);
    setField("icon", category.icon);
    setField("color", category.color || "#f8fafc");

    if (editorHeading) editorHeading.textContent = `Edit ${category.name}`;
    if (deleteButton instanceof HTMLButtonElement) deleteButton.hidden = false;
    if (confirmation) confirmation.hidden = true;
    showEditor();
  }

  createButton?.addEventListener("click", openCreateEditor);

  list?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const row = target.closest("[data-edit-category]");
    if (!(row instanceof HTMLElement)) return;

    openEditor(row.dataset.editCategory);
  });

  list?.addEventListener("keydown", (event) => {
    if (event.key !== "Enter" && event.key !== " ") return;

    const target = event.target;
    if (!(target instanceof HTMLElement) || !target.matches("tr[data-edit-category]")) return;

    event.preventDefault();
    openEditor(target.dataset.editCategory);
  });

  editor?.addEventListener("input", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLInputElement) || target.name !== "name") return;

    const slug = getField("slug");
    const originalSlug = getField("originalSlug");
    if (!slug || slug === originalSlug) {
      setField("slug", slugify(target.value));
    }
  });

  editor?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const originalSlug = getField("originalSlug");
    const existingCategory = readCategories().find((category) => category.slug === originalSlug);
    const slug = slugify(getField("slug") || getField("name"));
    const updated = {
      ...existingCategory,
      id: existingCategory?.id || `category-${slug}`,
      name: getField("name"),
      slug,
      description: getField("description"),
      icon: getField("icon"),
      color: getField("color") || "#f8fafc",
      sortOrder: existingCategory?.sortOrder || readCategories().length * 10 + 10,
      status: existingCategory?.status || "Active",
      createdAt: existingCategory?.createdAt || new Date().toISOString(),
      updatedAt: new Date().toISOString(),
    };

    let categories = readCategories();
    const slugAlreadyExists = categories.some(
      (category) => category.slug === updated.slug && category.slug !== originalSlug,
    );

    if (slugAlreadyExists) {
      if (confirmation) {
        confirmation.hidden = false;
        confirmation.innerHTML =
          "<strong>Slug already exists.</strong><p>Use a unique slug before saving this category.</p>";
      }
      return;
    }

    if (confirmation) {
      confirmation.hidden = false;
      confirmation.innerHTML = "<strong>Saving category...</strong>";
    }

    try {
      await saveBackendCategory(updated, originalSlug);
      setField("originalSlug", updated.slug);
      if (editorHeading) editorHeading.textContent = `Edit ${updated.name}`;
      if (deleteButton instanceof HTMLButtonElement) deleteButton.hidden = false;

      if (confirmation) {
        confirmation.hidden = false;
        confirmation.innerHTML =
          "<strong>Category saved.</strong><p>This admin category change is saved in Cloudflare D1.</p>";
      }
    } catch {
      if (confirmation) {
        confirmation.hidden = false;
        confirmation.innerHTML =
          "<strong>Category was not saved.</strong><p>The Cloudflare D1 update failed. Please try again.</p>";
      }
    }
  });

  deleteButton?.addEventListener("click", async () => {
    const originalSlug = getField("originalSlug");
    const categoryName = getField("name") || "this category";
    if (!originalSlug) return;

    const confirmed = window.confirm(
      `Delete "${categoryName}"? SOPs using this category will not be reassigned automatically.`,
    );
    if (!confirmed) return;

    try {
      await deleteBackendCategory(originalSlug);
      const categories = readCategories().filter((category) => category.slug !== originalSlug);
      categoryCache = categories;
      renderCategories();

      if (editor instanceof HTMLFormElement) {
        editor.reset();
        editor.hidden = true;
      }
    } catch {
      if (confirmation) {
        confirmation.hidden = false;
        confirmation.innerHTML =
          "<strong>Category was not deleted.</strong><p>The Cloudflare D1 delete failed. Please try again.</p>";
      }
    }
  });

  cancelButton?.addEventListener("click", () => {
    if (editor instanceof HTMLFormElement) {
      editor.hidden = true;
      editor.reset();
    }
  });

  loadBackendCategories();
</script>
