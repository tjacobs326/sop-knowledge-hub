---
import Layout from "../../../components/Layout.astro";
import StatusBadge from "../../../components/StatusBadge.astro";
import { mockDrafts } from "../../../data/mock-drafts";
import { mockSubmissions } from "../../../data/mock-submissions";
import {
  approvalCycles,
  searchLogs,
  sopUsageSignals,
  topMissingRequests,
} from "../../../data/mock-platform";
import { daysUntil, formatDate } from "../../../lib/dates";
import { getAllSops, getSopUrl } from "../../../lib/sops";

// Future access note: restrict this route to admins with Cloudflare Access.
const sops = await getAllSops();

const searchTerms = searchLogs
  .filter((log) => log.resultType === "Result")
  .map((log) => [log.query, Math.max(log.resultCount, 1)] as const);

const noResultSearches = searchLogs
  .filter((log) => log.resultType === "No Result")
  .map((log) => [log.query, Math.max(log.resultCount, 1)] as const);

const sopById = new Map(sops.map((sop) => [sop.data.id, sop]));
const mostViewed = sopUsageSignals
  .map((signal) => ({ ...signal, sop: sopById.get(signal.sopId) }))
  .filter((item) => item.sop)
  .sort((a, b) => b.views - a.views);

const ratingTotals = sopUsageSignals.reduce(
  (total, item) => ({
    helpful: total.helpful + item.helpful,
    notHelpful: total.notHelpful + item.notHelpful,
  }),
  { helpful: 0, notHelpful: 0 },
);
const totalRatings = ratingTotals.helpful + ratingTotals.notHelpful;
const helpfulRate = totalRatings > 0 ? Math.round((ratingTotals.helpful / totalRatings) * 100) : 0;

const approvalDurations = approvalCycles.map((cycle) => {
  const submitted = new Date(`${cycle.submitted}T00:00:00`);
  const approved = new Date(`${cycle.approved}T00:00:00`);
  return Math.round((approved.getTime() - submitted.getTime()) / (1000 * 60 * 60 * 24));
});
const averageApprovalDays =
  approvalDurations.length > 0
    ? Math.round(
        approvalDurations.reduce((total, days) => total + days, 0) / approvalDurations.length,
      )
    : 0;

const pastReview = sops
  .map((sop) => ({ sop, days: daysUntil(sop.data.reviewDate) }))
  .filter((item) => item.days !== null && item.days < 0)
  .sort((a, b) => (a.days ?? 0) - (b.days ?? 0));

const categoryCounts = [...new Set(sops.map((sop) => sop.data.category))]
  .map((category) => ({
    category,
    count: sops.filter((sop) => sop.data.category === category).length,
  }))
  .sort((a, b) => b.count - a.count || a.category.localeCompare(b.category));
const maxCategoryCount = Math.max(...categoryCounts.map((item) => item.count), 1);

const topStats = [
  ["Total SOP Views", sopUsageSignals.reduce((total, item) => total + item.views, 0)],
  ["Helpful Rating", `${helpfulRate}%`],
  ["Avg. Time to Approval", `${averageApprovalDays} days`],
  ["Past Review Date", pastReview.length],
  ["Searches With No Results", noResultSearches.reduce((total, [, count]) => total + count, 0)],
  ["Open Requests", mockSubmissions.length + mockDrafts.length],
];
---

<Layout title="Analytics" wide>
  <section class="tool-surface analytics-dashboard" aria-labelledby="analytics-heading">
    <div class="section-heading">
      <p class="eyebrow">Admin</p>
      <h1 id="analytics-heading">Analytics</h1>
      <p>
        Usage, search, review, and request signals that show where the SOP Knowledge Hub is
        delivering value and where teams need better documentation.
      </p>
    </div>

    <p class="analytics-note">
      Live Cloudflare analytics load from D1 when this page is running on Cloudflare Pages. The
      sample operating metrics below remain as a fallback for local static preview.
    </p>

    <section class="dashboard-section analytics-card" aria-labelledby="cloudflare-analytics-heading">
      <div class="dashboard-section-heading">
        <h2 id="cloudflare-analytics-heading">Cloudflare Live Analytics</h2>
        <span class="status-badge status-badge--in-review" id="cloudflare-analytics-status">
          Loading
        </span>
      </div>
      <div class="stat-grid" id="cloudflare-stat-grid">
        <article class="stat-card">
          <span>Page Views</span>
          <strong>--</strong>
        </article>
        <article class="stat-card">
          <span>SOP Views</span>
          <strong>--</strong>
        </article>
        <article class="stat-card">
          <span>Searches</span>
          <strong>--</strong>
        </article>
        <article class="stat-card">
          <span>Media Uploads</span>
          <strong>--</strong>
        </article>
      </div>
      <div class="analytics-grid analytics-grid--compact" id="cloudflare-analytics-tables">
        <p class="empty-state">Connecting to Cloudflare analytics...</p>
      </div>
    </section>

    <div class="stat-grid" id="analytics-top-stats">
      {topStats.map(([label, value]) => (
        <article class="stat-card">
          <span>{label}</span>
          <strong>{value}</strong>
        </article>
      ))}
    </div>

    <section class="dashboard-section analytics-grid" aria-label="Usage analytics">
      <article class="analytics-card">
        <h2>Most Viewed SOPs</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">SOP</th>
                <th scope="col">Views</th>
                <th scope="col">Helpful</th>
              </tr>
            </thead>
            <tbody id="analytics-most-viewed">
              {mostViewed.map((item) => (
                <tr>
                  <td><a href={getSopUrl(item.sop!)}>{item.sop!.data.title}</a></td>
                  <td>{item.views}</td>
                  <td>{item.helpful}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>

      <article class="analytics-card">
        <h2>Most Searched Terms</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Term</th>
                <th scope="col">Searches</th>
              </tr>
            </thead>
            <tbody>
              {searchTerms.map(([term, count]) => (
                <tr>
                  <td>{term}</td>
                  <td>{count}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>

      <article class="analytics-card">
        <h2>Searches With No Results</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Term</th>
                <th scope="col">Count</th>
              </tr>
            </thead>
            <tbody>
              {noResultSearches.map(([term, count]) => (
                <tr>
                  <td>{term}</td>
                  <td>{count}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>

      <article class="analytics-card">
        <h2>Helpful / Not Helpful Ratings</h2>
        <div class="rating-summary" id="analytics-helpful-summary" aria-label="Helpful rating summary">
          <strong>{helpfulRate}% helpful</strong>
          <span>{ratingTotals.helpful} helpful responses</span>
          <span>{ratingTotals.notHelpful} not helpful responses</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">SOP</th>
                <th scope="col">Helpful</th>
                <th scope="col">Not Helpful</th>
              </tr>
            </thead>
            <tbody id="analytics-helpful-table">
              {mostViewed.map((item) => (
                <tr>
                  <td>{item.sop!.data.title}</td>
                  <td>{item.helpful}</td>
                  <td>{item.notHelpful}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    </section>

    <section class="dashboard-section analytics-grid" aria-label="Review and request analytics">
      <article class="analytics-card">
        <h2>SOPs Past Review Date</h2>
        {
          pastReview.length > 0 ? (
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th scope="col">SOP</th>
                    <th scope="col">Review Date</th>
                    <th scope="col">Status</th>
                    <th scope="col">Days Past Due</th>
                  </tr>
                </thead>
                <tbody id="analytics-past-review">
                  {pastReview.map((item) => (
                    <tr>
                      <td><a href={getSopUrl(item.sop)}>{item.sop.data.title}</a></td>
                      <td>{formatDate(item.sop.data.reviewDate)}</td>
                      <td><StatusBadge status="Past Due" /></td>
                      <td>{Math.abs(item.days ?? 0)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <p class="empty-state">No SOPs are past review date.</p>
          )
        }
      </article>

      <article class="analytics-card">
        <h2>Average Time to Approval</h2>
        <div class="rating-summary">
          <strong>{averageApprovalDays} days</strong>
          <span>Average from recent approved SOP cycles</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">SOP</th>
                <th scope="col">Submitted</th>
                <th scope="col">Approved</th>
              </tr>
            </thead>
            <tbody>
              {approvalCycles.map((cycle) => (
                <tr>
                  <td>{cycle.title}</td>
                  <td>{formatDate(cycle.submitted)}</td>
                  <td>{formatDate(cycle.approved)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>

      <article class="analytics-card">
        <h2>Number of SOPs by Category</h2>
        <div class="category-breakdown" id="analytics-category-breakdown">
          {categoryCounts.map((item) => (
            <div class="category-bar">
              <div>
                <strong>{item.category}</strong>
                <span>{item.count} SOP{item.count === 1 ? "" : "s"}</span>
              </div>
              <meter min="0" max={maxCategoryCount} value={item.count}>{item.count}</meter>
            </div>
          ))}
        </div>
      </article>

      <article class="analytics-card">
        <h2>Top Requested Missing SOPs</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th scope="col">Requested SOP</th>
                <th scope="col">Requests</th>
              </tr>
            </thead>
            <tbody>
              {topMissingRequests.map(({ title, count }) => (
                <tr>
                  <td>{title}</td>
                  <td>{count}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    </section>
  </section>
</Layout>

<script>
  // @ts-nocheck
  import { fetchAnalyticsSummary } from "../../../lib/sop-api";

  const status = document.getElementById("cloudflare-analytics-status");
  const statGrid = document.getElementById("cloudflare-stat-grid");
  const tables = document.getElementById("cloudflare-analytics-tables");

  const escapeHtml = (value: unknown) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements: Record<string, string> = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character] || character;
    });

  const numberFormat = new Intl.NumberFormat();

  function formatDateClient(value: unknown) {
    if (!value) return "Not set";
    const date = new Date(String(value).includes("T") ? String(value) : `${String(value).slice(0, 10)}T00:00:00`);
    if (Number.isNaN(date.getTime())) return String(value);
    return new Intl.DateTimeFormat("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    }).format(date);
  }

  function renderRows(rows: Array<Record<string, unknown>>, columns: Array<[string, string]>) {
    if (!rows.length) return `<p class="empty-state">No live events recorded yet.</p>`;

    return `
      <div class="table-wrap">
        <table>
          <thead>
            <tr>${columns.map(([, label]) => `<th scope="col">${escapeHtml(label)}</th>`).join("")}</tr>
          </thead>
          <tbody>
            ${rows
              .map(
                (row) => `
                  <tr>
                    ${columns
                      .map(([field]) => `<td>${escapeHtml(row[field])}</td>`)
                      .join("")}
                  </tr>
                `,
              )
              .join("")}
          </tbody>
        </table>
      </div>
    `;
  }

  function renderLiveAnalytics(data: any) {
    if (status) {
      status.textContent = "Live";
      status.className = "status-badge status-badge--published";
    }

    const totals = data.totals || {};
    if (statGrid) {
      statGrid.innerHTML = [
        ["Page Views", totals.page_views],
        ["SOP Views", totals.sop_views],
        ["Searches", totals.searches],
        ["Media Uploads", totals.uploads],
      ]
        .map(
          ([label, value]) => `
            <article class="stat-card">
              <span>${escapeHtml(label)}</span>
              <strong>${numberFormat.format(Number(value || 0))}</strong>
            </article>
          `,
        )
        .join("");
    }

    if (tables) {
      tables.innerHTML = `
        <article class="analytics-card">
          <h3>Live Most Viewed SOPs</h3>
          ${renderRows(data.mostViewedSops || [], [
            ["title", "SOP"],
            ["views", "Views"],
          ])}
        </article>
        <article class="analytics-card">
          <h3>Live Search Terms</h3>
          ${renderRows(data.mostSearchedTerms || [], [
            ["query", "Term"],
            ["searches", "Searches"],
          ])}
        </article>
        <article class="analytics-card">
          <h3>Live No-Result Searches</h3>
          ${renderRows(data.noResultSearches || [], [
            ["query", "Term"],
            ["searches", "Searches"],
          ])}
        </article>
        <article class="analytics-card">
          <h3>Media Stored in R2</h3>
          ${renderRows(data.mediaSummary || [], [
            ["asset_type", "Type"],
            ["count", "Files"],
            ["bytes", "Bytes"],
          ])}
        </article>
      `;
    }

    const topStats = document.getElementById("analytics-top-stats");
    const liveTotals = data.totals || {};
    const helpfulRows = data.helpfulRatings || [];
    const helpful = Number(helpfulRows.find((row: any) => String(row.rating).toLowerCase() === "helpful")?.count || 0);
    const notHelpful = Number(helpfulRows.find((row: any) => String(row.rating).toLowerCase() === "not_helpful")?.count || 0);
    const totalRatings = helpful + notHelpful;
    const helpfulRate = totalRatings > 0 ? Math.round((helpful / totalRatings) * 100) : 0;

    if (topStats) {
      topStats.innerHTML = [
        ["Total SOP Views", liveTotals.sop_views],
        ["Helpful Rating", `${helpfulRate}%`],
        ["Avg. Time to Approval", "Live"],
        ["Past Review Date", (data.pastReview || []).length],
        ["Searches With No Results", (data.noResultSearches || []).reduce((total: number, row: any) => total + Number(row.searches || 0), 0)],
        ["Open Requests", "Live"],
      ]
        .map(
          ([label, value]) => `
            <article class="stat-card">
              <span>${escapeHtml(label)}</span>
              <strong>${escapeHtml(value ?? 0)}</strong>
            </article>
          `,
        )
        .join("");
    }

    const mostViewed = document.getElementById("analytics-most-viewed");
    if (mostViewed) {
      mostViewed.innerHTML = (data.mostViewedSops || []).length
        ? (data.mostViewedSops || [])
            .map(
              (row: any) => `
                <tr>
                  <td>${escapeHtml(row.title)}</td>
                  <td>${escapeHtml(row.views)}</td>
                  <td>${escapeHtml(row.helpful || 0)}</td>
                </tr>
              `,
            )
            .join("")
        : `<tr><td colspan="3"><p class="empty-state">No SOP view events recorded yet.</p></td></tr>`;
    }

    const helpfulSummary = document.getElementById("analytics-helpful-summary");
    if (helpfulSummary) {
      helpfulSummary.innerHTML = `
        <strong>${escapeHtml(helpfulRate)}% helpful</strong>
        <span>${escapeHtml(helpful)} helpful responses</span>
        <span>${escapeHtml(notHelpful)} not helpful responses</span>
      `;
    }

    const helpfulTable = document.getElementById("analytics-helpful-table");
    if (helpfulTable) {
      helpfulTable.innerHTML = helpfulRows.length
        ? helpfulRows
            .map(
              (row: any) => `
                <tr>
                  <td>${escapeHtml(row.rating)}</td>
                  <td>${escapeHtml(row.count)}</td>
                  <td>--</td>
                </tr>
              `,
            )
            .join("")
        : `<tr><td colspan="3"><p class="empty-state">No helpfulness feedback recorded yet.</p></td></tr>`;
    }

    const pastReviewRows = document.getElementById("analytics-past-review");
    if (pastReviewRows && Array.isArray(data.pastReview) && data.pastReview.length) {
      pastReviewRows.innerHTML = data.pastReview
        .map(
          (row: any) => `
            <tr>
              <td><a href="/sops/detail/?id=${encodeURIComponent(row.id)}">${escapeHtml(row.title)}</a></td>
              <td>${escapeHtml(formatDateClient(row.review_date))}</td>
              <td><span class="status-badge status-badge--past-due">Past Due</span></td>
              <td>${escapeHtml(
                Math.max(
                  0,
                  Math.round((Date.now() - new Date(`${String(row.review_date).slice(0, 10)}T00:00:00`).getTime()) / 86400000),
                ),
              )}</td>
            </tr>
          `,
        )
        .join("");
    }

    const categoryBreakdown = document.getElementById("analytics-category-breakdown");
    if (categoryBreakdown && Array.isArray(data.categoryCounts) && data.categoryCounts.length) {
      const max = Math.max(...data.categoryCounts.map((row: any) => Number(row.count || 0)), 1);
      categoryBreakdown.innerHTML = data.categoryCounts
        .map(
          (row: any) => `
            <div class="category-bar">
              <div>
                <strong>${escapeHtml(row.category)}</strong>
                <span>${escapeHtml(row.count)} SOP${Number(row.count) === 1 ? "" : "s"}</span>
              </div>
              <meter min="0" max="${escapeHtml(max)}" value="${escapeHtml(row.count)}">${escapeHtml(row.count)}</meter>
            </div>
          `,
        )
        .join("");
    }
  }

  fetchAnalyticsSummary()
    .then(renderLiveAnalytics)
    .catch(() => {
      if (status) {
        status.textContent = "Static Preview";
        status.className = "status-badge status-badge--draft";
      }
      if (tables) {
        tables.innerHTML =
          '<p class="empty-state">Live analytics are available after deploying with Cloudflare D1 bindings.</p>';
      }
    });
</script>
