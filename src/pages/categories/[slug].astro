---
import Layout from "../../components/Layout.astro";
import SopCard from "../../components/SopCard.astro";
import { categories, getCategoryBySlug } from "../../data/categories";
import { getAllSops, getSopUrl } from "../../lib/sops";

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
  }));
}

const { slug } = Astro.params;
const category = getCategoryBySlug(slug ?? "");
const sops = await getAllSops();
const categorySops = category ? sops.filter((sop) => sop.data.category === category.name) : [];
---

<Layout title={category?.name ?? "Category"} wide>
  <section class="page-section">
    <div class="section-heading">
      <p class="eyebrow">Category</p>
      <h1>{category?.name}</h1>
      <p>{category?.description}</p>
      <p><strong>{categorySops.length}</strong> SOP{categorySops.length === 1 ? "" : "s"}</p>
    </div>
    <div class="filter-row no-print">
      <label for="category-filter">Filter this category</label>
      <input id="category-filter" type="search" placeholder="Filter by title, tag, tool, or owner" />
    </div>
    <div class="sop-grid" id="category-sop-list">
      {
        categorySops.map((sop) => (
          <div
            data-category-sop
            data-search={`${sop.data.title} ${sop.data.purpose} ${sop.data.tags.join(" ")} ${sop.data.tools.join(" ")} ${sop.data.owner}`.toLowerCase()}
          >
            <SopCard
              title={sop.data.title}
              purpose={sop.data.purpose}
              category={sop.data.category}
              tags={sop.data.tags}
              owner={sop.data.owner}
              lastUpdated={sop.data.lastUpdated}
              reviewDate={sop.data.reviewDate}
              tools={sop.data.tools}
              status={sop.data.status}
              url={getSopUrl(sop)}
            />
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<script is:inline>
  const filter = document.getElementById("category-filter");
  const cards = Array.from(document.querySelectorAll("[data-category-sop]"));

  filter?.addEventListener("input", () => {
    const query = filter.value.trim().toLowerCase();
    cards.forEach((card) => {
      card.hidden = query.length > 0 && !card.dataset.search.includes(query);
    });
  });
</script>
