---
import Layout from "../components/Layout.astro";
import SopMetadata from "../components/SopMetadata.astro";
import PrintActions from "../components/PrintActions.astro";
import RelatedSops from "../components/RelatedSops.astro";
import ChangeHistory from "../components/ChangeHistory.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { formatDate } from "../lib/dates";
import { resolveRelatedSops, type SopEntry } from "../lib/sops";
import { EDIT_SOP_STORAGE_KEY, PUBLISHED_SOPS_STORAGE_KEY } from "../lib/drafts";

interface Props {
  sop: SopEntry;
  allSops: SopEntry[];
}

const { sop, allSops } = Astro.props;
const relatedSops = resolveRelatedSops(sop, allSops);
const sopBody = sop.body ?? "";

function getSection(markdown: string, heading: string) {
  const pattern = new RegExp(`## ${heading}\\r?\\n+([\\s\\S]*?)(?=\\r?\\n## |$)`, "i");
  return markdown.match(pattern)?.[1]?.trim() ?? "";
}

function stripMarkdown(value: string) {
  return value
    .replace(/\*\*(.*?)\*\*/g, "$1")
    .replace(/\[(.*?)\]\((.*?)\)/g, "$1")
    .replace(/^[-*]\s+/gm, "")
    .trim();
}

function parseProcedureSteps(markdown: string) {
  const procedure = getSection(markdown, "Procedure");
  const matches = Array.from(procedure.matchAll(/^\d+\.\s+(.+)$/gm));

  return matches.length > 0
    ? matches.map((match) => ({
        title: stripMarkdown(match[1]),
        instructions: stripMarkdown(match[1]),
        note: "",
        screenshot: "",
      }))
    : [
        {
          title: "Review published SOP content",
          instructions: stripMarkdown(procedure || markdown),
          note: "",
          screenshot: "",
        },
      ];
}

function parseBulletList(markdown: string, heading: string) {
  const section = getSection(markdown, heading);
  return Array.from(section.matchAll(/^[-*]\s+(.+)$/gm)).map((match) => stripMarkdown(match[1]));
}

const beforeYouBegin = stripMarkdown(getSection(sopBody, "Before You Begin"));
const procedureSteps = parseProcedureSteps(sopBody);
const troubleshootingNotes = parseBulletList(sopBody, "Troubleshooting / Notes");

const editPayload = {
  sourceId: sop.data.id,
  sourceSlug: sop.data.slug,
  sourceTitle: sop.data.title,
  title: sop.data.title,
  purpose: sop.data.purpose,
  owner: sop.data.owner,
  category: sop.data.category,
  type: sop.data.type,
  reviewDate: sop.data.reviewDate,
  tools: sop.data.tools,
  audience: sop.data.audience,
  tags: sop.data.tags,
  estimatedCompletionTime: sop.data.estimatedCompletionTime,
  beforeYouBegin: getSection(sopBody, "Before You Begin"),
  procedureSteps,
  screenshots: sop.data.screenshots.map((screenshot) => screenshot.src),
  troubleshootingNotes: getSection(sopBody, "Troubleshooting / Notes"),
  relatedSops: sop.data.relatedSops,
  status: "Draft",
  version: sop.data.version,
  changeSummary: `Update published SOP: ${sop.data.title}`,
};
---

<Layout title={sop.data.title} description={sop.data.purpose}>
  <article class="sop-document" data-pagefind-body data-sop-id={sop.data.id}>
    <div class="sop-document__header">
      <p class="eyebrow" id="sop-detail-category">{sop.data.category}</p>
      <div class="sop-title-row">
        <h1 id="sop-detail-title">{sop.data.title}</h1>
        <span id="sop-detail-status"><StatusBadge status={sop.data.status} /></span>
      </div>
      <p class="lede" id="sop-detail-lede">{sop.data.purpose}</p>
      <dl class="sop-hero-meta">
        <div>
          <dt>Owner</dt>
          <dd id="sop-detail-owner">{sop.data.owner}</dd>
        </div>
        <div>
          <dt>Last updated</dt>
          <dd id="sop-detail-last-updated">{formatDate(sop.data.lastUpdated)}</dd>
        </div>
        <div>
          <dt>Next review</dt>
          <dd id="sop-detail-review-date">{formatDate(sop.data.reviewDate)}</dd>
        </div>
        <div>
          <dt>Estimated time</dt>
          <dd id="sop-detail-time">{sop.data.estimatedCompletionTime}</dd>
        </div>
      </dl>
      <PrintActions />
      <div class="sop-edit-actions no-print">
        <a
          class="button button--primary"
          href={`/create/?edit=${encodeURIComponent(sop.data.id)}`}
          data-edit-published-sop
        >
          Edit Published SOP
        </a>
      </div>
    </div>

    <div class="sop-layout">
      <SopMetadata
        owner={sop.data.owner}
        lastUpdated={sop.data.lastUpdated}
        reviewDate={sop.data.reviewDate}
        category={sop.data.category}
        tools={sop.data.tools}
        audience={sop.data.audience}
        status={sop.data.status}
        version={sop.data.version}
        estimatedCompletionTime={sop.data.estimatedCompletionTime}
      />

      <div class="sop-content">
        <section class="sop-section">
          <h2>Purpose</h2>
          <p id="sop-detail-purpose">{sop.data.purpose}</p>
        </section>

        <section class="sop-section sop-callout" aria-labelledby="before-you-begin-heading">
          <h2 id="before-you-begin-heading">Before You Begin</h2>
          <p id="sop-detail-before">{beforeYouBegin || "Review the SOP metadata, required tools, and audience before starting."}</p>
        </section>

        <section class="sop-section" aria-labelledby="procedure-heading">
          <h2 id="procedure-heading">Step-by-Step Procedure</h2>
          <ol class="procedure-list sop-procedure-list" id="sop-detail-procedure">
            {procedureSteps.map((step) => (
              <li>
                <strong>{step.title}</strong>
                {step.instructions !== step.title && <p>{step.instructions}</p>}
              </li>
            ))}
          </ol>
        </section>

        <section class="sop-section" aria-labelledby="checklist-heading">
          <h2 id="checklist-heading">Checklist</h2>
          <ul class="sop-checklist" id="sop-detail-checklist">
            {procedureSteps.map((step) => <li>{step.title}</li>)}
          </ul>
        </section>

        <section class="sop-section" aria-labelledby="troubleshooting-heading">
          <h2 id="troubleshooting-heading">Troubleshooting</h2>
          <div id="sop-detail-troubleshooting">
            {
              troubleshootingNotes.length > 0 ? (
              <ul>
                {troubleshootingNotes.map((note) => <li>{note}</li>)}
              </ul>
            ) : (
              <p>No troubleshooting notes are listed for this SOP.</p>
            )
            }
          </div>
        </section>

        <RelatedSops items={relatedSops} />
        <ChangeHistory entries={sop.data.changeHistory} />

        <section class="sop-section sop-feedback no-print" aria-labelledby="feedback-heading">
          <h2 id="feedback-heading">Was this helpful?</h2>
          <p>Help improve this SOP by sharing whether it answered your question.</p>
          <div class="form-actions">
            <button class="button button--secondary" type="button" data-feedback="Helpful">
              Helpful
            </button>
            <button class="button button--secondary" type="button" data-feedback="Not Helpful">
              Not Helpful
            </button>
            <a
              class="button button--ghost"
              href={`/submit/?type=issue&sop=${encodeURIComponent(sop.data.title)}`}
            >
              Report an Issue
            </a>
          </div>
          <div class="confirmation" data-feedback-confirmation hidden></div>
        </section>
      </div>
    </div>
  </article>
</Layout>

<script
  is:inline
  type="application/json"
  id={`edit-source-${sop.data.id}`}
  set:html={JSON.stringify(editPayload)}
/>

<script is:inline define:vars={{ EDIT_SOP_STORAGE_KEY, sourceId: sop.data.id }}>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const editLink = target.closest("[data-edit-published-sop]");
    if (!(editLink instanceof HTMLAnchorElement)) return;

    const payload = document.getElementById(`edit-source-${sourceId}`)?.textContent;
    if (!payload) return;

    try {
      sessionStorage.setItem(EDIT_SOP_STORAGE_KEY, payload);
    } catch {
      // Continue to the creator route; it will show an empty form if storage is blocked.
    }
  });
</script>

<script is:inline define:vars={{ PUBLISHED_SOPS_STORAGE_KEY, sourceId: sop.data.id }}>
  const escapePublishedHtml = (value) =>
    String(value ?? "").replace(/[&<>"']/g, (character) => {
      const replacements = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      };
      return replacements[character];
    });

  function readPublishedSops() {
    try {
      const records = JSON.parse(localStorage.getItem(PUBLISHED_SOPS_STORAGE_KEY) || "[]");
      return Array.isArray(records) ? records : [];
    } catch {
      return [];
    }
  }

  function formatPublishedDate(value) {
    if (!value) return "Not set";
    const date = new Date(`${String(value).slice(0, 10)}T00:00:00`);
    if (Number.isNaN(date.getTime())) return value;
    return new Intl.DateTimeFormat("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    }).format(date);
  }

  function statusBadgeHtml(status) {
    const className = String(status || "Published").toLowerCase().replace(/[^a-z0-9]+/g, "-");
    return `<span class="status-badge status-badge--${escapePublishedHtml(className)}">${escapePublishedHtml(
      status || "Published",
    )}</span>`;
  }

  function setText(id, value) {
    const element = document.getElementById(id);
    if (element) element.textContent = value || "";
  }

  function setMeta(name, value, html = false) {
    const element = document.querySelector(`[data-sop-meta="${name}"]`);
    if (!element) return;
    if (html) {
      element.innerHTML = value;
    } else {
      element.textContent = value || "";
    }
  }

  function renderPublishedSteps(steps) {
    const procedure = document.getElementById("sop-detail-procedure");
    const checklist = document.getElementById("sop-detail-checklist");
    const safeSteps = Array.isArray(steps) ? steps : [];

    if (procedure) {
      procedure.innerHTML = safeSteps
        .map(
          (step) => `
            <li>
              <strong>${escapePublishedHtml(step.title)}</strong>
              ${step.instructions ? `<p>${escapePublishedHtml(step.instructions)}</p>` : ""}
              ${step.note ? `<p><strong>Note:</strong> ${escapePublishedHtml(step.note)}</p>` : ""}
              ${
                step.screenshot
                  ? `<figure class="step-screenshot"><img src="${escapePublishedHtml(
                      step.screenshot,
                    )}" alt="Screenshot for ${escapePublishedHtml(
                      step.title,
                    )}" /><figcaption>Step screenshot</figcaption></figure>`
                  : ""
              }
              ${
                step.video
                  ? `<figure class="step-screenshot"><video controls src="${escapePublishedHtml(
                      step.video,
                    )}"></video><figcaption>${escapePublishedHtml(
                      step.videoLabel || "Step video",
                    )}</figcaption></figure>`
                  : ""
              }
            </li>
          `,
        )
        .join("");
    }

    if (checklist) {
      checklist.innerHTML = safeSteps
        .map((step) => `<li>${escapePublishedHtml(step.title)}</li>`)
        .join("");
    }
  }

  function renderPublishedTroubleshooting(notes) {
    const container = document.getElementById("sop-detail-troubleshooting");
    if (!container) return;

    const lines = String(notes || "")
      .split(/\n+/)
      .map((line) => line.trim())
      .filter(Boolean);
    container.innerHTML = lines.length
      ? `<ul>${lines.map((line) => `<li>${escapePublishedHtml(line)}</li>`).join("")}</ul>`
      : "<p>No troubleshooting notes are listed for this SOP.</p>";
  }

  function applyPublishedOverride() {
    const published = readPublishedSops().find(
      (record) => record.id === sourceId || record.sourceId === sourceId,
    );
    if (!published) return;

    setText("sop-detail-category", published.category);
    setText("sop-detail-title", published.title);
    setText("sop-detail-lede", published.purpose);
    setText("sop-detail-purpose", published.purpose);
    setText("sop-detail-before", published.beforeYouBegin || "Review the SOP metadata, required tools, and audience before starting.");
    setText("sop-detail-owner", published.owner);
    setText("sop-detail-last-updated", formatPublishedDate(published.lastUpdated || published.updatedDate));
    setText("sop-detail-review-date", formatPublishedDate(published.reviewDate));
    setText("sop-detail-time", published.estimatedCompletionTime || "");

    const statusHtml = statusBadgeHtml("Published");
    const status = document.getElementById("sop-detail-status");
    if (status) status.innerHTML = statusHtml;
    setMeta("owner", published.owner);
    setMeta("lastUpdated", formatPublishedDate(published.lastUpdated || published.updatedDate));
    setMeta("reviewDate", formatPublishedDate(published.reviewDate));
    setMeta("category", published.category);
    setMeta("tools", Array.isArray(published.tools) ? published.tools.join(", ") : "");
    setMeta("audience", Array.isArray(published.audience) ? published.audience.join(", ") : "");
    setMeta("status", statusHtml, true);
    setMeta("version", published.version);
    setMeta("estimatedCompletionTime", published.estimatedCompletionTime || "");

    renderPublishedSteps(published.procedureSteps);
    renderPublishedTroubleshooting(published.troubleshootingNotes);

    const editSource = document.getElementById(`edit-source-${sourceId}`);
    if (editSource) {
      editSource.textContent = JSON.stringify({
        ...published,
        sourceId,
        sourceSlug: published.sourceSlug,
        sourceTitle: published.title,
        status: "Draft",
      });
    }
  }

  applyPublishedOverride();
</script>

<script is:inline>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const button = target.closest("[data-feedback]");
    if (!(button instanceof HTMLElement)) return;

    const panel = button.closest(".sop-feedback");
    const confirmation = panel?.querySelector("[data-feedback-confirmation]");
    if (confirmation instanceof HTMLElement) {
      confirmation.hidden = false;
      confirmation.textContent = `Feedback saved: ${button.dataset.feedback}.`;
    }
  });
</script>
